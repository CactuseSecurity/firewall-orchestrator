[Service]
EnvironmentFile=-/etc/default/slapd
ExecStartPre=/bin/mkdir -p /run/slapd
ExecStartPre=/bin/chown {{ openldap_server_user }}:{{ openldap_server_user }} /run/slapd
ExecStart=
ExecStart=/usr/sbin/slapd{% if slapd_unit_type.stdout == 'notify' %} -d0{% endif %} -u {{ openldap_server_user }} -g {{ openldap_server_user }} -h "${SLAPD_SERVICES}"
