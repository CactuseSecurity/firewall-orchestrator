@page "/help/reporting/reporttypes"
@model FWO.Ui.Pages.Help.MainModel
@{
    Layout = "HelpLayout";
}
@section sidebar{
    @{ 
        await Html.RenderPartialAsync("HelpReportingSidebar.cshtml"); 
    }
}
@using FWO.Config.Api
@inject UserConfig userConfig

<div class="p-2">
    <h3>@userConfig.GetText("report_types")</h3>
        @(Html.Raw(userConfig.GetText("H1102")))
    <p>The Compliance Report table includes an ExpirationTime column that shows the first available rule time expiration.</p>
</div>
