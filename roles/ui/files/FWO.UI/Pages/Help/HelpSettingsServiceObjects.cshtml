@page "/help/settings/flows/serviceobjects"
@model FWO.Ui.Pages.Help.MainModel
@{
    Layout = "HelpLayout";
}
@section sidebar{
    @{
        await Html.RenderPartialAsync("HelpSettingsSidebar.cshtml");
    }
}
@using FWO.Config.Api
@inject UserConfig userConfig

<div class="p-2">
    <h3>@userConfig.GetText("service_objects")</h3>
    <p>This page lists the flow service object catalog, including the per-management mappings that were resolved into each flow row.</p>
    <p>It also supports creating a custom service object from selected management-side services and resolving duplicate mappings.</p>
</div>
