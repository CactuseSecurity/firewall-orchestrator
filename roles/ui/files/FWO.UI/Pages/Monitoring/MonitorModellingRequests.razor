@using FWO.Data.Modelling
@using FWO.Data.Workflow
@using FWO.Services.Workflow

@page "/monitoring/modelling_requests"
@attribute [Authorize(Roles = $"{Roles.Admin}, {Roles.Auditor}")]

@inject ApiConnection apiConnection
@inject UserConfig userConfig

<div class="input-group">
    <h3>@(userConfig.GetText("modelling_request_status"))</h3>
    <HelpLink Page="monitoring/modelling_requests" />
</div>
@(userConfig.GetText("U5121"))
<hr />

@if (userConfig.ModIntegrationMode != ModIntegrationMode.WorkflowNotifications)
{
    <div>@(userConfig.GetText("WorkflowNotifications")) @(userConfig.GetText("inactive"))</div>
}
else if (InitComplete)
{
    <div class="m-2 vheight75">
        <PageSizeComponent PageSize="20" PageSizeCallback="UpdatePageSize"></PageSizeComponent>
        <Table PageSize="PageSize" class="table table-bordered th-bg-secondary table-responsive overflow-auto sticky-header" TableItem="OwnerRequestStatus" Items="Rows" ColumnReorder="true">
            <Column TableItem="OwnerRequestStatus" Title="@(userConfig.GetText("actions"))" Field="@(x => x.TicketId)" Sortable="false" Filterable="false">
                <Template Context="row">
                    @if (row.TicketId > 0)
                    {
                        <AuthorizeView Roles="@Roles.Admin">
                            <Authorized Context="authState">
                                <button type="button" class="btn btn-sm btn-danger" @onclick="() => RequestReset(row)">
                                    @(DisplayService.DisplayButton(userConfig, "reset", Icons.Undo))
                                </button>
                            </Authorized>
                        </AuthorizeView>
                    }
                </Template>
            </Column>
            <Column TableItem="OwnerRequestStatus" Title="@(userConfig.GetText("owner"))" Field="@(x => x.Owner.Name)" Sortable="true" Filterable="true">
                <Template Context="row">
                    @row.Owner.Display(userConfig.GetText("common_service"))
                </Template>
            </Column>
            <Column TableItem="OwnerRequestStatus" Title="@(userConfig.GetText("external_id"))" Field="@(x => x.Owner.ExtAppId)" Sortable="true" Filterable="true" />
            <Column TableItem="OwnerRequestStatus" Title="@(userConfig.GetText("request_status"))" Field="@(x => x.Status)" Sortable="true" Filterable="true" />
            <Column TableItem="OwnerRequestStatus" Title="@(userConfig.GetText("ticket"))" Field="@(x => x.TicketId)" Sortable="true" Filterable="true" />
            <Column TableItem="OwnerRequestStatus" Title="@(userConfig.GetText("ticket_status"))" Field="@(x => x.StateName)" Sortable="true" Filterable="true" />
            <Column TableItem="OwnerRequestStatus" Title="@(userConfig.GetText("open_tasks"))" Field="@(x => x.OpenTaskCount)" Sortable="true" Filterable="true" />
            <Column TableItem="OwnerRequestStatus" Title="@(userConfig.GetText("creation_date"))" Field="@(x => x.CreatedAt)" Sortable="true" Filterable="true" />
            <Column TableItem="OwnerRequestStatus" Title="@(userConfig.GetText("completion_date"))" Field="@(x => x.CompletedAt)" Sortable="true" Filterable="true" />
            <Pager ShowPageNumber="true" ShowTotalCount="true" />
        </Table>
    </div>
}
else
{
    <Loading/>
}

<Confirm @bind-Display="ResetMode" AllowedRoles="@Roles.Admin" PerformAction="ResetOwnerRequestStatus" Title="@userConfig.GetText("confirm")"
    Message="@(userConfig.GetText("U5122") + ResetRow.Owner.Display(userConfig.GetText("common_service")) + "?")" />

@code
{
    [CascadingParameter]
    private Task<AuthenticationState>? authenticationStateTask { get; set; }

    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;

    private List<OwnerRequestStatus> Rows = [];
    private readonly WfStateDict States = new();
    private ExtStateHandler? ExtStateHandler;
    private OwnerRequestStatus ResetRow = new();
    private bool InitComplete = false;
    private bool ResetMode { get; set; } = false;
    private int PageSize { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            apiConnection.SetProperRole(authenticationStateTask!.Result.User, [Roles.Admin, Roles.Auditor]);
            await States.Init(apiConnection);
            ExtStateHandler = new(apiConnection);
            await LoadRows();
            InitComplete = true;
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("fetch_data"), "", true);
        }
    }

    private async Task LoadRows()
    {
        List<FwoOwner> owners = await apiConnection.SendQueryAsync<List<FwoOwner>>(OwnerQueries.getOwnersWithConn);
        List<OwnerTicket> latestTickets = await apiConnection.SendQueryAsync<List<OwnerTicket>>(MonitorQueries.getLatestOwnerTickets);
        Dictionary<int, OwnerTicket> latestByOwner = latestTickets.ToDictionary(ownerTicket => ownerTicket.Owner.Id);

        Rows = [.. owners
            .Select(owner => latestByOwner.TryGetValue(owner.Id, out OwnerTicket? ownerTicket)
                ? BuildRow(owner, ownerTicket.Ticket)
                : OwnerRequestStatus.NoRequest(owner, userConfig.GetText("never_requested")))
            .OrderBy(row => row.Owner.Name)];
    }

    private OwnerRequestStatus BuildRow(FwoOwner owner, WfTicket ticket)
    {
        int openTasks = ExtStateHandler == null ? 0 : ticket.Tasks.Count(task => ExtStateHandler.IsInProgress(task.StateId));
        return new()
        {
            Owner = owner,
            TicketId = ticket.Id,
            StateName = States.Name[ticket.StateId] ?? ticket.StateId.ToString(),
            Status = RequestStatus(ticket),
            OpenTaskCount = openTasks,
            CreatedAt = ticket.CreationDate,
            CompletedAt = ticket.CompletionDate
        };
    }

    private string RequestStatus(WfTicket ticket)
    {
        if (ExtStateHandler == null)
        {
            return "";
        }
        return ExtStateHandler.GetExternalStateName(ticket.StateId) ?? States.Name[ticket.StateId] ?? ticket.StateId.ToString();
    }

    private void RequestReset(OwnerRequestStatus row)
    {
        ResetRow = row;
        ResetMode = true;
    }

    private async Task ResetOwnerRequestStatus()
    {
        try
        {
            await CleanOwnerModellingRequestState(ResetRow.Owner.Id);
            await apiConnection.SendQueryAsync<ReturnId>(MonitorQueries.deleteOwnerTickets, new { ownerId = ResetRow.Owner.Id });
            ResetMode = false;
            ReplaceResetRowDisplay();
            StateHasChanged();
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("modelling_request_status"), "", true);
        }
    }

    private async Task CleanOwnerModellingRequestState(int ownerId)
    {
        string stateMarker = ModIntegrationStateConfig.EffectiveMarker(userConfig.ModIntegrationStateMarker);
        await CleanConnectionRequestState(ownerId, stateMarker);
        await CleanNwGroupRequestState(ownerId, stateMarker);
        await CleanServiceGroupRequestState(ownerId, stateMarker);
    }

    private async Task CleanConnectionRequestState(int ownerId, string stateMarker)
    {
        List<ModellingConnection> connections = await apiConnection.SendQueryAsync<List<ModellingConnection>>(ModellingQueries.getConnections, new { appId = ownerId });
        foreach (ModellingConnection connection in connections)
        {
            RemoveConnectionRequestState(connection, stateMarker);
            await apiConnection.SendQueryAsync<ReturnId>(ModellingQueries.resetConnectionRequestState, new { id = connection.Id, connProp = connection.Properties });
        }
    }

    private static void RemoveConnectionRequestState(ModellingConnection connection, string stateMarker)
    {
        connection.RemoveProperty(stateMarker);
        connection.RemoveProperty(ModIntegrationStateConfig.TimestampMarker(stateMarker));
    }

    private async Task CleanNwGroupRequestState(int ownerId, string stateMarker)
    {
        List<ModellingAppRole> nwGroups = await apiConnection.SendQueryAsync<List<ModellingAppRole>>(ModellingQueries.getNwGroupsForApp, new { appId = ownerId });
        foreach (ModellingAppRole nwGroup in nwGroups)
        {
            string comment = RemoveGroupRequestState(nwGroup.Comment, stateMarker);
            if (comment != (nwGroup.Comment ?? ""))
            {
                await apiConnection.SendQueryAsync<ReturnId>(ModellingQueries.updateNwGroupComment, new { id = nwGroup.Id, comment });
            }
        }
    }

    private async Task CleanServiceGroupRequestState(int ownerId, string stateMarker)
    {
        List<ModellingServiceGroup> serviceGroups = await apiConnection.SendQueryAsync<List<ModellingServiceGroup>>(ModellingQueries.getServiceGroupsForApp, new { appId = ownerId });
        foreach (ModellingServiceGroup serviceGroup in serviceGroups)
        {
            string comment = RemoveGroupRequestState(serviceGroup.Comment, stateMarker);
            if (comment != (serviceGroup.Comment ?? ""))
            {
                await apiConnection.SendQueryAsync<ReturnId>(ModellingQueries.updateServiceGroupComment, new { id = serviceGroup.Id, comment });
            }
        }
    }

    private static string RemoveGroupRequestState(string? comment, string stateMarker)
    {
        string cleanedComment = ModIntegrationStateConfig.RemoveMarkedComment(comment, stateMarker);
        return ModIntegrationStateConfig.RemoveMarkedComment(cleanedComment, ModIntegrationStateConfig.TimestampMarker(stateMarker));
    }

    private void ReplaceResetRowDisplay()
    {
        int index = Rows.FindIndex(row => row.Owner.Id == ResetRow.Owner.Id);
        if (index >= 0)
        {
            Rows[index] = OwnerRequestStatus.NoRequest(Rows[index].Owner, userConfig.GetText("never_requested"));
        }
    }

    private void UpdatePageSize(int pageSize)
    {
        PageSize = pageSize;
    }

    private sealed class OwnerRequestStatus
    {
        public FwoOwner Owner { get; set; } = new();
        public long TicketId { get; set; }
        public string Status { get; set; } = "";
        public string StateName { get; set; } = "";
        public int OpenTaskCount { get; set; }
        public DateTime? CreatedAt { get; set; }
        public DateTime? CompletedAt { get; set; }

        public static OwnerRequestStatus NoRequest(FwoOwner owner, string status)
        {
            return new()
            {
                Owner = owner,
                Status = status
            };
        }
    }
}
