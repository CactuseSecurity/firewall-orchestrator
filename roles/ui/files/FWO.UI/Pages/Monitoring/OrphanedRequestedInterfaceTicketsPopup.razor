@using FWO.Api.Client.Queries
@using FWO.Compliance
@using FWO.Config.Api
@using FWO.Data.Modelling
@using FWO.Data.Workflow
@using FWO.Middleware.Client
@using FWO.Services.Workflow
@using Microsoft.AspNetCore.Components.Authorization

@inject ApiConnection apiConnection
@inject MiddlewareClient middlewareClient
@inject UserConfig userConfig

<PopUp Title="@(userConfig.GetText("orphaned_requested_interface_tickets"))" Show="@Display" Size="PopupSize.Large" OnClose="Close">
    <Body>
        @if (Display)
        {
            @if (WorkInProgress)
            {
                <Loading />
            }
            else if (Tickets.Count > 0)
            {
                <Table class="table table-bordered th-bg-secondary table-responsive overflow-auto sticky-header"
                       TableItem="OrphanedRequestedInterfaceTicketRow" Items="Tickets" PageSize="10">
                    <Column TableItem="OrphanedRequestedInterfaceTicketRow" Title="@(userConfig.GetText("actions"))" Field="@(x => x.TicketId)" Sortable="false" Filterable="false">
                        <Template>
                            <button type="button" class="btn btn-sm btn-dark" @onclick="() => OpenTicket.InvokeAsync(context.TicketId)">
                                @(DisplayService.DisplayButton(userConfig, "display_ticket", Icons.Display, "", Icons.Workflow))
                            </button>
                            @if (context.CanReject)
                            {
                                <button type="button" class="btn btn-sm btn-danger ms-1" @onclick="() => RejectTicket(context.TicketId)">
                                    @(DisplayService.DisplayButton(userConfig, "reject", Icons.Reject))
                                </button>
                            }
                            @if (context.CanCloseAsDone)
                            {
                                <button type="button" class="btn btn-sm btn-success ms-1" @onclick="() => CloseTicketAsDone(context.TicketId)">
                                    @(DisplayService.DisplayButton(userConfig, "close_as_done", Icons.Confirm))
                                </button>
                            }
                        </Template>
                    </Column>
                    <Column TableItem="OrphanedRequestedInterfaceTicketRow" Title="@(userConfig.GetText("ticket"))" Field="@(x => x.TicketId)" Sortable="true" Filterable="true" />
                    <Column TableItem="OrphanedRequestedInterfaceTicketRow" Title="@(userConfig.GetText("state"))" Field="@(x => x.TicketState)" Sortable="true" Filterable="true" />
                    <Column TableItem="OrphanedRequestedInterfaceTicketRow" Title="@(userConfig.GetText("creation_date"))" Field="@(x => x.TicketCreationDate)" Sortable="true" Filterable="false">
                        <Template>
                            @(context.TicketCreationDate?.ToString("g") ?? "-")
                        </Template>
                    </Column>
                    <Column TableItem="OrphanedRequestedInterfaceTicketRow" Title="@(userConfig.GetText("requested_interfaces"))" Field="@(x => x.InterfaceNames)" Sortable="true" Filterable="true" />
                    <Column TableItem="OrphanedRequestedInterfaceTicketRow" Title="@(userConfig.GetText("connection_id"))" Field="@(x => x.ConnectionIds)" Sortable="true" Filterable="true" />
                    <Column TableItem="OrphanedRequestedInterfaceTicketRow" Title="@(userConfig.GetText("problem_reason"))" Field="@(x => x.ProblemReasons)" Sortable="true" Filterable="true" />
                    <Pager ShowPageNumber="true" ShowTotalCount="true" />
                </Table>
            }
            else
            {
                <p>@(userConfig.GetText("orphaned_requested_interface_tickets_empty"))</p>
            }
        }
    </Body>
    <Footer>
        @if (Tickets.Any(ticket => ticket.CanReject))
        {
            <button type="button" class="btn btn-sm btn-danger me-2" @onclick="ShowRejectAllTicketsConfirm">
                @(DisplayService.DisplayButton(userConfig, "reject_tickets", Icons.Reject))
            </button>
        }
        @if (Tickets.Any(ticket => ticket.CanCloseAsDone))
        {
            <button type="button" class="btn btn-sm btn-success me-2" @onclick="ShowCloseAllTicketsAsDoneConfirm">
                @(DisplayService.DisplayButton(userConfig, "close_tickets_as_done", Icons.Confirm))
            </button>
        }
        <button type="button" class="btn btn-sm btn-secondary" @onclick="Close">@(DisplayService.DisplayButton(userConfig, "ok", Icons.Confirm))</button>
    </Footer>
</PopUp>

<Confirm @bind-Display="ConfirmRejectAllTickets" PerformAction="RejectAllTickets" Title="@(userConfig.GetText("reject_tickets"))"
         Message="@RejectAllTicketsMessage" />
<Confirm @bind-Display="ConfirmCloseAllTicketsAsDone" PerformAction="CloseAllTicketsAsDone" Title="@(userConfig.GetText("close_tickets_as_done"))"
         Message="@CloseAllTicketsAsDoneMessage" />

@code
{
    [Parameter]
    public bool Display { get; set; }

    [Parameter]
    public EventCallback<bool> DisplayChanged { get; set; }

    [Parameter]
    public EventCallback<long> OpenTicket { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? authenticationStateTask { get; set; }

    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;

    private List<OrphanedRequestedInterfaceTicketRow> Tickets { get; set; } = [];
    private WfStateDict States { get; set; } = new();
    private StateMatrix NewInterfaceStateMatrix { get; set; } = new();
    private bool WorkInProgress { get; set; } = false;
    private bool LoadPending { get; set; } = true;
    private bool ConfirmRejectAllTickets { get; set; } = false;
    private bool ConfirmCloseAllTicketsAsDone { get; set; } = false;
    private List<long> RejectableTicketIds => [.. Tickets.Where(ticket => ticket.CanReject).Select(ticket => ticket.TicketId).Distinct()];
    private List<long> DoneClosableTicketIds => [.. Tickets.Where(ticket => ticket.CanCloseAsDone).Select(ticket => ticket.TicketId).Distinct()];
    private string RejectAllTicketsMessage => userConfig.GetText("U9040").Replace(Placeholder.COUNT, RejectableTicketIds.Count.ToString());
    private string CloseAllTicketsAsDoneMessage => userConfig.GetText("U9041").Replace(Placeholder.COUNT, DoneClosableTicketIds.Count.ToString());

    protected override async Task OnParametersSetAsync()
    {
        if (Display && LoadPending)
        {
            await LoadOrphanedRequestedInterfaceTickets();
            LoadPending = false;
        }
        else if (!Display)
        {
            LoadPending = true;
            Tickets = [];
        }
    }

    /// <summary>
    /// Loads open new-interface tickets whose requested-interface linkage is missing or suspicious.
    /// </summary>
    private async Task LoadOrphanedRequestedInterfaceTickets()
    {
        try
        {
            WorkInProgress = true;
            await EnsureStateMatrixInitialized();
            await EnsureStatesInitialized();

            List<WfTicket> openTickets = await apiConnection.SendQueryAsync<List<WfTicket>>(RequestQueries.getTicketsByParameters, new
            {
                cutOffDate = DateTime.Now,
                taskType = WfTaskType.new_interface.ToString(),
                fromState = NewInterfaceStateMatrix.LowestInputState,
                toState = NewInterfaceStateMatrix.LowestEndState
            });
            Tickets = [];
            List<OpenInterfaceTask> openInterfaceTasks = BuildOpenInterfaceTasks(openTickets);
            MarkDuplicateOpenInterfaceTasks(openInterfaceTasks);
            foreach (IGrouping<long, OpenInterfaceTask> ticketTasks in openInterfaceTasks.GroupBy(task => task.Ticket.Id))
            {
                OrphanedRequestedInterfaceTicketRow? row = await BuildProblemRow(ticketTasks);
                if (row != null)
                {
                    Tickets.Add(row);
                }
            }
            Tickets = Tickets.OrderBy(ticket => ticket.TicketId).ToList();
        }
        catch (Exception exception)
        {
            Tickets = [];
            DisplayMessageInUi(exception, userConfig.GetText("orphaned_requested_interface_tickets"), "", true);
        }
        finally
        {
            WorkInProgress = false;
        }
    }

    private static List<OpenInterfaceTask> BuildOpenInterfaceTasks(IEnumerable<WfTicket> openTickets)
    {
        return [.. openTickets.SelectMany(ticket => ticket.Tasks
            .Where(task => task.TaskType == WfTaskType.new_interface.ToString())
            .Select(task => new OpenInterfaceTask(ticket, task)))];
    }

    private static void MarkDuplicateOpenInterfaceTasks(List<OpenInterfaceTask> openInterfaceTasks)
    {
        foreach (IGrouping<string, OpenInterfaceTask> duplicateGroup in openInterfaceTasks.GroupBy(DuplicateKey, StringComparer.OrdinalIgnoreCase))
        {
            if (duplicateGroup.Count() <= 1)
            {
                continue;
            }
            foreach (OpenInterfaceTask openInterfaceTask in duplicateGroup)
            {
                openInterfaceTask.DuplicateLooking = true;
            }
        }
    }

    private static string DuplicateKey(OpenInterfaceTask openInterfaceTask)
    {
        WfReqTask task = openInterfaceTask.Task;
        int requestedOwnerId = task.Owners.FirstOrDefault()?.Owner.Id ?? 0;
        int requestingOwnerId = task.GetAddInfoIntValueOrZero(AdditionalInfoKeys.ReqOwner);
        string normalizedTitle = NormalizeTaskTitle(task.Title);
        return $"{requestedOwnerId}|{requestingOwnerId}|{normalizedTitle}";
    }

    private static string NormalizeTaskTitle(string title)
    {
        return string.Join(" ", title.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));
    }

    private async Task<OrphanedRequestedInterfaceTicketRow?> BuildProblemRow(IEnumerable<OpenInterfaceTask> ticketTasks)
    {
        WfTicket ticket = ticketTasks.First().Ticket;
        List<string> interfaceNames = [];
        List<string> connectionIds = [];
        List<string> problemReasons = [];
        bool canReject = false;
        bool canCloseAsDone = false;
        foreach (OpenInterfaceTask openInterfaceTask in ticketTasks)
        {
            TaskProblemClassification classification = await ClassifyTaskProblems(openInterfaceTask);
            if (classification.Reasons.Count == 0)
            {
                continue;
            }
            interfaceNames.Add(DisplayTaskName(openInterfaceTask.Task));
            connectionIds.Add(DisplayConnectionId(openInterfaceTask.Task));
            problemReasons.AddRange(classification.Reasons);
            canReject |= classification.HasStructuralProblem;
            canCloseAsDone |= classification.CanCloseAsDone;
        }

        if (problemReasons.Count == 0)
        {
            return null;
        }

        return new()
        {
            TicketId = ticket.Id,
            TicketState = States.GetName(ticket.StateId),
            TicketCreationDate = ticket.CreationDate,
            InterfaceNames = string.Join(", ", interfaceNames.OrderBy(name => name)),
            ConnectionIds = string.Join(", ", connectionIds.Distinct().OrderBy(id => id)),
            ProblemReasons = string.Join(", ", problemReasons.Distinct().OrderBy(reason => reason)),
            CanReject = canReject,
            CanCloseAsDone = canCloseAsDone
        };
    }

    private async Task<TaskProblemClassification> ClassifyTaskProblems(OpenInterfaceTask openInterfaceTask)
    {
        List<string> reasons = [];
        bool hasStructuralProblem = false;
        WfReqTask task = openInterfaceTask.Task;
        int connId = task.GetAddInfoIntValueOrZero(AdditionalInfoKeys.ConnId);
        if (openInterfaceTask.DuplicateLooking)
        {
            reasons.Add(userConfig.GetText("E9022"));
        }
        if (connId <= 0)
        {
            reasons.Add(userConfig.GetText("E9023"));
            return new(reasons, true);
        }

        List<ModellingConnection> existingConnections = await apiConnection.SendQueryAsync<List<ModellingConnection>>(
            ModellingQueries.getConnectionById,
            new { id = connId });
        if (existingConnections.Count == 0)
        {
            reasons.Add(userConfig.GetText("E9024"));
            return new(reasons, true);
        }

        ModellingConnection connection = existingConnections[0];
        if (connection.TicketId != openInterfaceTask.Ticket.Id)
        {
            reasons.Add(userConfig.GetText("E9026"));
            hasStructuralProblem = true;
        }
        if (connection.Removed)
        {
            reasons.Add(userConfig.GetText("E9027"));
            hasStructuralProblem = true;
        }
        if (IsAlreadyPublishedRequestedInterface(connection, openInterfaceTask.Ticket.Id))
        {
            reasons.Add(userConfig.GetText("E9028"));
            return new(reasons, hasStructuralProblem, true);
        }
        if (!connection.IsInterface || !connection.IsRequested)
        {
            reasons.Add(userConfig.GetText("E9025"));
            hasStructuralProblem = true;
        }
        return new(reasons, hasStructuralProblem);
    }

    private static bool IsAlreadyPublishedRequestedInterface(ModellingConnection connection, long ticketId)
    {
        return connection.IsInterface
            && connection.IsPublished
            && !connection.IsRequested
            && connection.ProposedAppId == null
            && !connection.Removed
            && connection.TicketId == ticketId;
    }

    private static string DisplayTaskName(WfReqTask task)
    {
        return string.IsNullOrWhiteSpace(task.Title) ? "-" : task.Title;
    }

    private static string DisplayConnectionId(WfReqTask task)
    {
        int connId = task.GetAddInfoIntValueOrZero(AdditionalInfoKeys.ConnId);
        return connId > 0 ? connId.ToString() : "-";
    }

    /// <summary>
    /// Initializes the state names used to render workflow state labels.
    /// </summary>
    private async Task EnsureStatesInitialized()
    {
        if (States.Name.Count > 0)
        {
            return;
        }
        await States.Init(apiConnection);
    }

    /// <summary>
    /// Initializes the state matrix so open tickets can be identified reliably.
    /// </summary>
    private async Task EnsureStateMatrixInitialized()
    {
        if (NewInterfaceStateMatrix.LowestEndState > 0)
        {
            return;
        }
        await NewInterfaceStateMatrix.Init(WorkflowPhases.implementation, apiConnection, WfTaskType.new_interface);
    }

    /// <summary>
    /// Rejects a single orphaned new-interface ticket and reloads the popup content.
    /// </summary>
    private async Task RejectTicket(long ticketId)
    {
        await RejectTickets([ticketId]);
    }

    /// <summary>
    /// Rejects all currently listed orphaned new-interface tickets and reloads the popup content.
    /// </summary>
    private async Task RejectAllTickets()
    {
        List<long> ticketIds = RejectableTicketIds;
        ConfirmRejectAllTickets = false;
        await RejectTickets(ticketIds);
    }

    private void ShowRejectAllTicketsConfirm()
    {
        ConfirmRejectAllTickets = true;
    }

    /// <summary>
    /// Closes a single already-published new-interface ticket as done and reloads the popup content.
    /// </summary>
    private async Task CloseTicketAsDone(long ticketId)
    {
        await CloseTicketsAsDone([ticketId]);
    }

    /// <summary>
    /// Closes all listed already-published new-interface tickets as done and reloads the popup content.
    /// </summary>
    private async Task CloseAllTicketsAsDone()
    {
        List<long> ticketIds = DoneClosableTicketIds;
        ConfirmCloseAllTicketsAsDone = false;
        await CloseTicketsAsDone(ticketIds);
    }

    private void ShowCloseAllTicketsAsDoneConfirm()
    {
        ConfirmCloseAllTicketsAsDone = true;
    }

    /// <summary>
    /// Closes the given orphaned tickets via workflow promotion.
    /// </summary>
    private async Task RejectTickets(IEnumerable<long> ticketIds)
    {
        if (WorkInProgress)
        {
            return;
        }
        await PromoteTickets(ticketIds, ExtStates.Rejected, userConfig.GetText("U9036"), userConfig.GetText("reject_tickets"), userConfig.GetText("U9018"));
    }

    /// <summary>
    /// Closes the given already-published tickets as done via workflow promotion.
    /// </summary>
    private async Task CloseTicketsAsDone(IEnumerable<long> ticketIds)
    {
        if (WorkInProgress)
        {
            return;
        }
        await PromoteTickets(ticketIds, ExtStates.Done, userConfig.GetText("U9038"), userConfig.GetText("close_tickets_as_done"), userConfig.GetText("U9039"));
    }

    /// <summary>
    /// Promotes the given new-interface tickets and reloads the popup content.
    /// </summary>
    private async Task PromoteTickets(IEnumerable<long> ticketIds, ExtStates targetState, string comment, string dialogTitle, string successMessage)
    {
        if (WorkInProgress)
        {
            return;
        }
        if (authenticationStateTask?.Result.User == null)
        {
            return;
        }

        try
        {
            WorkInProgress = true;
            TicketCreator ticketCreator = new(apiConnection, userConfig, authenticationStateTask.Result.User, middlewareClient, WorkflowPhases.implementation, new ComplianceRequestedRulePolicyChecker(userConfig, apiConnection));
            int promotedCount = 0;
            foreach (long ticketId in ticketIds.Distinct())
            {
                if (await ticketCreator.PromoteNewInterfaceImplTask(ticketId, targetState, comment))
                {
                    promotedCount++;
                }
            }

            DisplayMessageInUi(null, dialogTitle, $"{successMessage} ({promotedCount})", false);
            await LoadOrphanedRequestedInterfaceTickets();
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, dialogTitle, "", true);
        }
        finally
        {
            WorkInProgress = false;
        }
    }

    private void Close()
    {
        Display = false;
        LoadPending = true;
        Tickets = [];
        _ = DisplayChanged.InvokeAsync(Display);
    }

    private sealed class OrphanedRequestedInterfaceTicketRow
    {
        public long TicketId { get; set; }
        public string TicketState { get; set; } = "-";
        public DateTime? TicketCreationDate { get; set; }
        public string InterfaceNames { get; set; } = "-";
        public string ConnectionIds { get; set; } = "-";
        public string ProblemReasons { get; set; } = "-";
        public bool CanReject { get; set; }
        public bool CanCloseAsDone { get; set; }
    }

    private sealed class OpenInterfaceTask(WfTicket ticket, WfReqTask task)
    {
        public WfTicket Ticket { get; } = ticket;
        public WfReqTask Task { get; } = task;
        public bool DuplicateLooking { get; set; }
    }

    private sealed class TaskProblemClassification(List<string> reasons, bool hasStructuralProblem, bool canCloseAsDone = false)
    {
        public List<string> Reasons { get; } = reasons;
        public bool HasStructuralProblem { get; } = hasStructuralProblem;
        public bool CanCloseAsDone { get; } = canCloseAsDone;
    }
}
