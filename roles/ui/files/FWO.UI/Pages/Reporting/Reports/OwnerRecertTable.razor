@using FWO.Ui.Display

@using FWO.Basics
@inject UserConfig userConfig

<Table TableClass="table table-bordered table-sm th-bg-secondary table-responsive overflow-auto sticky-header" TableItem="FwoOwner" Items="Owners" PageSize="0">
    @if (ShowRecertData)
    {
        <Column TableItem="FwoOwner" Title="@(userConfig.GetText("next_recert_date"))" Field="@(x => x.Id)" >
            <Template>
                @(OwnerRecertDisplay.FormatNextRecertDate(context, userConfig))
            </Template>
        </Column>
    }
    <Column TableItem="FwoOwner" Title="@(userConfig.GetText("id"))" Field="@(x => x.ExtAppId)" />
    <Column TableItem="FwoOwner" Title="@(userConfig.GetText("name"))" Field="@(x => x.Name)" />
    <Column TableItem="FwoOwner" Title="@(userConfig.GetText("main_responsible"))" Field="@(x => x.Id)" >
        <Template>
            @(OwnerRecertDisplay.FormatMainResponsibles(context))
        </Template>
    </Column>
    @if (ShowRecertData)
    {
        <Column TableItem="FwoOwner" Title="@(userConfig.GetText("last_recertified"))" Field="@(x => x.LastRecertified)" >
            <Template>
                @(OwnerRecertDisplay.FormatLastRecertified(context, userConfig))
            </Template>
        </Column>
        <Column TableItem="FwoOwner" Title="@(userConfig.GetText("last_recertifier"))" Field="@(x => x.LastRecertifierDn)" >
           <Template>
                @(GetRecertifierName(context))
            </Template>
        </Column>
    }
    @if (HasAdditionalInfoColumn())
    {
        <Column TableItem="FwoOwner" Title="@AdditionalInfoColumnTitle" Field="@(x => x.Id)" Sortable="false" Filterable="false">
           <Template>
                @((MarkupString)GetAdditionalInfoValueHtml(context))
            </Template>
        </Column>
    }
</Table>


@code
{
    [Parameter]
    public List<FwoOwner> Owners { get; set; } = [];

    [Parameter]
    public bool ShowRecertData { get; set; } = true;

    [Parameter]
    public string AdditionalInfoKey { get; set; } = "";

    private string AdditionalInfoColumnTitle => $"{userConfig.GetText("label")}: {AdditionalInfoKey}";

    private string GetRecertifierName(FwoOwner owner)
    {
        string UserName = new DistName(owner.LastRecertifierDn).UserName;
        return string.IsNullOrEmpty(UserName) ? (owner.LastRecertifierDn ?? "") : UserName;
    }

    private bool HasAdditionalInfoColumn()
    {
        return !string.IsNullOrWhiteSpace(AdditionalInfoKey);
    }

    private string GetAdditionalInfoValueHtml(FwoOwner owner)
    {
        return OwnerRecertDisplay.FormatAdditionalInfoValueHtml(owner, AdditionalInfoKey);
    }

}
