@using System.Net
@using System.Text.RegularExpressions
@using FWO.Report
@using FWO.Services.RuleTreeBuilder
@using FWO.Ui.Display
@using FWO.Ui.Shared

@inject UserConfig userConfig
@inject IRuleTreeBuilder ruleTreeBuilder

@if (ShouldShowTreeToolbar())
{
    <div class="rules-report__toolbar">
        <div class="rules-report__search">
            <label class="rules-report__search-label" for="rules-report-search">@(userConfig.GetText("search"))</label>
            <input id="rules-report-search"
                   class="form-control form-control-sm"
                   type="search"
                   value="@_searchTerm"
                   @oninput="UpdateSearchTerm" />
        </div>

        <details class="rules-report__column-filter">
            <summary>
                <span class="@Icons.Filter"></span>
                @(userConfig.GetText("filter"))
            </summary>
            <div class="rules-report__column-options">
                @foreach (var column in GetAvailableColumns())
                {
                    <label class="rules-report__column-option">
                        <input type="checkbox"
                               checked="@IsColumnVisible(column.Key)"
                               @onchange="args => SetColumnVisibility(column.Key, args.Value as bool? ?? false)" />
                        <span>@column.Title</span>
                    </label>
                }
            </div>
        </details>
    </div>
}

@foreach (var management in Managements)
{
    @if (management.ContainsRules())
    {
        <Collapse Title="@management.Name" Style="@("primary")" StartToggled="false">
            @if (SelectedReportType.IsRulebaseReport())
            {
                @foreach (var rulebase in management.Rulebases)
                {
                    var rulebaseRules = ReportRules.GetRulesByRulebaseId(rulebase.Id, management);
                    @if (rulebaseRules.Length > 0)
                    {
                        <Collapse Title="@rulebase.Name" Style="@("secondary")" StartToggled="true">
                            <RuleBaseReport ReadonlyMode="ReadonlyMode"
                                            SelectedReportType="SelectedReportType"
                                            Rules="[.. rulebaseRules]"
                                            @bind-SelectedRules="SelectedRules"
                                            RulesPerPage="RulesPerPage" />
                        </Collapse>
                    }
                }
            }
            else
            {
                @foreach (var device in management.Devices)
                {
                    @if (device.ContainsRules() && _ruleDisplay != null)
                    {
                        <Collapse Title="@device.Name" Style="@("secondary")" StartToggled="true">
                            <div class="rules-report__tree">
                                <div class="rules-report__header">
                                    <div class="rules-report__header-cell rules-report__header-cell--number">
                                        @(userConfig.GetText("number"))
                                    </div>

                                    @if (SelectedReportType == ReportType.Recertification)
                                    {
                                        @if (IsColumnVisible(ColumnNextRecertDate))
                                        {
                                            <div class="rules-report__header-cell">@(userConfig.GetText("next_recert_date"))</div>
                                        }
                                        @if (IsColumnVisible(ColumnOwner))
                                        {
                                            <div class="rules-report__header-cell">@(userConfig.GetText("owner"))</div>
                                        }
                                        @if (IsColumnVisible(ColumnIpMatches))
                                        {
                                            <div class="rules-report__header-cell">@(userConfig.GetText("ip_matches"))</div>
                                        }
                                        @if (IsColumnVisible(ColumnLastHit))
                                        {
                                            <div class="rules-report__header-cell">@(userConfig.GetText("last_hit"))</div>
                                        }
                                        @if (IsColumnVisible(ColumnLastModified))
                                        {
                                            <div class="rules-report__header-cell">LastModified</div>
                                        }
                                    }
                                    else
                                    {
                                        @if (ShouldShowLastHitColumn() && IsColumnVisible(ColumnLastHit))
                                        {
                                            <div class="rules-report__header-cell">@(userConfig.GetText("last_hit"))</div>
                                        }
                                        @if (ShouldShowLastModifiedAfterLastHit() && IsColumnVisible(ColumnLastModified))
                                        {
                                            <div class="rules-report__header-cell">LastModified</div>
                                        }
                                    }

                                    @if (IsColumnVisible(ColumnName))
                                    {
                                        <div class="rules-report__header-cell">@(userConfig.GetText("name"))</div>
                                    }
                                    @if (IsColumnVisible(ColumnSourceZone))
                                    {
                                        <div class="rules-report__header-cell">@(userConfig.GetText("source_zone"))</div>
                                    }
                                    @if (IsColumnVisible(ColumnSource))
                                    {
                                        <div class="rules-report__header-cell">@(userConfig.GetText("source"))</div>
                                    }
                                    @if (IsColumnVisible(ColumnDestinationZone))
                                    {
                                        <div class="rules-report__header-cell">@(userConfig.GetText("destination_zone"))</div>
                                    }
                                    @if (IsColumnVisible(ColumnDestination))
                                    {
                                        <div class="rules-report__header-cell">@(userConfig.GetText("destination"))</div>
                                    }
                                    @if (IsColumnVisible(ColumnServices))
                                    {
                                        <div class="rules-report__header-cell">@(userConfig.GetText("services"))</div>
                                    }

                                    @if (SelectedReportType == ReportType.NatRules)
                                    {
                                        @if (IsColumnVisible(ColumnTranslatedSource))
                                        {
                                            <div class="rules-report__header-cell rules-report__header-cell--translated">@(userConfig.GetText("trans_source"))</div>
                                        }
                                        @if (IsColumnVisible(ColumnTranslatedDestination))
                                        {
                                            <div class="rules-report__header-cell rules-report__header-cell--translated">@(userConfig.GetText("trans_destination"))</div>
                                        }
                                        @if (IsColumnVisible(ColumnTranslatedServices))
                                        {
                                            <div class="rules-report__header-cell rules-report__header-cell--translated">@(userConfig.GetText("trans_services"))</div>
                                        }
                                    }
                                    else
                                    {
                                        @if (IsColumnVisible(ColumnAction))
                                        {
                                            <div class="rules-report__header-cell">@(userConfig.GetText("action"))</div>
                                        }
                                        @if (IsColumnVisible(ColumnTrack))
                                        {
                                            <div class="rules-report__header-cell">@(userConfig.GetText("track"))</div>
                                        }
                                    }

                                    @if (IsColumnVisible(ColumnEnabled))
                                    {
                                        <div class="rules-report__header-cell">@(userConfig.GetText("enabled"))</div>
                                    }
                                    @if (IsColumnVisible(ColumnEnforcingDevices))
                                    {
                                        <div class="rules-report__header-cell">@(userConfig.GetText("enforcing_devices"))</div>
                                    }
                                    @if (IsColumnVisible(ColumnUid))
                                    {
                                        <div class="rules-report__header-cell">@(userConfig.GetText("uid"))</div>
                                    }
                                    @if (IsColumnVisible(ColumnComment))
                                    {
                                        <div class="rules-report__header-cell">@(userConfig.GetText("comment"))</div>
                                    }
                                    @if (!ShouldShowLastModifiedAfterLastHit()
                                        && SelectedReportType != ReportType.Recertification
                                        && IsColumnVisible(ColumnLastModified))
                                    {
                                        <div class="rules-report__header-cell">LastModified</div>
                                    }
                                </div>

                                <TreeView T="RuleTreeItem"
                                          Nodes="@GetRootNodes(management, device)"
                                          NodeContent="@RenderRuleNode(management.Name ?? string.Empty, device.Name ?? string.Empty)"
                                          DetailContent="@RenderRuleDetail()"
                                          IsDetailExpanded="ShouldShowRuleDetail"
                                          ShouldRenderNode="ShouldRenderNode" />
                            </div>
                        </Collapse>
                    }
                }
            }
        </Collapse>
    }
}

@code
{
    [Parameter]
    public List<ManagementReport> Managements { get; set; } = [];

    [Parameter]
    public bool ReadonlyMode { get; set; }

    [Parameter]
    public bool Recertification { get; set; }

    [Parameter]
    public int RulesPerPage { get; set; }

    [Parameter]
    public ReportType SelectedReportType { get; set; }

    [Parameter]
    public List<Rule> SelectedRules { get; set; } = [];

    [Parameter]
    public EventCallback<List<Rule>> SelectedRulesChanged { get; set; }

    [Parameter]
    public int Width { get; set; }

    [Parameter]
    public EventCallback<int> WidthChanged { get; set; }

    private const string ColumnAction = "action";
    private const string ColumnComment = "comment";
    private const string ColumnDestination = "destination";
    private const string ColumnDestinationZone = "destination_zone";
    private const string ColumnEnabled = "enabled";
    private const string ColumnEnforcingDevices = "enforcing_devices";
    private const string ColumnIpMatches = "ip_matches";
    private const string ColumnLastHit = "last_hit";
    private const string ColumnLastModified = "last_modified";
    private const string ColumnName = "name";
    private const string ColumnNextRecertDate = "next_recert_date";
    private const string ColumnOwner = "owner";
    private const string ColumnServices = "services";
    private const string ColumnSource = "source";
    private const string ColumnSourceZone = "source_zone";
    private const string ColumnTrack = "track";
    private const string ColumnTranslatedDestination = "trans_destination";
    private const string ColumnTranslatedServices = "trans_services";
    private const string ColumnTranslatedSource = "trans_source";
    private const string ColumnUid = "uid";

    private readonly HashSet<string> _hiddenColumns = [];
    private readonly Dictionary<RuleTreeItem, bool> _nodeVisibility = [];

    private string _searchTerm = string.Empty;
    private NatRuleDisplayHtml? _ruleDisplay;

    protected override void OnInitialized()
    {
        _ruleDisplay = new NatRuleDisplayHtml(userConfig);
    }

    protected override void OnParametersSet()
    {
        RefreshSearchVisibility();
    }

    private sealed record RuleReportColumn(string Key, string Title);

    private bool ShouldShowTreeToolbar()
    {
        return !SelectedReportType.IsRulebaseReport()
            && Managements.Any(management => management.ContainsRules() && management.Devices.Any(device => device.ContainsRules()));
    }

    private List<RuleTreeItem> GetRootNodes(ManagementReport managementReport, DeviceReport deviceReport)
    {
        return GetRuleTree(managementReport, deviceReport).Children.ToList();
    }

    private RuleTreeItem GetRuleTree(ManagementReport managementReport, DeviceReport deviceReport)
    {
        if (ruleTreeBuilder.RuleTreeCache.TryGetValue((managementReport.Id, deviceReport.Id), out RuleTreeItem? ruleTreeFromCache))
        {
            return ruleTreeFromCache;
        }

        return new();
    }

    private void UpdateSearchTerm(ChangeEventArgs args)
    {
        _searchTerm = args.Value?.ToString() ?? string.Empty;
        RefreshSearchVisibility();
    }

    private void SetColumnVisibility(string columnKey, bool isVisible)
    {
        if (isVisible)
        {
            _hiddenColumns.Remove(columnKey);
        }
        else
        {
            _hiddenColumns.Add(columnKey);
        }
    }

    private bool IsColumnVisible(string columnKey)
    {
        return !_hiddenColumns.Contains(columnKey);
    }

    private IEnumerable<RuleReportColumn> GetAvailableColumns()
    {
        if (SelectedReportType == ReportType.Recertification)
        {
            yield return new(ColumnNextRecertDate, userConfig.GetText("next_recert_date"));
            yield return new(ColumnOwner, userConfig.GetText("owner"));
            yield return new(ColumnIpMatches, userConfig.GetText("ip_matches"));
            yield return new(ColumnLastHit, userConfig.GetText("last_hit"));
            yield return new(ColumnLastModified, "LastModified");
        }
        else
        {
            if (ShouldShowLastHitColumn())
            {
                yield return new(ColumnLastHit, userConfig.GetText("last_hit"));
            }

            yield return new(ColumnLastModified, "LastModified");
        }

        yield return new(ColumnName, userConfig.GetText("name"));
        yield return new(ColumnSourceZone, userConfig.GetText("source_zone"));
        yield return new(ColumnSource, userConfig.GetText("source"));
        yield return new(ColumnDestinationZone, userConfig.GetText("destination_zone"));
        yield return new(ColumnDestination, userConfig.GetText("destination"));
        yield return new(ColumnServices, userConfig.GetText("services"));

        if (SelectedReportType == ReportType.NatRules)
        {
            yield return new(ColumnTranslatedSource, userConfig.GetText("trans_source"));
            yield return new(ColumnTranslatedDestination, userConfig.GetText("trans_destination"));
            yield return new(ColumnTranslatedServices, userConfig.GetText("trans_services"));
        }
        else
        {
            yield return new(ColumnAction, userConfig.GetText("action"));
            yield return new(ColumnTrack, userConfig.GetText("track"));
        }

        yield return new(ColumnEnabled, userConfig.GetText("enabled"));
        yield return new(ColumnEnforcingDevices, userConfig.GetText("enforcing_devices"));
        yield return new(ColumnUid, userConfig.GetText("uid"));
        yield return new(ColumnComment, userConfig.GetText("comment"));
    }

    private bool ShouldShowLastHitColumn()
    {
        return SelectedReportType == ReportType.UnusedRules
            || SelectedReportType == ReportType.AppRules
            || SelectedReportType == ReportType.Recertification;
    }

    private bool ShouldShowLastModifiedAfterLastHit()
    {
        return SelectedReportType == ReportType.UnusedRules
            || SelectedReportType == ReportType.AppRules;
    }

    private RenderFragment<TreeViewNodeContext<RuleTreeItem>> RenderRuleNode(string managementName, string deviceName) => context => @<div>
        @if (IsHeaderNode(context.Node))
        {
            <div class="rules-report__row rules-report__row--header">
                <div class="rules-report__header-node @GetDepthClass(context.Level)">
                    @if (context.HasChildren)
                    {
                        <button class="rules-report__toggle" type="button" @onclick="context.ToggleNodeAsync" @onclick:stopPropagation="true">
                            @GetToggleSymbol(context.Node)
                        </button>
                    }
                    else
                    {
                        <span class="rules-report__toggle rules-report__toggle-placeholder"></span>
                    }
                    <span class="rules-report__header-title" title="@GetHeaderTitle(context.Node)">
                        @GetHeaderTitle(context.Node)
                    </span>
                </div>
            </div>
        }
        else
        {
            <div class="@GetRuleRowClasses(context.Node)" @onclick="() => ToggleRuleSelection(context.Node, managementName, deviceName)">
                <div class="rules-report__cell rules-report__cell--number @GetDepthClass(context.Level)">
                    @if (context.HasChildren)
                    {
                        <button class="rules-report__toggle" type="button" @onclick="context.ToggleNodeAsync" @onclick:stopPropagation="true">
                            @GetToggleSymbol(context.Node)
                        </button>
                    }
                    else
                    {
                        <span class="rules-report__toggle rules-report__toggle-placeholder"></span>
                    }
                    <span class="rules-report__cell-content" title="@GetPlainNumber(context.Node.Data)">
                        @((MarkupString)RuleDisplayBase.DisplayNumber(context.Node.Data))
                    </span>
                </div>

                @if (SelectedReportType == ReportType.Recertification)
                {
                    @if (IsColumnVisible(ColumnNextRecertDate))
                    {
                        <div class="rules-report__cell" title="@GetPlainNextRecert(context.Node.Data)">
                            <span class="rules-report__cell-content rules-report__cell-content--clamp">
                                @((MarkupString)RuleDisplayHtml.DisplayNextRecert(context.Node.Data.Metadata))
                            </span>
                        </div>
                    }
                    @if (IsColumnVisible(ColumnOwner))
                    {
                        <div class="rules-report__cell" title="@GetPlainOwner(context.Node.Data)">
                            <span class="rules-report__cell-content rules-report__cell-content--clamp">
                                @((MarkupString)RuleDisplayHtml.DisplayOwner(context.Node.Data.Metadata))
                            </span>
                        </div>
                    }
                    @if (IsColumnVisible(ColumnIpMatches))
                    {
                        <div class="rules-report__cell" title="@GetPlainIpMatches(context.Node.Data)">
                            <span class="rules-report__cell-content rules-report__cell-content--clamp">
                                @((MarkupString)RuleDisplayHtml.DisplayRecertIpMatches(context.Node.Data.Metadata))
                            </span>
                        </div>
                    }
                    @if (IsColumnVisible(ColumnLastHit))
                    {
                        <div class="rules-report__cell" title="@GetPlainLastHit(context.Node.Data)">
                            <span class="rules-report__cell-content">
                                @((MarkupString)RuleDisplayHtml.DisplayLastHit(context.Node.Data.Metadata))
                            </span>
                        </div>
                    }
                    @if (IsColumnVisible(ColumnLastModified))
                    {
                        <div class="rules-report__cell" title="@GetPlainLastModified(context.Node.Data)">
                            <span class="rules-report__cell-content">
                                @((MarkupString)RuleDisplayBase.DisplayLastModified(context.Node.Data))
                            </span>
                        </div>
                    }
                }
                else
                {
                    @if (ShouldShowLastHitColumn() && IsColumnVisible(ColumnLastHit))
                    {
                        <div class="rules-report__cell" title="@GetPlainLastHit(context.Node.Data)">
                            <span class="rules-report__cell-content">
                                @((MarkupString)RuleDisplayHtml.DisplayLastHit(context.Node.Data.Metadata))
                            </span>
                        </div>
                    }
                    @if (ShouldShowLastModifiedAfterLastHit() && IsColumnVisible(ColumnLastModified))
                    {
                        <div class="rules-report__cell" title="@GetPlainLastModified(context.Node.Data)">
                            <span class="rules-report__cell-content">
                                @((MarkupString)RuleDisplayBase.DisplayLastModified(context.Node.Data))
                            </span>
                        </div>
                    }
                }

                @if (IsColumnVisible(ColumnName))
                {
                    <div class="rules-report__cell" title="@GetPlainName(context.Node.Data)">
                        <span class="rules-report__cell-content rules-report__cell-content--clamp">
                            @context.Node.Data.Name
                        </span>
                    </div>
                }
                @if (IsColumnVisible(ColumnSourceZone))
                {
                    <div class="rules-report__cell" title="@GetPlainSourceZones(context.Node.Data)">
                        <span class="rules-report__cell-content rules-report__cell-content--clamp">
                            @((MarkupString)RuleDisplayBase.DisplaySourceZones(context.Node.Data))
                        </span>
                    </div>
                }
                @if (IsColumnVisible(ColumnSource))
                {
                    <div class="rules-report__cell" title="@GetPlainSource(context.Node.Data)">
                        <span class="rules-report__cell-content rules-report__cell-content--clamp">
                            @((MarkupString)_ruleDisplay!.DisplaySource(context.Node.Data, GetActLocation(), SelectedReportType))
                        </span>
                    </div>
                }
                @if (IsColumnVisible(ColumnDestinationZone))
                {
                    <div class="rules-report__cell" title="@GetPlainDestinationZones(context.Node.Data)">
                        <span class="rules-report__cell-content rules-report__cell-content--clamp">
                            @((MarkupString)RuleDisplayBase.DisplayDestinationZones(context.Node.Data))
                        </span>
                    </div>
                }
                @if (IsColumnVisible(ColumnDestination))
                {
                    <div class="rules-report__cell" title="@GetPlainDestination(context.Node.Data)">
                        <span class="rules-report__cell-content rules-report__cell-content--clamp">
                            @((MarkupString)_ruleDisplay!.DisplayDestination(context.Node.Data, GetActLocation(), SelectedReportType))
                        </span>
                    </div>
                }
                @if (IsColumnVisible(ColumnServices))
                {
                    <div class="rules-report__cell" title="@GetPlainServices(context.Node.Data)">
                        <span class="rules-report__cell-content rules-report__cell-content--clamp">
                            @((MarkupString)_ruleDisplay!.DisplayServices(context.Node.Data, GetActLocation(), SelectedReportType))
                        </span>
                    </div>
                }

                @if (SelectedReportType == ReportType.NatRules)
                {
                    @if (IsColumnVisible(ColumnTranslatedSource))
                    {
                        <div class="rules-report__cell rules-report__cell--translated" title="@GetPlainTranslatedSource(context.Node.Data)">
                            <span class="rules-report__cell-content rules-report__cell-content--clamp">
                                @((MarkupString)_ruleDisplay!.DisplayTranslatedSource(context.Node.Data, GetActLocation()))
                            </span>
                        </div>
                    }
                    @if (IsColumnVisible(ColumnTranslatedDestination))
                    {
                        <div class="rules-report__cell rules-report__cell--translated" title="@GetPlainTranslatedDestination(context.Node.Data)">
                            <span class="rules-report__cell-content rules-report__cell-content--clamp">
                                @((MarkupString)_ruleDisplay!.DisplayTranslatedDestination(context.Node.Data, GetActLocation()))
                            </span>
                        </div>
                    }
                    @if (IsColumnVisible(ColumnTranslatedServices))
                    {
                        <div class="rules-report__cell rules-report__cell--translated" title="@GetPlainTranslatedServices(context.Node.Data)">
                            <span class="rules-report__cell-content rules-report__cell-content--clamp">
                                @((MarkupString)_ruleDisplay!.DisplayTranslatedService(context.Node.Data, GetActLocation()))
                            </span>
                        </div>
                    }
                }
                else
                {
                    @if (IsColumnVisible(ColumnAction))
                    {
                        <div class="rules-report__cell" title="@GetPlainAction(context.Node.Data)">
                            <span class="rules-report__cell-content rules-report__cell-content--clamp">
                                @context.Node.Data.Action
                            </span>
                        </div>
                    }
                    @if (IsColumnVisible(ColumnTrack))
                    {
                        <div class="rules-report__cell" title="@GetPlainTrack(context.Node.Data)">
                            <span class="rules-report__cell-content rules-report__cell-content--clamp">
                                @context.Node.Data.Track
                            </span>
                        </div>
                    }
                }

                @if (IsColumnVisible(ColumnEnabled))
                {
                    <div class="rules-report__cell" title="@GetPlainEnabled(context.Node.Data)">
                        <span class="rules-report__cell-content">
                            @((MarkupString)RuleDisplayHtml.DisplayEnabled(context.Node.Data, GetActLocation()))
                        </span>
                    </div>
                }
                @if (IsColumnVisible(ColumnEnforcingDevices))
                {
                    <div class="rules-report__cell" title="@GetPlainEnforcingDevices(context.Node.Data)">
                        <span class="rules-report__cell-content rules-report__cell-content--clamp">
                            @((MarkupString)RuleDisplayHtml.DisplayEnforcingGateways(context.Node.Data, GetActLocation(), SelectedReportType))
                        </span>
                    </div>
                }
                @if (IsColumnVisible(ColumnUid))
                {
                    <div class="rules-report__cell" title="@GetPlainUid(context.Node.Data)">
                        <span class="rules-report__cell-content rules-report__cell-content--clamp">
                            @context.Node.Data.Uid
                        </span>
                    </div>
                }
                @if (IsColumnVisible(ColumnComment))
                {
                    <div class="rules-report__cell" title="@GetPlainComment(context.Node.Data)">
                        <span class="rules-report__cell-content rules-report__cell-content--clamp">
                            @context.Node.Data.Comment
                        </span>
                    </div>
                }
                @if (!ShouldShowLastModifiedAfterLastHit()
                    && SelectedReportType != ReportType.Recertification
                    && IsColumnVisible(ColumnLastModified))
                {
                    <div class="rules-report__cell" title="@GetPlainLastModified(context.Node.Data)">
                        <span class="rules-report__cell-content">
                            @((MarkupString)RuleDisplayBase.DisplayLastModified(context.Node.Data))
                        </span>
                    </div>
                }
            </div>
        }
    </div>;

    private RenderFragment<TreeViewNodeContext<RuleTreeItem>> RenderRuleDetail() => context => @<div class="rules-report__detail">
        <RuleDetails Rule="context.Node.Data" />
    </div>;

    private async Task ToggleRuleSelection(RuleTreeItem node, string managementName, string deviceName)
    {
        if (!node.IsRule)
        {
            return;
        }

        node.Data.ManagementName = managementName;
        node.Data.DeviceName = deviceName;
        node.Data.RulebaseName = ResolveRulebaseName(node);

        if (!SelectedRules.Remove(node.Data))
        {
            SelectedRules.Add(node.Data);
        }

        await SelectedRulesChanged.InvokeAsync(SelectedRules);
    }

    private bool ShouldShowRuleDetail(RuleTreeItem node)
    {
        return node.IsRule && SelectedRules.Contains(node.Data);
    }

    private bool ShouldRenderNode(RuleTreeItem node)
    {
        if (string.IsNullOrWhiteSpace(_searchTerm))
        {
            return true;
        }

        return _nodeVisibility.TryGetValue(node, out bool isVisible) && isVisible;
    }

    private void RefreshSearchVisibility()
    {
        _nodeVisibility.Clear();

        if (string.IsNullOrWhiteSpace(_searchTerm))
        {
            return;
        }

        foreach (var root in GetAllRuleTrees())
        {
            ApplySearchVisibility(root, _searchTerm.Trim());
        }
    }

    private IEnumerable<RuleTreeItem> GetAllRuleTrees()
    {
        foreach (var management in Managements)
        {
            foreach (var device in management.Devices.Where(dev => dev.ContainsRules()))
            {
                yield return GetRuleTree(management, device);
            }
        }
    }

    private bool ApplySearchVisibility(RuleTreeItem node, string searchTerm)
    {
        bool childVisible = false;
        foreach (var child in node.Children)
        {
            childVisible |= ApplySearchVisibility(child, searchTerm);
        }

        bool selfVisible = GetSearchText(node).Contains(searchTerm, StringComparison.OrdinalIgnoreCase);
        bool isVisible = selfVisible || childVisible;
        _nodeVisibility[node] = isVisible;

        if (childVisible)
        {
            node.IsExpanded = true;
        }

        return isVisible;
    }

    private string GetSearchText(RuleTreeItem node)
    {
        if (!node.IsRule)
        {
            return node.Header ?? string.Empty;
        }

        Rule rule = node.Data;
        return string.Join(
            " ",
            new[]
            {
                node.Header,
                GetPlainNumber(rule),
                GetPlainName(rule),
                GetPlainSourceZones(rule),
                GetPlainSource(rule),
                GetPlainDestinationZones(rule),
                GetPlainDestination(rule),
                GetPlainServices(rule),
                GetPlainTranslatedSource(rule),
                GetPlainTranslatedDestination(rule),
                GetPlainTranslatedServices(rule),
                GetPlainAction(rule),
                GetPlainTrack(rule),
                GetPlainEnabled(rule),
                GetPlainEnforcingDevices(rule),
                GetPlainUid(rule),
                GetPlainComment(rule),
                GetPlainLastHit(rule),
                GetPlainLastModified(rule),
                GetPlainNextRecert(rule),
                GetPlainOwner(rule),
                GetPlainIpMatches(rule)
            }.Where(value => !string.IsNullOrWhiteSpace(value)));
    }

    private bool IsHeaderNode(RuleTreeItem node)
    {
        return !node.IsRule;
    }

    private string GetHeaderTitle(RuleTreeItem node)
    {
        if (!string.IsNullOrWhiteSpace(node.Header))
        {
            return node.Header;
        }

        return userConfig.GetText("name");
    }

    private string ResolveRulebaseName(RuleTreeItem node)
    {
        RuleTreeItem? current = node.Parent;

        while (current != null)
        {
            if (!string.IsNullOrWhiteSpace(current.Header))
            {
                return current.Header;
            }

            current = current.Parent;
        }

        return node.Data.Rulebase?.Name ?? node.Data.RulebaseName;
    }

    private string GetRuleRowClasses(RuleTreeItem node)
    {
        return $"rules-report__row {(SelectedRules.Contains(node.Data) ? "rules-report__row--selected" : string.Empty)}".Trim();
    }

    private string GetDepthClass(int level)
    {
        return $"rules-report__depth-{Math.Min(level, 10)}";
    }

    private static string GetToggleSymbol(RuleTreeItem node)
    {
        return node.IsExpanded ? "▼" : "▶";
    }

    private OutputLocation GetActLocation()
    {
        return Recertification ? OutputLocation.certification : OutputLocation.report;
    }

    private static string NormalizeMarkup(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        string withoutTags = Regex.Replace(value, "<.*?>", " ");
        return WebUtility.HtmlDecode(withoutTags).Replace('\n', ' ').Replace('\r', ' ').Trim();
    }

