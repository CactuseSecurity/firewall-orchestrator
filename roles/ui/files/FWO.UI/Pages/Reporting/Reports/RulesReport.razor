@using System.Net
@using System.Text.RegularExpressions
@using FWO.Report
@using FWO.Services.RuleTreeBuilder
@using FWO.Ui.Display
@using FWO.Ui.Shared

@inject UserConfig userConfig
@inject IRuleTreeBuilder ruleTreeBuilder

@if (ShouldShowTreeToolbar())
{
    <div class="rules-report__toolbar">
        <div class="rules-report__search">
            <label class="rules-report__search-label" for="rules-report-search">@(userConfig.GetText("search"))</label>
            <input id="rules-report-search"
                   class="form-control form-control-sm"
                   type="search"
                   value="@_searchTerm"
                   @oninput="UpdateSearchTerm" />
        </div>

        <details class="rules-report__column-filter">
            <summary>
                <span class="@Icons.Filter"></span>
                @(userConfig.GetText("filter"))
            </summary>
            <div class="rules-report__column-options">
                @foreach (var column in GetAllColumns())
                {
                    <label class="rules-report__column-option">
                        <input type="checkbox"
                               checked="@IsColumnVisible(column.Key)"
                               @onchange="args => SetColumnVisibility(column.Key, args.Value as bool? ?? false)" />
                        <span>@column.Title</span>
                    </label>
                }
            </div>
        </details>
    </div>
}

@foreach (var management in Managements)
{
    @if (management.ContainsRules())
    {
        <Collapse Title="@management.Name" Style="@("primary")" StartToggled="false">
            @if (SelectedReportType.IsRulebaseReport())
            {
                @foreach (var rulebase in management.Rulebases)
                {
                    var rulebaseRules = ReportRules.GetRulesByRulebaseId(rulebase.Id, management);
                    @if (rulebaseRules.Length > 0)
                    {
                        <Collapse Title="@rulebase.Name" Style="@("secondary")" StartToggled="true">
                            <RuleBaseReport ReadonlyMode="ReadonlyMode"
                                            SelectedReportType="SelectedReportType"
                                            Rules="[.. rulebaseRules]"
                                            @bind-SelectedRules="SelectedRules"
                                            RulesPerPage="RulesPerPage" />
                        </Collapse>
                    }
                }
            }
            else
            {
                @foreach (var device in management.Devices)
                {
                    @if (device.ContainsRules() && _ruleDisplay != null)
                    {
                        <Collapse Title="@device.Name" Style="@("secondary")" StartToggled="true">
                            <div class="rules-report__tree">
                                <TreeView T="RuleTreeItem"
                                          Nodes="@GetRootNodes(management, device)"
                                          Columns="@GetVisibleColumns()"
                                          IsHeaderNode="IsHeaderNode"
                                          HeaderTitleSelector="GetHeaderTitle"
                                          OnNodeSelected="@CreateRuleSelectionCallback(management.Name ?? string.Empty, device.Name ?? string.Empty)"
                                          IsNodeSelected="IsRuleSelected"
                                          DetailContent="@RenderRuleDetail()"
                                          IsDetailExpanded="ShouldShowRuleDetail"
                                          ShouldRenderNode="ShouldRenderNode" />
                            </div>
                        </Collapse>
                    }
                }
            }
        </Collapse>
    }
}

@code
{
    [Parameter]
    public List<ManagementReport> Managements { get; set; } = [];

    [Parameter]
    public bool ReadonlyMode { get; set; }

    [Parameter]
    public bool Recertification { get; set; }

    [Parameter]
    public int RulesPerPage { get; set; }

    [Parameter]
    public ReportType SelectedReportType { get; set; }

    [Parameter]
    public List<Rule> SelectedRules { get; set; } = [];

    [Parameter]
    public EventCallback<List<Rule>> SelectedRulesChanged { get; set; }

    [Parameter]
    public int Width { get; set; }

    [Parameter]
    public EventCallback<int> WidthChanged { get; set; }

    private const string ColumnAction = "action";
    private const string ColumnComment = "comment";
    private const string ColumnDestination = "destination";
    private const string ColumnDestinationZone = "destination_zone";
    private const string ColumnEnabled = "enabled";
    private const string ColumnEnforcingDevices = "enforcing_devices";
    private const string ColumnIpMatches = "ip_matches";
    private const string ColumnLastHit = "last_hit";
    private const string ColumnLastModified = "last_modified";
    private const string ColumnName = "name";
    private const string ColumnNextRecertDate = "next_recert_date";
    private const string ColumnNumber = "number";
    private const string ColumnOwner = "owner";
    private const string ColumnServices = "services";
    private const string ColumnSource = "source";
    private const string ColumnSourceZone = "source_zone";
    private const string ColumnTrack = "track";
    private const string ColumnTranslatedDestination = "trans_destination";
    private const string ColumnTranslatedServices = "trans_services";
    private const string ColumnTranslatedSource = "trans_source";
    private const string ColumnUid = "uid";

    private readonly HashSet<string> _hiddenColumns = [];
    private readonly Dictionary<RuleTreeItem, bool> _nodeVisibility = [];

    private string _searchTerm = string.Empty;
    private NatRuleDisplayHtml? _ruleDisplay;

    protected override void OnInitialized()
    {
        _ruleDisplay = new NatRuleDisplayHtml(userConfig);
    }

    protected override void OnParametersSet()
    {
        RefreshSearchVisibility();
    }

    private bool ShouldShowTreeToolbar()
    {
        return !SelectedReportType.IsRulebaseReport()
            && Managements.Any(management => management.ContainsRules() && management.Devices.Any(device => device.ContainsRules()));
    }

    private List<RuleTreeItem> GetRootNodes(ManagementReport managementReport, DeviceReport deviceReport)
    {
        return GetRuleTree(managementReport, deviceReport).Children.ToList();
    }

    private RuleTreeItem GetRuleTree(ManagementReport managementReport, DeviceReport deviceReport)
    {
        if (ruleTreeBuilder.RuleTreeCache.TryGetValue((managementReport.Id, deviceReport.Id), out RuleTreeItem? ruleTreeFromCache))
        {
            return ruleTreeFromCache;
        }

        return new();
    }

    private void UpdateSearchTerm(ChangeEventArgs args)
    {
        _searchTerm = args.Value?.ToString() ?? string.Empty;
        RefreshSearchVisibility();
    }

    private void SetColumnVisibility(string columnKey, bool isVisible)
    {
        if (isVisible)
        {
            _hiddenColumns.Remove(columnKey);
        }
        else
        {
            _hiddenColumns.Add(columnKey);
        }
    }

    private bool IsColumnVisible(string columnKey)
    {
        return !_hiddenColumns.Contains(columnKey);
    }

    private List<TreeViewColumn<RuleTreeItem>> GetVisibleColumns()
    {
        return GetAllColumns().Where(column => IsColumnVisible(column.Key)).ToList();
    }

    private List<TreeViewColumn<RuleTreeItem>> GetAllColumns()
    {
        List<TreeViewColumn<RuleTreeItem>> columns =
        [
            CreateHtmlColumn(
                ColumnNumber,
                userConfig.GetText("number"),
                rule => RuleDisplayBase.DisplayNumber(rule),
                GetPlainNumber,
                "rules-report__column--number",
                isHierarchyColumn: true)
        ];

        if (SelectedReportType == ReportType.Recertification)
        {
            columns.Add(CreateHtmlColumn(ColumnNextRecertDate, userConfig.GetText("next_recert_date"), rule => RuleDisplayHtml.DisplayNextRecert(rule.Metadata), GetPlainNextRecert, clampContent: true));
            columns.Add(CreateHtmlColumn(ColumnOwner, userConfig.GetText("owner"), rule => RuleDisplayHtml.DisplayOwner(rule.Metadata), GetPlainOwner, clampContent: true));
            columns.Add(CreateHtmlColumn(ColumnIpMatches, userConfig.GetText("ip_matches"), rule => RuleDisplayHtml.DisplayRecertIpMatches(rule.Metadata), GetPlainIpMatches, clampContent: true));
            columns.Add(CreateHtmlColumn(ColumnLastHit, userConfig.GetText("last_hit"), rule => RuleDisplayHtml.DisplayLastHit(rule.Metadata), GetPlainLastHit));
            columns.Add(CreateHtmlColumn(ColumnLastModified, "LastModified", rule => RuleDisplayBase.DisplayLastModified(rule), GetPlainLastModified));
        }
        else
        {
            if (ShouldShowLastHitColumn())
            {
                columns.Add(CreateHtmlColumn(ColumnLastHit, userConfig.GetText("last_hit"), rule => RuleDisplayHtml.DisplayLastHit(rule.Metadata), GetPlainLastHit));
            }

            if (ShouldShowLastModifiedAfterLastHit())
            {
                columns.Add(CreateHtmlColumn(ColumnLastModified, "LastModified", rule => RuleDisplayBase.DisplayLastModified(rule), GetPlainLastModified));
            }
        }

        columns.Add(CreateTextColumn(ColumnName, userConfig.GetText("name"), rule => rule.Name ?? string.Empty, GetPlainName, clampContent: true));
        columns.Add(CreateHtmlColumn(ColumnSourceZone, userConfig.GetText("source_zone"), rule => RuleDisplayBase.DisplaySourceZones(rule), GetPlainSourceZones, clampContent: true));
        columns.Add(CreateHtmlColumn(ColumnSource, userConfig.GetText("source"), rule => _ruleDisplay!.DisplaySource(rule, GetActLocation(), SelectedReportType), GetPlainSource, clampContent: true));
        columns.Add(CreateHtmlColumn(ColumnDestinationZone, userConfig.GetText("destination_zone"), rule => RuleDisplayBase.DisplayDestinationZones(rule), GetPlainDestinationZones, clampContent: true));
        columns.Add(CreateHtmlColumn(ColumnDestination, userConfig.GetText("destination"), rule => _ruleDisplay!.DisplayDestination(rule, GetActLocation(), SelectedReportType), GetPlainDestination, clampContent: true));
        columns.Add(CreateHtmlColumn(ColumnServices, userConfig.GetText("services"), rule => _ruleDisplay!.DisplayServices(rule, GetActLocation(), SelectedReportType), GetPlainServices, clampContent: true));

        if (SelectedReportType == ReportType.NatRules)
        {
            columns.Add(CreateHtmlColumn(ColumnTranslatedSource, userConfig.GetText("trans_source"), rule => _ruleDisplay!.DisplayTranslatedSource(rule, GetActLocation()), GetPlainTranslatedSource, "rules-report__column--translated", true));
            columns.Add(CreateHtmlColumn(ColumnTranslatedDestination, userConfig.GetText("trans_destination"), rule => _ruleDisplay!.DisplayTranslatedDestination(rule, GetActLocation()), GetPlainTranslatedDestination, "rules-report__column--translated", true));
            columns.Add(CreateHtmlColumn(ColumnTranslatedServices, userConfig.GetText("trans_services"), rule => _ruleDisplay!.DisplayTranslatedService(rule, GetActLocation()), GetPlainTranslatedServices, "rules-report__column--translated", true));
        }
        else
        {
            columns.Add(CreateTextColumn(ColumnAction, userConfig.GetText("action"), rule => rule.Action ?? string.Empty, GetPlainAction, clampContent: true));
            columns.Add(CreateTextColumn(ColumnTrack, userConfig.GetText("track"), rule => rule.Track ?? string.Empty, GetPlainTrack, clampContent: true));
        }

        columns.Add(CreateHtmlColumn(ColumnEnabled, userConfig.GetText("enabled"), rule => RuleDisplayHtml.DisplayEnabled(rule, GetActLocation()), GetPlainEnabled));
        columns.Add(CreateHtmlColumn(ColumnEnforcingDevices, userConfig.GetText("enforcing_devices"), rule => RuleDisplayHtml.DisplayEnforcingGateways(rule, GetActLocation(), SelectedReportType), GetPlainEnforcingDevices, clampContent: true));
        columns.Add(CreateTextColumn(ColumnUid, userConfig.GetText("uid"), rule => rule.Uid ?? string.Empty, GetPlainUid, clampContent: true));
        columns.Add(CreateTextColumn(ColumnComment, userConfig.GetText("comment"), rule => rule.Comment ?? string.Empty, GetPlainComment, clampContent: true));

        if (!ShouldShowLastModifiedAfterLastHit() && SelectedReportType != ReportType.Recertification)
        {
            columns.Add(CreateHtmlColumn(ColumnLastModified, "LastModified", rule => RuleDisplayBase.DisplayLastModified(rule), GetPlainLastModified));
        }

        return columns;
    }

    private static TreeViewColumn<RuleTreeItem> CreateTextColumn(
        string key,
        string title,
        Func<Rule, string> textSelector,
        Func<Rule, string> tooltipSelector,
        string columnClass = "",
        bool clampContent = false,
        bool isHierarchyColumn = false)
    {
        return new()
        {
            Key = key,
            Title = title,
            HeaderClass = columnClass,
            CellClass = columnClass,
            ClampContent = clampContent,
            IsHierarchyColumn = isHierarchyColumn,
            TextSelector = context => textSelector(context.Node.Data),
            TooltipSelector = context => tooltipSelector(context.Node.Data)
        };
    }

    private static TreeViewColumn<RuleTreeItem> CreateHtmlColumn(
        string key,
        string title,
        Func<Rule, string> htmlSelector,
        Func<Rule, string> tooltipSelector,
        string columnClass = "",
        bool clampContent = false,
        bool isHierarchyColumn = false)
    {
        return new()
        {
            Key = key,
            Title = title,
            HeaderClass = columnClass,
            CellClass = columnClass,
            ClampContent = clampContent,
            IsHierarchyColumn = isHierarchyColumn,
            HtmlSelector = context => htmlSelector(context.Node.Data),
            TooltipSelector = context => tooltipSelector(context.Node.Data)
        };
    }

    private bool ShouldShowLastHitColumn()
    {
        return SelectedReportType == ReportType.UnusedRules
            || SelectedReportType == ReportType.AppRules
            || SelectedReportType == ReportType.Recertification;
    }

    private bool ShouldShowLastModifiedAfterLastHit()
    {
        return SelectedReportType == ReportType.UnusedRules
            || SelectedReportType == ReportType.AppRules;
    }

    private RenderFragment<TreeViewNodeContext<RuleTreeItem>> RenderRuleDetail() => context => @<div class="rules-report__detail">
        <RuleDetails Rule="context.Node.Data" />
    </div>;

    private EventCallback<RuleTreeItem> CreateRuleSelectionCallback(string managementName, string deviceName)
    {
        return EventCallback.Factory.Create<RuleTreeItem>(this, node => ToggleRuleSelection(node, managementName, deviceName));
    }

    private async Task ToggleRuleSelection(RuleTreeItem node, string managementName, string deviceName)
    {
        if (!node.IsRule)
        {
            return;
        }

        node.Data.ManagementName = managementName;
        node.Data.DeviceName = deviceName;
        node.Data.RulebaseName = ResolveRulebaseName(node);

        if (!SelectedRules.Remove(node.Data))
        {
            SelectedRules.Add(node.Data);
        }

        await SelectedRulesChanged.InvokeAsync(SelectedRules);
    }

    private bool IsRuleSelected(RuleTreeItem node)
    {
        return node.IsRule && SelectedRules.Contains(node.Data);
    }

    private bool ShouldShowRuleDetail(RuleTreeItem node)
    {
        return node.IsRule && SelectedRules.Contains(node.Data);
    }

    private bool ShouldRenderNode(RuleTreeItem node)
    {
        if (string.IsNullOrWhiteSpace(_searchTerm))
        {
            return true;
        }

        return _nodeVisibility.TryGetValue(node, out bool isVisible) && isVisible;
    }

    private void RefreshSearchVisibility()
    {
        _nodeVisibility.Clear();

        if (string.IsNullOrWhiteSpace(_searchTerm))
        {
            return;
        }

        foreach (var root in GetAllRuleTrees())
        {
            ApplySearchVisibility(root, _searchTerm.Trim());
        }
    }

    private IEnumerable<RuleTreeItem> GetAllRuleTrees()
    {
        foreach (var management in Managements)
        {
            foreach (var device in management.Devices.Where(dev => dev.ContainsRules()))
            {
                yield return GetRuleTree(management, device);
            }
        }
    }

    private bool ApplySearchVisibility(RuleTreeItem node, string searchTerm)
    {
        bool childVisible = false;
        foreach (var child in node.Children)
        {
            childVisible |= ApplySearchVisibility(child, searchTerm);
        }

        bool selfVisible = GetSearchText(node).Contains(searchTerm, StringComparison.OrdinalIgnoreCase);
        bool isVisible = selfVisible || childVisible;
        _nodeVisibility[node] = isVisible;

        if (childVisible)
        {
            node.IsExpanded = true;
        }

        return isVisible;
    }

    private string GetSearchText(RuleTreeItem node)
    {
        if (!node.IsRule)
        {
            return node.Header ?? string.Empty;
        }

        Rule rule = node.Data;
        return string.Join(
            " ",
            new[]
            {
                node.Header,
                GetPlainNumber(rule),
                GetPlainName(rule),
                GetPlainSourceZones(rule),
                GetPlainSource(rule),
                GetPlainDestinationZones(rule),
                GetPlainDestination(rule),
                GetPlainServices(rule),
                GetPlainTranslatedSource(rule),
                GetPlainTranslatedDestination(rule),
                GetPlainTranslatedServices(rule),
                GetPlainAction(rule),
                GetPlainTrack(rule),
                GetPlainEnabled(rule),
                GetPlainEnforcingDevices(rule),
                GetPlainUid(rule),
                GetPlainComment(rule),
                GetPlainLastHit(rule),
                GetPlainLastModified(rule),
                GetPlainNextRecert(rule),
                GetPlainOwner(rule),
                GetPlainIpMatches(rule)
            }.Where(value => !string.IsNullOrWhiteSpace(value)));
    }

    private static bool IsHeaderNode(RuleTreeItem node)
    {
        return !node.IsRule;
    }

    private string GetHeaderTitle(RuleTreeItem node)
    {
        if (!string.IsNullOrWhiteSpace(node.Header))
        {
            return node.Header;
        }

        return userConfig.GetText("name");
    }

    private string ResolveRulebaseName(RuleTreeItem node)
    {
        RuleTreeItem? current = node.Parent;

        while (current != null)
        {
            if (!string.IsNullOrWhiteSpace(current.Header))
            {
                return current.Header;
            }

            current = current.Parent;
        }

        return node.Data.Rulebase?.Name ?? node.Data.RulebaseName;
    }

    private OutputLocation GetActLocation()
    {
        return Recertification ? OutputLocation.certification : OutputLocation.report;
    }

    private static string NormalizeMarkup(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        string withoutTags = Regex.Replace(value, "<.*?>", " ");
        return WebUtility.HtmlDecode(withoutTags).Replace('\n', ' ').Replace('\r', ' ').Trim();
    }

    private static string GetPlainLastModified(Rule rule)
    {
        return NormalizeMarkup(RuleDisplayBase.DisplayLastModified(rule));
    }

    private static string GetPlainNumber(Rule rule)
    {
        return NormalizeMarkup(RuleDisplayBase.DisplayNumber(rule));
    }

    private static string GetPlainSourceZones(Rule rule)
    {
        return NormalizeMarkup(RuleDisplayBase.DisplaySourceZones(rule));
    }

    private static string GetPlainDestinationZones(Rule rule)
    {
        return NormalizeMarkup(RuleDisplayBase.DisplayDestinationZones(rule));
    }

    private string GetPlainSource(Rule rule)
    {
        return NormalizeMarkup(_ruleDisplay?.DisplaySource(rule, GetActLocation(), SelectedReportType) ?? string.Empty);
    }

    private string GetPlainDestination(Rule rule)
    {
        return NormalizeMarkup(_ruleDisplay?.DisplayDestination(rule, GetActLocation(), SelectedReportType) ?? string.Empty);
    }

    private string GetPlainServices(Rule rule)
    {
        return NormalizeMarkup(_ruleDisplay?.DisplayServices(rule, GetActLocation(), SelectedReportType) ?? string.Empty);
    }

    private string GetPlainTranslatedSource(Rule rule)
    {
        return NormalizeMarkup(_ruleDisplay?.DisplayTranslatedSource(rule, GetActLocation()) ?? string.Empty);
    }

    private string GetPlainTranslatedDestination(Rule rule)
    {
        return NormalizeMarkup(_ruleDisplay?.DisplayTranslatedDestination(rule, GetActLocation()) ?? string.Empty);
    }

    private string GetPlainTranslatedServices(Rule rule)
    {
        return NormalizeMarkup(_ruleDisplay?.DisplayTranslatedService(rule, GetActLocation()) ?? string.Empty);
    }

    private static string GetPlainName(Rule rule)
    {
        return rule.Name ?? string.Empty;
    }

    private static string GetPlainAction(Rule rule)
    {
        return rule.Action ?? string.Empty;
    }

    private static string GetPlainTrack(Rule rule)
    {
        return rule.Track ?? string.Empty;
    }

    private static string GetPlainUid(Rule rule)
    {
        return rule.Uid ?? string.Empty;
    }

    private static string GetPlainComment(Rule rule)
    {
        return rule.Comment ?? string.Empty;
    }

    private static string GetPlainEnabled(Rule rule)
    {
        return rule.Disabled ? "disabled" : "enabled";
    }

    private string GetPlainEnforcingDevices(Rule rule)
    {
        return NormalizeMarkup(RuleDisplayHtml.DisplayEnforcingGateways(rule, GetActLocation(), SelectedReportType));
    }

    private static string GetPlainLastHit(Rule rule)
    {
        return NormalizeMarkup(RuleDisplayHtml.DisplayLastHit(rule.Metadata));
    }

    private static string GetPlainNextRecert(Rule rule)
    {
        return NormalizeMarkup(RuleDisplayHtml.DisplayNextRecert(rule.Metadata));
    }

    private static string GetPlainOwner(Rule rule)
    {
        return NormalizeMarkup(RuleDisplayHtml.DisplayOwner(rule.Metadata));
    }

    private static string GetPlainIpMatches(Rule rule)
    {
        return NormalizeMarkup(RuleDisplayHtml.DisplayRecertIpMatches(rule.Metadata));
    }
}
