@using FWO.Ui.Display
@using FWO.Data.Flow


@attribute [Authorize(Roles = $"{Roles.Admin}, {Roles.WorkflowRolesList}, {Roles.Auditor}, {Roles.FwAdmin}")]

@inject ApiConnection apiConnection
@inject UserConfig userConfig


<hr />
@if(InitComplete)
{
    @if (AnyEditMode && userConfig.ReqAllowObjectSearch)
    {
        <div class="bg-secondary p-2">
            <div class="form-group row col-sm-12">
                @if (CanEditSources)
                {
                    <div class="col-sm-4">
                        <div class="form-group row">
                            <label class="col-sm-2">@(userConfig.GetText("obj")):</label>
                            <div class="col-sm-9">
                                <Dropdown ElementType="NetworkObject" @bind-SelectedElement="newSourceNetwork" ElementToString="@(n => n.Name)" Elements="nwObjects" Nullable="true">
                                    <ElementTemplate Context="nwObject">
                                        @nwObject.Name
                                    </ElementTemplate>
                                </Dropdown>
                            </div>
                        </div>
                    </div>
                }
                @if (CanEditDestinations)
                {
                    <div class="col-sm-4">
                        <div class="form-group row">
                            <label class="col-sm-2">@(userConfig.GetText("obj")):</label>
                            <div class="col-sm-9">
                                <Dropdown ElementType="NetworkObject" @bind-SelectedElement="newDestinationNetwork" ElementToString="@(n => n.Name)" Elements="nwObjects" Nullable="true">
                                    <ElementTemplate Context="nwObject">
                                        @nwObject.Name
                                    </ElementTemplate>
                                </Dropdown>
                            </div>
                        </div>
                    </div>
                }
                @if (CanEditServices)
                {
                    <div class="col-sm-4">
                        <div class="form-group row">
                            <label class="col-sm-2">@(userConfig.GetText("obj")):</label>
                            <div class="col-sm-9">
                                <Dropdown ElementType="NetworkService" @bind-SelectedElement="newService" ElementToString="@(s => s.Name)" Elements="nwServices" Nullable="true">
                                    <ElementTemplate Context="nwService">
                                        @nwService.Name
                                    </ElementTemplate>
                                </Dropdown>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    <div class="form-group row col-sm-12 mh-13">
        <div class="col-sm-4">
            <label class="col-sm-12 col-form-label col-form-label-sm">@(userConfig.GetText("source"))*:</label>
            @if (CanEditSources)
            {
                <IpSelector IpAddresses="Sources" @bind-IpsToAdd="SourcesToAdd" @bind-IpsToDelete="SourcesToDelete" WithLabel="false"/>
            }
            else
            {
                <div class="list-group">
                    @foreach(var source in Sources.Where(HasNetworkObjectReference))
                    {
                        <div class="list-group-item border bg-secondary">
                            <label>@DisplayNetworkObject(source)</label>
                        </div>
                    }
                    @foreach(var source in Sources.Where(x => !HasNetworkObjectReference(x)))
                    {
                        <div class="list-group-item border bg-secondary">
                            <label>@DisplayNetworkElement(source)</label>
                        </div>
                    }
                </div>
            }
        </div>
        <div class="col-sm-4">
            <label for="taskDest" class="col-sm-12 col-form-label col-form-label-sm">@(userConfig.GetText("destination"))*:</label>
            @if (CanEditDestinations)
            {
                <IpSelector IpAddresses="Destinations" @bind-IpsToAdd="DestinationsToAdd" @bind-IpsToDelete="DestinationsToDelete" WithLabel="false"/>
            }
            else
            {
                <div class="list-group">
                    @foreach(var destination in Destinations.Where(HasNetworkObjectReference))
                    {
                        <div class="list-group-item border bg-secondary">
                            <label>@DisplayNetworkObject(destination)</label>
                        </div>
                    }
                    @foreach(var destination in Destinations.Where(x => !HasNetworkObjectReference(x)))
                    {
                        <div class="list-group-item border bg-secondary">
                            <label>@DisplayNetworkElement(destination)</label>
                        </div>
                    }
                </div>
            }
        </div>
        <div class="col-sm-4">
            <label for="taskService" class="col-sm-12 col-form-label col-form-label-sm">@(userConfig.GetText("service"))*:</label>
            @if (CanEditServices)
            {
                <ServiceSelector Services="Services" @bind-ServicesToAdd="ServicesToAdd" @bind-ServicesToDelete="ServicesToDelete" IpProtos="IpProtos" TaskId="TaskId" WithLabel="false"/>
            }
            else
            {
                <div class="list-group">
                    @foreach(var service in Services.Where(HasServiceObjectReference))
                    {
                        <label class="list-group-item border bg-secondary">@DisplayNetworkService(service)</label>
                    }
                    @foreach(var service in Services.Where(x => !HasServiceObjectReference(x)))
                    {
                        <div class="list-group-item border bg-secondary">
                            <label>@DisplayServiceElement(service)</label>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}
else
{
    <Loading/>
}

@code
{
    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;

    [Parameter]
    public List<NwObjectElement> Sources { get; set; } = [];

    [Parameter]
    public List<NwObjectElement> SourcesToAdd { get; set; } = [];

    [Parameter]
    public EventCallback<List<NwObjectElement>> SourcesToAddChanged { get; set; }

    [Parameter]
    public List<NwObjectElement> SourcesToDelete { get; set; } = [];
        
    [Parameter]
    public EventCallback<List<NwObjectElement>> SourcesToDeleteChanged { get; set; }

    [Parameter]
    public List<NwObjectElement> Destinations { get; set; } = [];

    [Parameter]
    public List<NwObjectElement> DestinationsToAdd { get; set; } = [];

    [Parameter]
    public EventCallback<List<NwObjectElement>> DestinationsToAddChanged { get; set; }

    [Parameter]
    public List<NwObjectElement> DestinationsToDelete { get; set; } = [];

    [Parameter]
    public EventCallback<List<NwObjectElement>> DestinationsToDeleteChanged { get; set; }

    [Parameter]
    public List<NwServiceElement> Services { get; set; } = [];

    [Parameter]
    public List<NwServiceElement> ServicesToAdd { get; set; } = [];

    [Parameter]
    public EventCallback<List<NwServiceElement>> ServicesToAddChanged { get; set; }

    [Parameter]
    public List<NwServiceElement> ServicesToDelete { get; set; } = [];

    [Parameter]
    public EventCallback<List<NwServiceElement>> ServicesToDeleteChanged { get; set; }

    [Parameter]
    public List<IpProtocol> IpProtos { get; set; } = [];

    [Parameter]
    public long TaskId { get; set; } = 0;

    [Parameter]
    public bool EditMode { get; set; } = false;

    [Parameter]
    public bool EditSources { get; set; } = false;

    [Parameter]
    public bool EditDestinations { get; set; } = false;

    [Parameter]
    public bool EditServices { get; set; } = false;

    private bool InitComplete = false;
    private bool CanEditSources => EditMode || EditSources;
    private bool CanEditDestinations => EditMode || EditDestinations;
    private bool CanEditServices => EditMode || EditServices;
    private bool AnyEditMode => CanEditSources || CanEditDestinations || CanEditServices;
    private List<NetworkObject> nwObjects = [];
    private List<NetworkService> nwServices = [];
    

    private NetworkObject? newSourceNetworkInt = null;
    private NetworkObject? newSourceNetwork
    {
        get => newSourceNetworkInt;
        set
        {
            if(value != null && value.Id != 0)
            {
                AddSelectedNetworkElement(SourcesToAdd, BuildNetworkElement(value));
            }
            newSourceNetworkInt = null;
            StateHasChanged();
        }
    }

    private NetworkObject? newDestinationNetworkInt = null;
    private NetworkObject? newDestinationNetwork
    {
        get => newDestinationNetworkInt;
        set
        {
            if(value != null && value.Id != 0)
            {
                AddSelectedNetworkElement(DestinationsToAdd, BuildNetworkElement(value));
            }
            newDestinationNetworkInt = null;
            StateHasChanged();
        }
    }

    private NetworkService? newServiceInt = null;
    private NetworkService? newService
    {
        get => newServiceInt;
        set
        {
            if(value != null && value.Id != 0)
            {
                AddSelectedServiceElement(ServicesToAdd, BuildServiceElement(value));
            }
            newServiceInt = null;
            StateHasChanged();
        }
    }

    private string DisplayNetworkObject(NwObjectElement element)
    {
        if (!string.IsNullOrWhiteSpace(element.GroupName))
        {
            return element.GroupName;
        }
        string? catalogName = nwObjects.FirstOrDefault(nwObject => IsMatchingNetworkObject(nwObject, element))?.Name;
        if (!string.IsNullOrWhiteSpace(catalogName))
        {
            return catalogName;
        }
        if (!string.IsNullOrWhiteSpace(element.Name))
        {
            return element.Name;
        }
        return element.FlowNetworkObjectId?.ToString()
            ?? element.FlowNetworkGroupId?.ToString()
            ?? element.NetworkId?.ToString()
            ?? "";
    }

    private string DisplayNetworkService(NwServiceElement element)
    {
        if (!string.IsNullOrWhiteSpace(element.GroupName))
        {
            return element.GroupName;
        }
        string? catalogName = nwServices.FirstOrDefault(service => IsMatchingNetworkService(service, element))?.Name;
        if (!string.IsNullOrWhiteSpace(catalogName))
        {
            return catalogName;
        }
        if (!string.IsNullOrWhiteSpace(element.Name))
        {
            return element.Name;
        }
        return element.FlowServiceObjectId?.ToString()
            ?? element.FlowServiceGroupId?.ToString()
            ?? element.ServiceId?.ToString()
            ?? "";
    }

    private string DisplayServiceElement(NwServiceElement element)
    {
        if (!string.IsNullOrEmpty(element.GroupName))
        {
            return element.GroupName;
        }
        if (!string.IsNullOrWhiteSpace(element.Name))
        {
            return element.Name;
        }
        return DisplayBase.DisplayService(element, IpProtos);
    }

    private static string DisplayNetworkElement(NwObjectElement element)
    {
        if (!string.IsNullOrWhiteSpace(element.GroupName))
        {
            return element.GroupName;
        }
        if (!string.IsNullOrWhiteSpace(element.Name))
        {
            return element.Name;
        }
        return NwObjDisplay.DisplayIp(element.IpString, element.IpEndString);
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (NeedsFlowCatalog())
            {
                List<FlowNwObject> flowNwObjects = await apiConnection.SendQueryAsync<List<FlowNwObject>>(FlowQueries.getFlowNwObjectCatalog) ?? [];
                List<FlowSvcObject> flowSvcObjects = await apiConnection.SendQueryAsync<List<FlowSvcObject>>(FlowQueries.getFlowSvcObjectCatalog) ?? [];
                nwObjects = [.. flowNwObjects.Where(IsSelectable).Select(ToNetworkObject)];
                nwServices = [.. flowSvcObjects.Where(IsSelectable).Select(ToNetworkService)];
            }
            InitComplete = true;
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("fetch_data"), "", true);
        }
    }

    private NwObjectElement BuildNetworkElement(NetworkObject networkObject)
    {
        NwObjectElement element = new()
        {
            NetworkId = userConfig.ReqUseFlowDb ? null : networkObject.Id,
            FlowNetworkObjectId = userConfig.ReqUseFlowDb ? networkObject.FlowNetworkObjectId ?? networkObject.Id : null,
            Name = networkObject.Name,
            TaskId = TaskId
        };
        if (!string.IsNullOrWhiteSpace(networkObject.IP))
        {
            element.IpString = networkObject.IP;
        }
        if (!string.IsNullOrWhiteSpace(networkObject.IpEnd))
        {
            element.IpEndString = networkObject.IpEnd;
        }
        return element;
    }

    private static void AddSelectedNetworkElement(List<NwObjectElement> elementsToAdd, NwObjectElement element)
    {
        elementsToAdd.Add(element);
    }

    private NwServiceElement BuildServiceElement(NetworkService networkService)
    {
        return new()
        {
            ServiceId = userConfig.ReqUseFlowDb ? null : networkService.Id,
            FlowServiceObjectId = userConfig.ReqUseFlowDb ? networkService.FlowServiceObjectId ?? networkService.Id : null,
            Name = networkService.Name,
            Port = networkService.DestinationPort ?? 0,
            PortEnd = networkService.DestinationPortEnd,
            ProtoId = networkService.ProtoId ?? 0,
            TaskId = TaskId
        };
    }

    private static void AddSelectedServiceElement(List<NwServiceElement> elementsToAdd, NwServiceElement element)
    {
        elementsToAdd.Add(element);
    }

    private static bool HasNetworkObjectReference(NwObjectElement element)
    {
        return HasId(element.NetworkId) || HasNetworkFlowReference(element);
    }

    private static bool HasServiceObjectReference(NwServiceElement element)
    {
        return HasId(element.ServiceId) || HasServiceFlowReference(element);
    }

    private bool NeedsFlowCatalog()
    {
        return userConfig.ReqUseFlowDb
            && (AnyEditMode && userConfig.ReqAllowObjectSearch
                || Sources.Any(HasNetworkFlowReference)
                || Destinations.Any(HasNetworkFlowReference)
                || Services.Any(HasServiceFlowReference));
    }

    private static bool HasNetworkFlowReference(NwObjectElement element)
    {
        return HasId(element.FlowNetworkObjectId) || HasId(element.FlowNetworkGroupId);
    }

    private static bool HasServiceFlowReference(NwServiceElement element)
    {
        return HasId(element.FlowServiceObjectId) || HasId(element.FlowServiceGroupId);
    }

    private static bool HasId(long? id)
    {
        return id.HasValue && id.Value != 0;
    }

    private static bool IsMatchingNetworkObject(NetworkObject networkObject, NwObjectElement element)
    {
        return HasId(element.FlowNetworkObjectId) && networkObject.FlowNetworkObjectId == element.FlowNetworkObjectId
            || HasId(element.NetworkId) && networkObject.Id == element.NetworkId;
    }

    private static bool IsMatchingNetworkService(NetworkService networkService, NwServiceElement element)
    {
        return HasId(element.FlowServiceObjectId) && networkService.FlowServiceObjectId == element.FlowServiceObjectId
            || HasId(element.ServiceId) && networkService.Id == element.ServiceId;
    }

    private static bool IsSelectable(FlowNwObject nwObject)
    {
        return nwObject.ShowInRequestModule && nwObject.RemovedDate == null;
    }

    private static bool IsSelectable(FlowSvcObject svcObject)
    {
        return svcObject.ShowInRequestModule && svcObject.RemovedDate == null;
    }

    private static NetworkObject ToNetworkObject(FlowNwObject nwObject)
    {
        return new()
        {
            Id = nwObject.Id,
            Name = nwObject.Name ?? BuildNetworkObjectName(nwObject),
            IP = nwObject.IpStart ?? "",
            IpEnd = nwObject.IpEnd ?? "",
            FlowNetworkObjectId = nwObject.Id
        };
    }

    private NetworkService ToNetworkService(FlowSvcObject svcObject)
    {
        return new()
        {
            Id = svcObject.Id,
            Name = !string.IsNullOrWhiteSpace(svcObject.Name) ? svcObject.Name : BuildServiceObjectName(svcObject),
            DestinationPort = svcObject.PortStart,
            DestinationPortEnd = svcObject.PortEnd,
            ProtoId = svcObject.ProtoId,
            FlowServiceObjectId = svcObject.Id
        };
    }

    private static string BuildNetworkObjectName(FlowNwObject nwObject)
    {
        return string.IsNullOrWhiteSpace(nwObject.IpEnd) || nwObject.IpEnd == nwObject.IpStart
            ? nwObject.IpStart ?? ""
            : $"{nwObject.IpStart}-{nwObject.IpEnd}";
    }

    private string BuildServiceObjectName(FlowSvcObject svcObject)
    {
        string portLabel = svcObject.PortEnd.HasValue && svcObject.PortEnd != svcObject.PortStart
            ? $"{svcObject.PortStart}-{svcObject.PortEnd}"
            : $"{svcObject.PortStart}";
        string protocolLabel = IpProtos.FirstOrDefault(protocol => protocol.Id == svcObject.ProtoId)?.Name ?? $"{svcObject.ProtoId}";
        return $"{portLabel}/{protocolLabel}";
    }

    private void DeleteSource(NwObjectElement obj)
    {
        Sources.Remove(obj);
        StateHasChanged();
    }

    private void DeleteDestination(NwObjectElement obj)
    {
        Destinations.Remove(obj);
        StateHasChanged();
    }

    private void DeleteService(NwServiceElement obj)
    {
        Services.Remove(obj);
        StateHasChanged();
    }
}
