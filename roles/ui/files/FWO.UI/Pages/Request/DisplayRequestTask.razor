@using FWO.Ui.Display
@using FWO.Ui.Pages.NetworkModelling
@using FWO.Ui.Services
@using FWO.Data.Workflow
@using System.Text.Json


@attribute [Authorize(Roles = $"{Roles.Admin}, {Roles.WorkflowRolesList}, {Roles.Auditor}, {Roles.FwAdmin}")]

@inject ApiConnection apiConnection
@inject UserConfig userConfig


<PopUp Title="@(userConfig.GetText("task") + ": " + WfHandler.ActReqTask.Title)" Show="@WfHandler.DisplayReqTaskMode" Size=PopupSize.XLarge OnClose="async () => await Close()">
    <Body>
        @if (WfHandler.DisplayReqTaskMode)
        {
            <form>
                <div class="form-group row">
                    <div class="col-sm-2">
                        <div class="form-group row">
                            <label class="col-sm-6 col-form-label col-form-label-sm">@(userConfig.GetText("req_task_id")):</label>
                            <div class="col-sm-6">
                                <label class="col-sm-12 border bg-secondary">@WfHandler.ActReqTask.Id</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-10">
                        <div class="form-group row">
                            <label class="col-sm-1 col-form-label col-form-label-sm">@(userConfig.GetText("title"))*:</label>
                            <div class="col-sm-11">
                                <input type="text" class="form-control form-control-sm" readonly="@(!CanEditReqTaskField(WorkflowEditableFieldKeys.Title))" @bind="WfHandler.ActReqTask.Title" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="form-group row mt-2">
                    <div class="col-sm-3">
                        <div class="form-group row">
                            <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("state")):</label>
                            <div class="col-sm-8">
                                <label class="col-sm-12 h-100 border bg-secondary">@States.GetName(WfHandler.ActReqTask.StateId)</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <div class="form-group row">
                            <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("handler")):</label>
                            <div class="col-sm-8">
                                <label class="col-sm-12 h-100 border bg-secondary">@WfHandler.ActReqTask.CurrentHandler?.Name</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <div class="form-group row">
                            <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("assigned")):</label>
                            <div class="col-sm-8">
                                <label class="col-sm-12 h-100 border bg-secondary">@(new DistName(WfHandler.ActReqTask.AssignedGroup).UserName)</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="form-group row mt-2">
                    <div class="col-sm-3">
                        <div class="form-group row">
                            <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("type"))*:</label>
                            <div class="col-sm-8">
                                @if (WfHandler.AddReqTaskMode)
                                {
                                    <Dropdown ElementType="WfTaskType" @bind-SelectedElement="actTaskType" ElementToString="@(t => userConfig.GetText(t.ToString()))" Elements="availableTaskTypes.Where(x => x != WfTaskType.master)" >
                                        <ElementTemplate Context="type">
                                            @(userConfig.GetText(type.ToString()))
                                        </ElementTemplate>
                                    </Dropdown>
                                }
                                else
                                {
                                    <label class="col-sm-12 h-100 border bg-secondary">@(userConfig.GetText(actTaskType.ToString()))</label>
                                }
                            </div>
                        </div>
                    </div>

                    @if(actTaskType == WfTaskType.access || actTaskType == WfTaskType.rule_modify || actTaskType == WfTaskType.rule_delete || actTaskType == WfTaskType.group_create)
                    {
                        <div class="col-sm-3">
                            <div class="form-group row">
                                <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("management")):</label>
                                <div class="col-sm-8">
                                    @if (CanEditReqTaskField(WorkflowEditableFieldKeys.Management))
                                    {
                                        <Dropdown ElementType="Management" @bind-SelectedElement="actManagement" ElementToString="@(d => d.Name)" Elements="managements" Nullable="true">
                                            <ElementTemplate Context="management">
                                                @management.Name
                                            </ElementTemplate>
                                        </Dropdown>
                                    }
                                    else
                                    {
                                        <label class="col-sm-12 h-100 border bg-secondary">@actManagement?.Name</label>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    @if(actTaskType == WfTaskType.access && NeedsManualDeviceSelection())
                    {
                        <div class="col-sm-3">
                            <div class="form-group row">
                                <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("gateway"))@(actTaskType == WfTaskType.rule_modify || actTaskType == WfTaskType.rule_delete ? "*" : ""):</label>
                                <div class="col-sm-8">
                                    @if (CanEditReqTaskField(WorkflowEditableFieldKeys.Gateways))
                                    {
                                        <Dropdown ElementType="Device" SelectedElementsChanged="SetDevices" SelectedElementChanged="SetDevice" SelectedElements="selectedDevices" ElementToString="@(d => d.Name ?? string.Empty)" Elements="selectableDevices" Multiselect="true">
                                            <ElementTemplate Context="device">
                                                @device.Name
                                            </ElementTemplate>
                                        </Dropdown>
                                    }
                                    else
                                    {
                                        <label class="col-sm-12 h-100 border bg-secondary">@DisplayDevices()</label>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    else if(actTaskType == WfTaskType.rule_delete || actTaskType == WfTaskType.rule_modify)
                    {
                        <div class="col-sm-3">
                            <div class="form-group row">
                                <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("gateway"))*:</label>
                                <div class="col-sm-8">
                                    @if (CanEditReqTaskField(WorkflowEditableFieldKeys.Gateway))
                                    {
                                        <Dropdown ElementType="Device" @bind-SelectedElement="actRuleDevice" ElementToString="@(d => d.Name ?? string.Empty)" Elements="WfHandler.Devices" Nullable="true">
                                            <ElementTemplate Context="device">
                                                @device.Name
                                            </ElementTemplate>
                                        </Dropdown>
                                    }
                                    else
                                    {
                                        <label class="col-sm-12 h-100 border bg-secondary">@actRuleDevice?.Name</label>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    else if(actTaskType == WfTaskType.new_interface)
                    {
                        @if (CanEditReqTaskField(WorkflowEditableFieldKeys.Owner) || CanEditReqTaskField(WorkflowEditableFieldKeys.RequestingOwner))
                        {
                            <div class="col-sm-8">
                                <div class="form-group row">
                                    @if (CanEditReqTaskField(WorkflowEditableFieldKeys.Owner))
                                    {
                                        <label class="col-sm-3 col-form-label col-form-label-sm">@(userConfig.GetText("owner"))*:</label>
                                        <div class="col-sm-9">
                                            <Dropdown ElementType="FwoOwner" @bind-SelectedElement="actOwner"
                                                ElementToString="@(a => a.Display(userConfig.GetText("common_service")))" Elements="NewInterfaceOwnerOptions" Nullable="true">
                                                <ElementTemplate Context="app">
                                                    @app.Display(userConfig.GetText("common_service"))
                                                </ElementTemplate>
                                            </Dropdown>
                                        </div>
                                    }
                                    @if (CanEditReqTaskField(WorkflowEditableFieldKeys.RequestingOwner))
                                    {
                                        <label class="col-sm-3 col-form-label col-form-label-sm">@(userConfig.GetText("requesting_owner")):</label>
                                        <div class="col-sm-9">
                                            <Dropdown ElementType="FwoOwner" @bind-SelectedElement="actRequestingOwner"
                                                ElementToString="@(a => a.Display(userConfig.GetText("common_service")))" Elements="RequestingOwnerOptions" Nullable="true">
                                                <ElementTemplate Context="app">
                                                    @app.Display(userConfig.GetText("common_service"))
                                                </ElementTemplate>
                                            </Dropdown>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            @if(WfHandler.ActReqTask.GetAddInfoValue(AdditionalInfoKeys.ReqOwner) == "")
                            {
                                <div class="col-sm-7">
                                    <div class="form-group row">
                                        <label class="col-sm-3 col-form-label col-form-label-sm">@(userConfig.GetText("owner"))*:</label>
                                        <label class="col-sm-9 border bg-secondary">@actOwner?.Display()</label>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("owner"))*:</label>
                                        <label class="col-sm-8 border bg-secondary">@actOwner?.Display()</label>
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group row">
                                        <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("requesting_owner")):</label>
                                        <label class="col-sm-8 border bg-secondary">@WfHandler.GetRequestingOwner()</label>
                                    </div>
                                </div>
                            }
                        }
                    }
                    else if(actTaskType == WfTaskType.group_create)
                    {
                        <div class="col-sm-6">
                            <div class="form-group row">
                                <label class="col-sm-1 col-form-label col-form-label-sm">@(userConfig.GetText("name"))*:</label>
                                <div class="col-sm-11">
                                    <input type="text" class="form-control form-control-sm" readonly="@(!CanEditReqTaskField(WorkflowEditableFieldKeys.Name))" @bind="actGrpName" />
                                </div>
                            </div>
                        </div>
                    }
                </div>
                @if(actTaskType == WfTaskType.generic)
                {
                    <div class="form-group row mt-2">
                        <label class="col-sm-1 col-form-label col-form-label-sm">@(userConfig.GetText("free_text")):</label>
                        <div class="col-sm-11">
                            <textarea rows="2" type="text" class="form-control form-control-sm" readonly="@(!CanEditReqTaskField(WorkflowEditableFieldKeys.FreeText))" @bind="WfHandler.ActReqTask.FreeText"/>   
                        </div>
                    </div>
                }
                else if(actTaskType == WfTaskType.access)
                {
                    <div class="form-group row mt-2">
                        <div class="col-sm-3">
                            <div class="form-group row">
                                <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("rule_action"))*:</label>
                                <div class="col-sm-8">
                                    @if (CanEditReqTaskField(WorkflowEditableFieldKeys.RuleAction))
                                    {
                                        <Dropdown ElementType="RuleAction" @bind-SelectedElement="actRuleAction" ElementToString="@(a => a.Name)" Elements="ruleActions" Nullable="true">
                                            <ElementTemplate Context="action">
                                                @action.Name
                                            </ElementTemplate>
                                        </Dropdown>
                                    }
                                    else
                                    {
                                        <label class="col-sm-12 h-100 border bg-secondary">@actRuleAction?.Name</label>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="form-group row">
                                <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("track"))*:</label>
                                <div class="col-sm-8">
                                    @if (CanEditReqTaskField(WorkflowEditableFieldKeys.Track))
                                    {
                                        <Dropdown ElementType="Tracking" @bind-SelectedElement="actTracking" ElementToString="@(t => t.Name)" Elements="trackings" Nullable="true">
                                            <ElementTemplate Context="track">
                                                @track.Name
                                            </ElementTemplate>
                                        </Dropdown>
                                    }
                                    else
                                    {
                                        <label class="col-sm-12 h-100 border bg-secondary">@actTracking?.Name</label>
                                    }
                                </div>
                            </div>
                        </div>
                        <DisplayTaskTargetDates @bind-TargetBeginDate="WfHandler.ActReqTask.TargetBeginDate"
                            @bind-TargetEndDate="WfHandler.ActReqTask.TargetEndDate"
                            CanEditTargetBeginDate="CanEditReqTaskField(WorkflowEditableFieldKeys.ValidFrom)"
                            CanEditTargetEndDate="CanEditReqTaskField(WorkflowEditableFieldKeys.ValidTo)"
                            TargetDatesValidChanged="SetTargetDatesValid" />
                    </div>
                }
                <div class="form-group row mt-2">
                    <label class="col-sm-1 col-form-label col-form-label-sm">@(userConfig.GetText("reason")):</label>
                    <div class="col-sm-11">
                        <textarea rows="2" type="text" class="form-control form-control-sm" readonly="@(!CanEditReqTaskField(WorkflowEditableFieldKeys.Reason))" @bind="WfHandler.ActReqTask.Reason"/>   
                    </div>
                </div>

                @if(actTaskType == WfTaskType.access || actTaskType == WfTaskType.rule_modify)
                {
                    <DisplayAccessElements Sources="actSources" @bind-SourcesToAdd="sourcesToAdd" @bind-SourcesToDelete="sourcesToDelete"
                    Destinations="actDestinations" @bind-DestinationsToAdd="destinationsToAdd" @bind-DestinationsToDelete="destinationsToDelete"
                    Services="actServices" @bind-ServicesToAdd="servicesToAdd" @bind-ServicesToDelete="servicesToDelete"
                    IpProtos="ipProtos" TaskId="WfHandler.ActReqTask.Id" EditMode="WfHandler.EditReqTaskMode"
                    EditSources="CanEditReqTaskField(WorkflowEditableFieldKeys.Source)"
                    EditDestinations="CanEditReqTaskField(WorkflowEditableFieldKeys.Destination)"
                    EditServices="CanEditReqTaskField(WorkflowEditableFieldKeys.Services)" />
                }
                else if(actTaskType == WfTaskType.rule_delete)
                {
                    <DisplayRules @bind-Rules="actRules" TaskId="WfHandler.ActReqTask.Id" EditMode="CanEditReqTaskField(WorkflowEditableFieldKeys.Rules)" />
                }
                else if(actTaskType == WfTaskType.group_create)
                {
                    <div class="form-group row mt-2">
                        @if (WfHandler.EditReqTaskMode)
                        {
                            <div class="col-sm-2">
                                <input class="form-check-input" type="radio" checked="@(!grpTypeSvc)" name="shortcutRange" id="nwGrp" @onchange="() => {grpTypeSvc = false;}" >
                                <label class="col-sm-1 col-form-label col-form-label-sm" for="nwGrp">@(userConfig.GetText("network_group"))</label>
                            </div>
                            <div class="col-sm-2">
                                <input class="form-check-input" type="radio" checked="@(grpTypeSvc)" name="shortcutRange" id="svcGrp" @onchange="() => {grpTypeSvc = true;}" >
                                <label class="col-sm-1 col-form-label col-form-label-sm" for="svcGrp">@(userConfig.GetText("service_group"))</label>
                            </div>
                            <div class="col-sm-4">
                                @if(!grpTypeSvc)
                                {
                                    <IpSelector IpAddresses="actSources" @bind-IpsToAdd="sourcesToAdd" @bind-IpsToDelete="sourcesToDelete" WithLabel="false"/>
                                }
                                else
                                {
                                    <ServiceSelector Services="actServices" @bind-ServicesToAdd="servicesToAdd" @bind-ServicesToDelete="servicesToDelete"
                                        IpProtos="ipProtos" TaskId="WfHandler.ActReqTask.Id" WithLabel="false"/>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="list-group col-sm-4">
                                @foreach(var source in actSources)
                                {
                                    <div class="list-group-item border bg-secondary">
                                        <label>@DisplayObjectElement(source)</label>
                                    </div>
                                }
                                @foreach(var service in actServices)
                                {
                                    <div class="list-group-item border bg-secondary">
                                        <label>@DisplayServiceElement(service)</label>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                <hr />
                @if(!WfHandler.EditReqTaskMode)
                {
                    <div class="form-group row mt-2">
                        <div class="col-sm-1">
                            <label class="col-form-label col-form-label-sm">@(userConfig.GetText("comments")):</label>
                            @if(WfHandler.PlanReqTaskMode || WfHandler.ApproveReqTaskMode)
                            {
                                <button type="button" class="btn btn-sm btn-success" @onclick:preventDefault @onclick="InitAddComment">
                                    @(DisplayService.DisplayButton(userConfig, "add_comment", Icons.Add))</button>
                            }
                        </div>
                        <div class="col-sm-11">
                            <textarea rows="3" type="text" class="form-control form-control-sm" readonly="true">@allComments</textarea>
                        </div>
                    </div>
                }

                @if(Phase == WorkflowPhases.planning || WfHandler.ActReqTask.ImplementationTasks.Count > 0)
                {
                    <h5 class="mt-2">@(userConfig.GetText("implementation_tasks"))</h5>

                    <DisplayImplTaskTable Phase="Phase" States="States" WfHandler="WfHandler" ResetParent="Reset"
                        AllImplTasks="WfHandler.ActReqTask.ImplementationTasks" StartImplPhase="StartImplementationPhase"/>
                }
            </form>
        }
    </Body>
    <Footer>
        <div class="d-flex align-items-center w-100">
            <div class="d-flex flex-fill justify-content-start">
            </div>
            <div class="d-flex flex-fill justify-content-center px-4">
                <div class="btn-group">
                    @if (CanShowApprovalsButton())
                    {
                        <button type="button" class="btn btn-sm btn-primary" @onclick:preventDefault @onclick="ShowApprovals">
                            @(DisplayService.DisplayButton(userConfig, "approvals", Icons.Approval))</button>
                    }
                    @foreach(var action in offeredActions)
                    {
                        @if(CanShowConfiguredActionButton(action))
                        {
                            <button type="button" class="btn btn-sm btn-dark" @onclick:preventDefault @onclick="() => PerformAction(action)">@action.ButtonText</button>
                        }
                    }
                </div>
            </div>
            <div class="d-flex flex-fill justify-content-end">
                <div class="btn-group">
                    @if (WfHandler.EditReqTaskMode)
                    {
                        <ExecutionModeAuthorizeView Roles="@($"{Roles.Admin}, {Roles.Requester}, {Roles.FwAdmin}")">
                            <Authorized>
                                @if(WfHandler.AddReqTaskMode)
                                {
                                    <button type="button" class="btn btn-sm btn-primary" @onclick:preventDefault @onclick="SaveReqTask">@(DisplayService.DisplayButton(userConfig, "add", Icons.Add))</button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-primary" @onclick:preventDefault @onclick="SaveReqTask">@(DisplayService.DisplayButton(userConfig, "save", Icons.Save))</button>
                                }
                            </Authorized>
                            <NotAuthorized>
                                <button type="button" class="btn btn-sm btn-primary" disabled>@(DisplayService.DisplayButton(userConfig, "save", Icons.Save))</button>
                            </NotAuthorized>
                        </ExecutionModeAuthorizeView>
                    }
                    else if (WfHandler.PlanReqTaskMode)
                    {
                        <ExecutionModeAuthorizeView Roles="@($"{Roles.Admin}, {Roles.Planner}, {Roles.FwAdmin}")">
                            <Authorized>
                                <button type="button" class="btn btn-sm btn-primary" @onclick:preventDefault @onclick="InitPromoteReqTask">@(DisplayService.DisplayButton(userConfig, "change_state", Icons.ChangeState))</button>
                            </Authorized>
                            <NotAuthorized>
                                <button type="button" class="btn btn-sm btn-primary" disabled>@(DisplayService.DisplayButton(userConfig, "change_state", Icons.ChangeState))</button>
                            </NotAuthorized>
                        </ExecutionModeAuthorizeView>
                    }
                    else if (WfHandler.ApproveReqTaskMode)
                    {
                        <ExecutionModeAuthorizeView Roles="@($"{Roles.Admin}, {Roles.Approver}, {Roles.FwAdmin}")">
                            <Authorized>
                                <button type="button" class="btn btn-sm btn-primary" @onclick:preventDefault @onclick="InitApproveTask">@(DisplayService.DisplayButton(userConfig, "approve", Icons.Approve))</button>
                            </Authorized>
                            <NotAuthorized>
                                <button type="button" class="btn btn-sm btn-primary" disabled>@(DisplayService.DisplayButton(userConfig, "approve", Icons.Approve))</button>
                            </NotAuthorized>
                        </ExecutionModeAuthorizeView>
                    }
                    @if(WfHandler.EditReqTaskMode || WfHandler.PlanReqTaskMode || WfHandler.ApproveReqTaskMode)
                    {
                        <button type="button" class="btn btn-sm btn-secondary" @onclick:preventDefault @onclick="Close">@(DisplayService.DisplayButton(userConfig, "cancel", Icons.Cancel))</button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-sm btn-primary" @onclick:preventDefault @onclick="Close">@(userConfig.GetText("ok"))</button>
                    }
                </div>
            </div>
        </div>
    </Footer>
</PopUp>

<PromoteObject @bind-Promote="WfHandler.DisplayPromoteReqTaskMode" CloseParent="Close" CancelParent="Cancel" ObjectName="@WfHandler.ActReqTask.Title" Save="ConfPromoteReqTask" StatefulObject="WfHandler.ActReqTask" StateMatrix="WfHandler.ActStateMatrix" States="States"/>
<PromoteObject @bind-Promote="WfHandler.DisplayApproveMode" CloseParent="Close" CancelParent="Cancel" ObjectName="@userConfig.GetText("approval")" WithComment="true" Save="ConfApproveTask" StatefulObject="WfHandler.ActApproval" StateMatrix="WfHandler.ActStateMatrix" States="States"/>
<DisplayApprovals @bind-Display="WfHandler.DisplayApprovalReqMode" WfHandler="WfHandler" ResetParent="ResetApprovalsPopup" Approvals="WfHandler.ActReqTask.Approvals" States="States" ReadOnlyMode="IsRequestTaskReadOnly()"/>
<CommentObject @bind-Display="WfHandler.DisplayReqTaskCommentMode" ResetParent="InitComments" ObjectName="@WfHandler.ActReqTask.Title" Save="ConfAddComment"/>
<DisplayPathAnalysis @bind-Display="WfHandler.DisplayPathAnalysisMode" ReqTask="WfHandler.ActReqTask"/>
@if(WfHandler.ActionHandler != null)
{
    <EditConnPopup @bind-Display="WfHandler.ActionHandler.DisplayConnectionMode" ConnHandler="WfHandler.ActionHandler.ConnHandler"/>
}
<InProgress Display="WorkInProgress"/>


@code
{
    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;

    [Parameter]
    public WorkflowPhases Phase { get; set; } = WorkflowPhases.request;

    [Parameter]
    public WfStateDict States { get; set; } = new ();

    [Parameter]
    public WfHandler WfHandler { get; set; } = new ();

    [Parameter]
    public Func<Task> ResetParent { get; set; } = DefaultInit.DoNothing;

    [Parameter]
    public Func<WfReqTask, Task> StartPhase { get; set; } = DefaultInit.DoNothing;

    [Parameter]
    public Func<WfImplTask, Task> StartImplPhase { get; set; } = DefaultInit.DoNothing;


    private List<WfTaskType> availableTaskTypes { get; set; } = [];
    private List<RuleAction> ruleActions = [];
    private List<Tracking> trackings = [];
    private List<IpProtocol> ipProtos = [];

    private List<NwObjectElement> actSources = [];
    private List<NwObjectElement> actDestinations = [];
    private List<NwServiceElement> actServices = [];
    private List<NwRuleElement> actRules = [];

    private List<NwObjectElement> sourcesToAdd = [];
    private List<NwObjectElement> sourcesToDelete = [];
    private List<NwObjectElement> destinationsToAdd = [];
    private List<NwObjectElement> destinationsToDelete = [];
    private List<NwServiceElement> servicesToAdd = [];
    private List<NwServiceElement> servicesToDelete = [];
    private WfTaskType actTaskType = WfTaskType.access;

    private List<WfStateAction> offeredActions = [];
    private string allComments = "";
    private IEnumerable<Device> selectedDevices { get; set; } = new List<Device>();
    private List<Device> selectableDevices = [];
    private Device? actRuleDevice;
    private RuleAction? actRuleAction;
    private Tracking? actTracking;
    private FwoOwner? actOwner;
    private FwoOwner? oldOwner;
    private string? actGrpName;
    private bool grpTypeSvc = false;
    private bool firstParamSet = false;
    private bool WorkInProgress = false;
    private bool targetDatesValid = true;
    private List<Management> managements = [];
    private Management? actManagement;
    private FwoOwner? actRequestingOwner;
    private long displayedReqTaskId = -1;
    private IEnumerable<FwoOwner> NewInterfaceOwnerOptions => WfHandler.AllOwners.Where(owner => owner.Id != 0);
    private IEnumerable<FwoOwner> RequestingOwnerOptions => userConfig.CanUseAnyRole(Roles.Admin)
        ? NewInterfaceOwnerOptions
        : NewInterfaceOwnerOptions.Where(owner => userConfig.User.Ownerships.Contains(owner.Id));
  
    protected override async Task OnInitializedAsync()
    {
        try
        {
            availableTaskTypes = System.Text.Json.JsonSerializer.Deserialize<List<WfTaskType>>(userConfig.ReqAvailableTaskTypes) ?? throw new JsonException("Config data could not be parsed.");
            actTaskType = availableTaskTypes.Count > 0 ? availableTaskTypes.Last() : WfTaskType.access;
            ruleActions = await apiConnection.SendQueryAsync<List<RuleAction>>(StmQueries.getRuleActions);
            trackings = await apiConnection.SendQueryAsync<List<Tracking>>(StmQueries.getTracking);
            managements.Add(new(){ Id = -1, Name = userConfig.GetText("all"), DeviceType = new(){ Id = 0 } });
            managements.AddRange(await apiConnection.SendQueryAsync<List<Management>>(DeviceQueries.getManagementNames));
            ipProtos = DisplayBase.CustomSortProtocols(await apiConnection.SendQueryAsync<List<IpProtocol>>(StmQueries.getIpProtocols));
            selectableDevices =
            [
                new Device() { Id = WfReqTaskBase.kAllDevicesId, Name = userConfig.GetText("all"), DeviceType = new() { Id = 0 } },
                .. WfHandler.Devices
            ];
            InitElements();
            firstParamSet = true;
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("fetch_data"), "", true);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            if (WfHandler.DisplayReqTaskMode && (firstParamSet || displayedReqTaskId != WfHandler.ActReqTask.Id))
            {
                firstParamSet = false;
                displayedReqTaskId = WfHandler.ActReqTask.Id;
                InitElements();
                await InitComments();
                if(!WfHandler.AddReqTaskMode)
                {
                    Enum.TryParse<WfTaskType>(WfHandler.ActReqTask.TaskType, out actTaskType);
                    if(!availableTaskTypes.Contains(actTaskType))
                    {
                        DisplayMessageInUi(null, userConfig.GetText("display_task"), userConfig.GetText("E8014"), true);
                    }
                    if(WfHandler.ActReqTask.TaskType == WfTaskType.new_interface.ToString() && WfHandler.ActReqTask.Owners.Count > 0)
                    {
                        oldOwner = actOwner;
                    }
                    actGrpName = WfHandler.ActReqTask.GetAddInfoValue(AdditionalInfoKeys.GrpName);
                }
                await Reset();
            }
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("init_environment"), "", true);
        }
    }

    private void SetDevice(Device device)
    {
        selectedDevices = device.Id == WfReqTaskBase.kAllDevicesId ? [GetAllDevicesOption()] : new[] { device };
    }

    private void SetDevices(IEnumerable<Device> devices)
    {
        List<Device> deviceList = [.. devices];
        bool containsAll = deviceList.Any(device => device.Id == WfReqTaskBase.kAllDevicesId);
        bool containsConcreteDevice = deviceList.Any(device => device.Id != WfReqTaskBase.kAllDevicesId);
        bool previouslyHadAll = selectedDevices.Any(device => device.Id == WfReqTaskBase.kAllDevicesId);
        if (containsAll && containsConcreteDevice)
        {
            selectedDevices = previouslyHadAll
                ? deviceList.Where(device => device.Id != WfReqTaskBase.kAllDevicesId)
                : [GetAllDevicesOption()];
        }
        else if (containsAll)
        {
            selectedDevices = [GetAllDevicesOption()];
        }
        else
        {
            selectedDevices = deviceList;
        }
    }

    private void InitElements()
    {
        actSources = WfHandler.ActReqTask.GetNwObjectElements(ElemFieldType.source);
        actDestinations = WfHandler.ActReqTask.GetNwObjectElements(ElemFieldType.destination);
        actServices = WfHandler.ActReqTask.GetServiceElements();
        actRules = WfHandler.ActReqTask.GetRuleElements();
        grpTypeSvc = actServices.Count > 0;
    }

