    private void UpdateElements()
    {
        foreach(var src in sourcesToDelete)
        {
            actSources.Remove(src);
            RemoveElem(src.ElemId);
        }
        foreach(var dst in destinationsToDelete)
        {
            actDestinations.Remove(dst);
            RemoveElem(dst.ElemId);
        }
        foreach(var svc in servicesToDelete)
        {
            actServices.Remove(svc);
            RemoveElem(svc.ElemId);
        }
        if(actTaskType != WfTaskType.group_create || !grpTypeSvc)
        {
            foreach(var src in sourcesToAdd)
            {
                src.TaskId = WfHandler.ActReqTask.Id;
                actSources.Add(src);
                WfHandler.ActReqTask.Elements.Add(src.ToReqElement(ElemFieldType.source));
            }
        }
        foreach(var dst in destinationsToAdd)
        {
            dst.TaskId = WfHandler.ActReqTask.Id;
            actDestinations.Add(dst);
            WfHandler.ActReqTask.Elements.Add(dst.ToReqElement(ElemFieldType.destination));
        }
        if(actTaskType != WfTaskType.group_create || grpTypeSvc)
        {
            foreach(var svc in servicesToAdd)
            {
                svc.TaskId = WfHandler.ActReqTask.Id;
                actServices.Add(svc);
                WfHandler.ActReqTask.Elements.Add(svc.ToReqElement());
            }
        }
        sourcesToDelete = [];
        destinationsToDelete = [];
        servicesToDelete = [];
        sourcesToAdd = [];
        destinationsToAdd = [];
        servicesToAdd = [];

        WfHandler.ActReqTask.Elements.RemoveAll(x => x.Field == ElemFieldType.rule.ToString());
        foreach(var rule in actRules)
        {
            WfReqElement reqElem = rule.ToReqElement();
            reqElem.DeviceId = actRuleDevice?.Id;
            reqElem.RequestAction = WfHandler.ActReqTask.RequestAction;
            WfHandler.ActReqTask.Elements.Add(reqElem);
        }
    }

    private void RemoveElem(long elemId)
    {
        WfReqElement? oldElem = WfHandler.ActReqTask.Elements.FirstOrDefault(x => x.Id == elemId);
        if(oldElem != null)
        {
            WfHandler.ActReqTask.RemovedElements.Add(oldElem);
            WfHandler.ActReqTask.Elements.Remove(oldElem);
        }
    }

    private async Task SaveReqTask()
    {
        if (WorkInProgress)
        {
            return;
        }
        WorkInProgress = true;
        try
        {
            if (await PrepareReqTaskForSave())
            {
                if (WfHandler.AddReqTaskMode)
                {
                    await WfHandler.AddApproval();
                    WfHandler.ActReqTask.TaskNumber = WfHandler.ActTicket.HighestTaskNumber() + 1;
                    await WfHandler.AddReqTask();
                }
                else
                {
                    await WfHandler.ChangeReqTask();
                }
                await Close();
            }
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("save_task"), "", true);
        }
        finally
        {
            WorkInProgress = false;
        }
    }

    private async Task<bool> PrepareReqTaskForSave()
    {
        if (!RejectInvalidTargetDates())
        {
            return false;
        }

        WfHandler.ActReqTask.TaskType = actTaskType.ToString();
        WfHandler.ActReqTask.RuleAction = actRuleAction?.Id;
        WfHandler.ActReqTask.Tracking = actTracking?.Id;
        WfHandler.ActReqTask.ManagementId = actManagement != null && actManagement.Id >= 0 ? actManagement.Id : null;
        WfHandler.ActReqTask.RemovedOwners = new();
        WfHandler.ActReqTask.NewOwners = new();
        if(actOwner != oldOwner)
        {
            if(oldOwner != null)
            {
                WfHandler.ActReqTask.RemovedOwners.Add(oldOwner);
            }
            if(actOwner != null)
            {
                WfHandler.ActReqTask.NewOwners.Add(actOwner);
            }
        }
        if (WfHandler.ActReqTask.Sanitize())
        {
            DisplayMessageInUi(null, userConfig.GetText("save_task"), userConfig.GetText("U0001"), true);
        }
        if(actTaskType == WfTaskType.rule_delete)
        {
            WfHandler.ActReqTask.RequestAction = RequestAction.delete.ToString();
        }
        else if(actTaskType == WfTaskType.group_create)
        {
            WfHandler.ActReqTask.SetAddInfo(AdditionalInfoKeys.GrpName, actGrpName ?? "");
        }

        if (actTaskType == WfTaskType.new_interface)
        {
            WfHandler.ActReqTask.SetAddInfo(AdditionalInfoKeys.ReqOwner, actRequestingOwner?.Id.ToString() ?? "");
        }

        UpdateElements();
        if (!await CheckTaskValues())
        {
            return false;
        }

        WfHandler.ActReqTask.SetDeviceList(selectedDevices.Any(dev => dev.Id == WfReqTaskBase.kAllDevicesId)
            ? [WfReqTaskBase.kAllDevicesId]
            : [.. selectedDevices.Select(dev => dev.Id)]);
        WfHandler.ActReqTask.Owners = [];
        if (actOwner != null)
        {
            WfHandler.ActReqTask.Owners.Add(new() { Owner = actOwner });
        }
        return true;
    }

    private bool RejectInvalidTaskFormat()
    {
        if (WfHandler.ActReqTask.Title == null || WfHandler.ActReqTask.Title == "" ||
            (actTaskType == WfTaskType.new_interface && (actOwner == null || !IsRequestingOwnerAllowed())))
        {
            DisplayMessageInUi(null, userConfig.GetText("save_task"), userConfig.GetText("E5102"), true);
            return false;
        }

        return true;
    }

    private bool RejectInvalidTargetDates()
    {
        if (!targetDatesValid ||
            (WfHandler.ActReqTask.TargetBeginDate.HasValue && WfHandler.ActReqTask.TargetEndDate.HasValue &&
                WfHandler.ActReqTask.TargetBeginDate.Value > WfHandler.ActReqTask.TargetEndDate.Value))
        {
            DisplayMessageInUi(null, userConfig.GetText("save_task"), userConfig.GetText("E5119"), true);
            return false;
        }

        return true;
    }

    private bool IsRequestingOwnerAllowed()
    {
        return actRequestingOwner == null || RequestingOwnerOptions.Any(owner => owner.Id == actRequestingOwner.Id);
    }

    private bool RejectInvalidAccessTask()
    {
        if (actSources.Count == 0 || actDestinations.Count == 0 || actServices.Count == 0 ||
            (NeedsManualDeviceSelection() && selectedDevices.Count<Device>() == 0))
        {
            DisplayMessageInUi(null, userConfig.GetText("save_task"), userConfig.GetText("E5102"), true);
            return false;
        }
        foreach (var reqElem in WfHandler.ActReqTask.Elements)
        {
            if (!HasObjectReference(reqElem) && IsInvalidServicePort(reqElem))
            {
                DisplayMessageInUi(null, userConfig.GetText("save_element"), userConfig.GetText("E5103"), true);
                return false;
            }
        }
        return true;
    }

    private static bool HasObjectReference(WfReqElement element)
    {
        return HasId(element.NetworkId)
            || HasId(element.ServiceId)
            || HasId(element.FlowNetworkObjectId)
            || HasId(element.FlowNetworkGroupId)
            || HasId(element.FlowServiceObjectId)
            || HasId(element.FlowServiceGroupId);
    }

    private static bool HasId(long? id)
    {
        return id.HasValue && id.Value != 0;
    }

    private static bool IsInvalidServicePort(WfReqElement element)
    {
        return element.Field == ElemFieldType.service.ToString()
            && (element.Port < 1 || element.Port > GlobalConst.kMaxPortNumber);
    }

    private async Task<bool> RejectInvalidRuleDeleteTask()
    {
        if (actRuleDevice == null || actRules.Count == 0)
        {
            DisplayMessageInUi(null, userConfig.GetText("save_task"), userConfig.GetText("E5102"), true);
            return false;
        }
        foreach(var elem in WfHandler.ActReqTask.Elements.Where(x => x.Field == ElemFieldType.rule.ToString()))
        {
            if(!(await WfHandler.CheckRuleUid(actRuleDevice?.Id, elem.RuleUid)))
            {
                DisplayMessageInUi(null, userConfig.GetText("save_task"), userConfig.GetText("E8013") + elem.RuleUid, true);
                return false;
            }
        }
        return true;
    }

    private bool RejectInvalidGroupCreateTask()
    {
        if (string.IsNullOrEmpty(actGrpName) || (actSources.Count == 0 && actServices.Count == 0))
        {
            DisplayMessageInUi(null, userConfig.GetText("save_task"), userConfig.GetText("E5102"), true);
            return false;
        }

        return true;
    }
    
    private async Task<bool> CheckTaskValues()
    {
        if (!RejectInvalidTaskFormat())
        {
            return false;
        }
        switch (actTaskType)
        {
            case WfTaskType.access when !RejectInvalidAccessTask():
            case WfTaskType.rule_delete when !(await RejectInvalidRuleDeleteTask()):
            case WfTaskType.group_create when !RejectInvalidGroupCreateTask():
                return false;
            default:
                return true;
        }
    }

