    private string DisplayDevices()
    {
        if (selectedDevices.Any(dev => dev.Id == WfReqTaskBase.kAllDevicesId))
        {
            return userConfig.GetText("all");
        }
        List<string> devNames = new();
        foreach(var dev in selectedDevices)
        {
            devNames.Add(dev?.Name ?? "");
        }
        return string.Join(", ", devNames);
    }

    private Device GetAllDevicesOption()
    {
        return selectableDevices.FirstOrDefault(dev => dev.Id == WfReqTaskBase.kAllDevicesId)
            ?? new Device()
            {
                Id = WfReqTaskBase.kAllDevicesId,
                Name = userConfig.GetText("all"),
                DeviceType = new() { Id = 0 }
            };
    }

    private string DisplayObjectElement(NwObjectElement element)
    {
        if (!string.IsNullOrEmpty(element.GroupName))
        {
            return element.GroupName;
        }
        if (!string.IsNullOrEmpty(element.Name) && string.IsNullOrEmpty(element.IpString))
        {
            return element.Name;
        }
        return NwObjDisplay.DisplayIp(element.IpString, element.IpEndString);
    }

    private string DisplayServiceElement(NwServiceElement element)
    {
        if (!string.IsNullOrEmpty(element.GroupName))
        {
            return element.GroupName;
        }
        if (!string.IsNullOrEmpty(element.Name) && element.Port == 0)
        {
            return element.Name;
        }
        return DisplayBase.DisplayService(element, ipProtos);
    }

    private bool NeedsManualDeviceSelection()
    {
        bool planningPhaseActive = WfHandler.ActStateMatrix.PhaseActive.TryGetValue(WorkflowPhases.planning, out bool isActive) && isActive;
        return !planningPhaseActive
            && (userConfig.ReqAutoCreateImplTasks == AutoCreateImplTaskOptions.enterInReqTask
                || userConfig.ReqAutoCreateImplTasks == AutoCreateImplTaskOptions.oneTaskForAllDevices);
    }

    private async Task PerformAction(WfStateAction action)
    {
        if (WorkInProgress)
        {
            return;
        }
        WorkInProgress = true;
        try
        {
            if(WfHandler.ActionHandler != null)
            {
                await WfHandler.ActionHandler.PerformAction(action, WfHandler.ActReqTask, WfObjectScopes.RequestTask, actOwner, WfHandler.ActReqTask.TicketId);
            }
            if(action.ActionType == nameof(StateActionTypes.AddApproval) && await WfHandler.ReloadActReqTask())
            {
                InitElements();
                await InitComments();
            }
            await Reset();
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("action"), "", true);
        }
        finally
        {
            WorkInProgress = false;
            await InvokeAsync(StateHasChanged);
        }
    }

