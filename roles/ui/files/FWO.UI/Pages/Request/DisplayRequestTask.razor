    }

    private async Task Reset()
    {
        Log.WriteDebug("DisplayRequestTask", "Reset");
        if(WfHandler.ActionHandler != null)
        {
            offeredActions = WfHandler.ActionHandler.GetOfferedActions(WfHandler.ActReqTask, WfObjectScopes.RequestTask, WfHandler.Phase);
        }
        List<int> selectedDeviceIds = WfHandler.ActReqTask.GetDeviceList().ToList();
        if ((selectedDeviceIds.Count == 0 && NeedsManualDeviceSelection())
            || WfHandler.ActReqTask.HasAllDevicesSelected()
            || (selectedDeviceIds.Count > 0 && selectedDeviceIds.Count == WfHandler.Devices.Count
             && !WfHandler.Devices.Select(x => x.Id).Except(selectedDeviceIds).Any())
           )
        {
            selectedDevices = [GetAllDevicesOption()];
        }
        else
        {
            selectedDevices = new List<Device>();
            foreach(int devId in selectedDeviceIds)
            {
                Device? dev = WfHandler.Devices.FirstOrDefault(x => x.Id == devId);
                if(dev != null)
                {
                    selectedDevices = selectedDevices.Append(dev);
                }
            }
        }
        actRuleDevice = WfHandler.Devices.FirstOrDefault(x => x.Id == WfHandler.ActReqTask.GetRuleDeviceId());
        actRuleAction = ruleActions.FirstOrDefault(x => x.Id == WfHandler.ActReqTask.RuleAction);
        actTracking = trackings.FirstOrDefault(x => x.Id == WfHandler.ActReqTask.Tracking);
        actManagement = WfHandler.ActReqTask.ManagementId != null ? managements.FirstOrDefault(x => x.Id == WfHandler.ActReqTask.ManagementId) : managements.FirstOrDefault();
        actOwner = WfHandler.ActReqTask.Owners.FirstOrDefault()?.Owner;
        actRequestingOwner = RequestingOwnerOptions.FirstOrDefault(x => x.Id == WfHandler.ActReqTask.GetAddInfoIntValue(AdditionalInfoKeys.ReqOwner));
        await InvokeAsync(StateHasChanged);
    }

