@using FWO.Ui.Services
@using System.Globalization
@using FWO.Data.Flow
@using FWO.Data.Workflow

@inject ApiConnection apiConnection
@inject UserConfig userConfig

@if (!HideFlowTimeObjectSelection && ShowFlowTimeObjectSelection)
{
    <div class="col-sm-3">
        <div class="form-group row">
            <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("time_object")):</label>
            <div class="col-sm-8">
                <Dropdown ElementType="FlowTimeObject" @bind-SelectedElement="selectedFlowTimeObject" ElementToString="DisplayFlowTimeObject" Elements="FlowTimeObjects" Nullable="true">
                    <ElementTemplate Context="timeObject">
                        @DisplayFlowTimeObject(timeObject)
                    </ElementTemplate>
                </Dropdown>
            </div>
        </div>
    </div>
}
@if (!ShowOnlyFlowTimeObjectSelection)
{
    <div class="col-sm-3">
        <div class="form-group row">
            <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("valid_from")):</label>
            <div class="col-sm-8">
                @if (CanEditTargetBeginDate && ShowManualTimeObjectSelection)
                {
                    <div class="d-flex gap-1">
                        <input type="date" class="form-control form-control-sm" value="@targetBeginDateInput" @oninput="SetTargetBeginDate" />
                        @if (ShowHourInput)
                        {
                            <input type="number" min="0" max="23" class="form-control form-control-sm" value="@targetBeginHourInput" @oninput="SetTargetBeginHour" />
                        }
                        else if (ShowTimeInput)
                        {
                            <input type="time" step="@TimeInputStep" class="form-control form-control-sm" value="@targetBeginTimeInput" @oninput="SetTargetBeginTime" />
                        }
                    </div>
                }
                else
                {
                    <label class="col-sm-12 h-100 border bg-secondary">@FormatDateTimeDisplay(TargetBeginDate)</label>
                }
            </div>
        </div>
    </div>
    <div class="col-sm-3">
        <div class="form-group row">
            <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("valid_to")):</label>
            <div class="col-sm-8">
                @if (CanEditTargetEndDate && ShowManualTimeObjectSelection)
                {
                    <div class="d-flex gap-1">
                        <input type="date" class="form-control form-control-sm" value="@targetEndDateInput" @oninput="SetTargetEndDate" />
                        @if (ShowHourInput)
                        {
                            <input type="number" min="0" max="23" class="form-control form-control-sm" value="@targetEndHourInput" @oninput="SetTargetEndHour" />
                        }
                        else if (ShowTimeInput)
                        {
                            <input type="time" step="@TimeInputStep" class="form-control form-control-sm" value="@targetEndTimeInput" @oninput="SetTargetEndTime" />
                        }
                    </div>
                }
                else
                {
                    <label class="col-sm-12 h-100 border bg-secondary">@FormatDateTimeDisplay(TargetEndDate)</label>
                }
            </div>
        </div>
    </div>
}

@code
{
    [Parameter]
    public DateTime? TargetBeginDate { get; set; }

    [Parameter]
    public EventCallback<DateTime?> TargetBeginDateChanged { get; set; }

    [Parameter]
    public DateTime? TargetEndDate { get; set; }

    [Parameter]
    public EventCallback<DateTime?> TargetEndDateChanged { get; set; }

    [Parameter]
    public bool CanEditTargetBeginDate { get; set; }

    [Parameter]
    public bool CanEditTargetEndDate { get; set; }

    [Parameter]
    public EventCallback<bool> TargetDatesValidChanged { get; set; }

    [Parameter]
    public FlowIntegrationConfig? FlowIntegration { get; set; }

    [Parameter]
    public bool ShowOnlyFlowTimeObjectSelection { get; set; } = false;

    [Parameter]
    public bool HideFlowTimeObjectSelection { get; set; } = false;

    private const string kDateInputFormat = "yyyy-MM-dd";
    private const string kTimeInputFormat = "HH:mm:ss";
    private const string kDefaultBeginTime = "00:00:00";
    private const string kDefaultEndTime = "23:59:59";
    private const string kDefaultHourEndTime = "00:00:00";

    private string targetBeginDateInput = "";
    private string targetBeginTimeInput = "";
    private string targetBeginHourInput = "";
    private string targetEndDateInput = "";
    private string targetEndTimeInput = "";
    private string targetEndHourInput = "";
    private DateTime? displayedTargetBeginDate;
    private DateTime? displayedTargetEndDate;
    private bool targetBeginDateInitialized = false;
    private bool targetEndDateInitialized = false;
    private bool targetBeginDateValid = true;
    private bool targetEndDateValid = true;
    private List<FlowTimeObject> FlowTimeObjects { get; set; } = [];
    private FlowTimeObject? selectedFlowTimeObjectInt;
    private FlowIntegrationConfig ActiveFlowIntegration => FlowIntegration ?? FlowIntegrationConfig.Parse(userConfig.ReqFlowIntegration);
    private bool AnyDateEditMode => CanEditTargetBeginDate || CanEditTargetEndDate;
    private bool ShowFlowTimeObjectSelection => AnyDateEditMode && userConfig.ReqUseFlowDb && ShowsFlowDbSelection(ActiveFlowIntegration.SelectTimeObjects);
    private bool ShowManualTimeObjectSelection => !userConfig.ReqUseFlowDb || ShowsManualSelection(ActiveFlowIntegration.SelectTimeObjects);
    private bool ShowHourInput => ActiveFlowIntegration.TimeObjectPrecision == FlowIntegrationTimePrecisionOptions.Hours;
    private bool ShowTimeInput => ActiveFlowIntegration.TimeObjectPrecision != FlowIntegrationTimePrecisionOptions.Date;
    private int TimeInputStep => ActiveFlowIntegration.TimeObjectPrecision switch
    {
        FlowIntegrationTimePrecisionOptions.Hours => 3600,
        FlowIntegrationTimePrecisionOptions.Minutes => 60,
        _ => 1
    };

    private FlowTimeObject? selectedFlowTimeObject
    {
        get => selectedFlowTimeObjectInt;
        set
        {
            selectedFlowTimeObjectInt = value;
            if (value != null)
            {
                _ = SelectFlowTimeObject(value);
            }
        }
    }

    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (!HideFlowTimeObjectSelection && ShowFlowTimeObjectSelection)
            {
                List<FlowTimeObject> catalog = await apiConnection.SendQueryAsync<List<FlowTimeObject>>(FlowQueries.getFlowTimeObjectCatalog) ?? [];
                FlowTimeObjects = [.. catalog.Where(IsSelectable)];
            }
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("fetch_data"), "", true);
        }
    }

    protected override void OnParametersSet()
    {
        try
        {
            if (!targetBeginDateInitialized || TargetBeginDate != displayedTargetBeginDate)
            {
                targetBeginDateInput = FormatDateInput(TargetBeginDate);
                targetBeginTimeInput = FormatTimeInput(TargetBeginDate, ActiveFlowIntegration.TimeObjectPrecision);
                targetBeginHourInput = FormatHourInput(TargetBeginDate);
                displayedTargetBeginDate = TargetBeginDate;
                targetBeginDateInitialized = true;
                targetBeginDateValid = true;
            }
            if (!targetEndDateInitialized || TargetEndDate != displayedTargetEndDate)
            {
                targetEndDateInput = FormatDateInput(TargetEndDate);
                targetEndTimeInput = FormatTimeInput(TargetEndDate, ActiveFlowIntegration.TimeObjectPrecision);
                targetEndHourInput = FormatHourInput(TargetEndDate);
                displayedTargetEndDate = TargetEndDate;
                targetEndDateInitialized = true;
                targetEndDateValid = true;
            }
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("init_environment"), "", true);
            targetBeginDateInput = SafeDateInput(TargetBeginDate);
            targetBeginTimeInput = SafeTimeInput(TargetBeginDate);
            targetBeginHourInput = SafeHourInput(TargetBeginDate);
            targetEndDateInput = SafeDateInput(TargetEndDate);
            targetEndTimeInput = SafeTimeInput(TargetEndDate);
            targetEndHourInput = SafeHourInput(TargetEndDate);
            targetBeginDateInitialized = true;
            targetEndDateInitialized = true;
        }
    }

    private async Task SetTargetBeginDate(ChangeEventArgs args)
    {
        targetBeginDateInput = args.Value?.ToString() ?? "";
        if (!string.IsNullOrWhiteSpace(targetBeginDateInput) && string.IsNullOrWhiteSpace(targetBeginTimeInput))
        {
            targetBeginTimeInput = kDefaultBeginTime;
            targetBeginHourInput = "0";
        }
        await UpdateTargetBeginDate();
    }

    private async Task SetTargetBeginTime(ChangeEventArgs args)
    {
        targetBeginTimeInput = args.Value?.ToString() ?? "";
        await UpdateTargetBeginDate();
    }

    private async Task SetTargetBeginHour(ChangeEventArgs args)
    {
        targetBeginHourInput = args.Value?.ToString() ?? "";
        targetBeginTimeInput = BuildHourTimeInput(targetBeginHourInput);
        await UpdateTargetBeginDate();
    }

    private async Task SetTargetEndDate(ChangeEventArgs args)
    {
        targetEndDateInput = args.Value?.ToString() ?? "";
        if (!string.IsNullOrWhiteSpace(targetEndDateInput) && string.IsNullOrWhiteSpace(targetEndTimeInput))
        {
            targetEndTimeInput = GetDefaultEndTime();
            targetEndHourInput = "0";
        }
        await UpdateTargetEndDate();
    }

    private async Task SetTargetEndTime(ChangeEventArgs args)
    {
        targetEndTimeInput = args.Value?.ToString() ?? "";
        await UpdateTargetEndDate();
    }

    private async Task SetTargetEndHour(ChangeEventArgs args)
    {
        targetEndHourInput = args.Value?.ToString() ?? "";
        targetEndTimeInput = BuildHourTimeInput(targetEndHourInput);
        await UpdateTargetEndDate();
    }

    private async Task UpdateTargetBeginDate()
    {
        if (!ShowTimeInput && !string.IsNullOrWhiteSpace(targetBeginDateInput))
        {
            targetBeginTimeInput = kDefaultBeginTime;
        }
        targetBeginDateValid = TryParseDateTimeInput(targetBeginDateInput, targetBeginTimeInput, out DateTime? targetBeginDate);
        if (targetBeginDateValid)
        {
            await TargetBeginDateChanged.InvokeAsync(targetBeginDate);
        }
        await TargetDatesValidChanged.InvokeAsync(targetBeginDateValid && targetEndDateValid);
    }

    private async Task UpdateTargetEndDate()
    {
        if (!ShowTimeInput && !string.IsNullOrWhiteSpace(targetEndDateInput))
        {
            targetEndTimeInput = GetDefaultEndTime();
        }
        targetEndDateValid = TryParseDateTimeInput(targetEndDateInput, targetEndTimeInput, out DateTime? targetEndDate);
        if (targetEndDateValid)
        {
            await TargetEndDateChanged.InvokeAsync(targetEndDate);
        }
        await TargetDatesValidChanged.InvokeAsync(targetBeginDateValid && targetEndDateValid);
    }

    private static string FormatDateInput(DateTime? dateTime)
    {
        return dateTime?.ToString(kDateInputFormat, CultureInfo.InvariantCulture) ?? "";
    }

    private static string FormatTimeInput(DateTime? dateTime, string precision)
    {
        if (!dateTime.HasValue)
        {
            return "";
        }
        return precision switch
        {
            FlowIntegrationTimePrecisionOptions.Hours => dateTime.Value.ToString("HH:00", CultureInfo.InvariantCulture),
            FlowIntegrationTimePrecisionOptions.Minutes => dateTime.Value.ToString("HH:mm", CultureInfo.InvariantCulture),
            _ => dateTime.Value.ToString(kTimeInputFormat, CultureInfo.InvariantCulture)
        };
    }

    private static string FormatHourInput(DateTime? dateTime)
    {
        return dateTime?.ToString("%H", CultureInfo.InvariantCulture) ?? "";
    }

    private static string BuildHourTimeInput(string hourInput)
    {
        return int.TryParse(hourInput, NumberStyles.Integer, CultureInfo.InvariantCulture, out int hour) && hour is >= 0 and <= 23
            ? $"{hour:00}:00:00"
            : "";
    }

    private string DisplayFlowTimeObject(FlowTimeObject timeObject)
    {
        return !string.IsNullOrWhiteSpace(timeObject.Name) ? timeObject.Name : timeObject.Id.ToString();
    }

    private string FormatDateTimeDisplay(DateTime? dateTime)
    {
        if (!dateTime.HasValue)
        {
            return "";
        }
        try
        {
            return ActiveFlowIntegration.TimeObjectPrecision switch
            {
                FlowIntegrationTimePrecisionOptions.Date => dateTime.Value.ToString(kDateInputFormat, CultureInfo.InvariantCulture),
                FlowIntegrationTimePrecisionOptions.Hours => dateTime.Value.ToString("yyyy-MM-dd H 'h'", CultureInfo.InvariantCulture),
                FlowIntegrationTimePrecisionOptions.Minutes => dateTime.Value.ToString("yyyy-MM-dd HH:mm", CultureInfo.InvariantCulture),
                _ => dateTime.Value.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture)
            };
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("display"), "", true);
            return SafeDateTimeDisplay(dateTime);
        }
    }

    private static string SafeDateInput(DateTime? dateTime)
    {
        return dateTime?.ToString(kDateInputFormat, CultureInfo.InvariantCulture) ?? "";
    }

    private static string SafeTimeInput(DateTime? dateTime)
    {
        return dateTime?.ToString(kTimeInputFormat, CultureInfo.InvariantCulture) ?? "";
    }

    private static string SafeHourInput(DateTime? dateTime)
    {
        return dateTime?.Hour.ToString(CultureInfo.InvariantCulture) ?? "";
    }

    private static string SafeDateTimeDisplay(DateTime? dateTime)
    {
        return dateTime?.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture) ?? "";
    }

    private async Task SelectFlowTimeObject(FlowTimeObject timeObject)
    {
        targetBeginDateValid = true;
        targetEndDateValid = true;
        await TargetBeginDateChanged.InvokeAsync(timeObject.StartTime);
        await TargetEndDateChanged.InvokeAsync(timeObject.EndTime);
        await TargetDatesValidChanged.InvokeAsync(true);
    }

    private string GetDefaultEndTime()
    {
        return ActiveFlowIntegration.TimeObjectPrecision == FlowIntegrationTimePrecisionOptions.Hours
            ? kDefaultHourEndTime
            : kDefaultEndTime;
    }

    private static bool TryParseDateTimeInput(string dateValue, string timeValue, out DateTime? dateTime)
    {
        dateTime = null;
        if (string.IsNullOrWhiteSpace(dateValue) && string.IsNullOrWhiteSpace(timeValue))
        {
            return true;
        }
        if (string.IsNullOrWhiteSpace(dateValue) || string.IsNullOrWhiteSpace(timeValue))
        {
            return false;
        }
        if (!DateTime.TryParseExact(dateValue, kDateInputFormat, CultureInfo.InvariantCulture, DateTimeStyles.None, out DateTime parsedDate))
        {
            return false;
        }
        if (!DateTime.TryParseExact(timeValue, [kTimeInputFormat, "HH:mm"], CultureInfo.InvariantCulture, DateTimeStyles.None, out DateTime parsedTime))
        {
            return false;
        }

        dateTime = parsedDate.Date.Add(parsedTime.TimeOfDay);
        return true;
    }

    private static bool IsSelectable(FlowTimeObject timeObject)
    {
        return timeObject.ShowInRequestModule && timeObject.RemovedDate == null;
    }

    private static bool ShowsFlowDbSelection(string selection)
    {
        return selection is FlowIntegrationObjectSelectionOptions.FromFlowDb or FlowIntegrationObjectSelectionOptions.Both;
    }

    private static bool ShowsManualSelection(string selection)
    {
        return selection is FlowIntegrationObjectSelectionOptions.Manually or FlowIntegrationObjectSelectionOptions.Both;
    }
}
