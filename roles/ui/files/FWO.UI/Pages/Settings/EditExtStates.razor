@inject UserConfig userConfig
@inject ApiConnection apiConnection

<PopUp Title="@(userConfig.GetText("ext_states"))" Show="@Display" Size=PopupSize.Large OnClose="Close">
    <Body>
        @if (Display)
        {
            <div class="m-2 vheight75">
                <div class="mb-4">
                    <h5 class="mb-3">@(userConfig.GetText("static_external_states"))</h5>
                    <table class="table table-bordered table-sm th-bg-secondary table-responsive overflow-auto sticky-header">
                        <thead>
                            <tr>
                                <th>@(userConfig.GetText("actions"))</th>
                                <th>@(userConfig.GetText("external_state_name"))</th>
                                <th>@(userConfig.GetText("assigned_internal_states"))</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (ExtStateGroup group in staticExternalStates)
                            {
                                <tr>
                                    <td>
                                        <div class="btn-group">
                                            <button type="button" class="btn btn-sm btn-warning" @onclick="() => EditExtStateGroup(group)">
                                                @(DisplayService.DisplayButton(userConfig, "edit", Icons.Edit))
                                            </button>
                                        </div>
                                    </td>
                                    <td>@group.Name</td>
                                    <td>@DisplaySelectedStateNames(group)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">@(userConfig.GetText("manual_external_states"))</h5>
                        <button type="button" class="btn btn-sm btn-success" @onclick="AddManualExtState">
                            @(DisplayService.DisplayButton(userConfig, "add", Icons.Add))
                        </button>
                    </div>
                    <table class="table table-bordered table-sm th-bg-secondary table-responsive overflow-auto sticky-header">
                        <thead>
                            <tr>
                                <th>@(userConfig.GetText("actions"))</th>
                                <th>@(userConfig.GetText("external_state_name"))</th>
                                <th>@(userConfig.GetText("assigned_internal_states"))</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (ExtStateGroup group in manualExternalStates)
                            {
                                <tr>
                                    <td>
                                        <div class="btn-group">
                                            <button type="button" class="btn btn-sm btn-warning" @onclick="() => EditExtStateGroup(group)">
                                                @(DisplayService.DisplayButton(userConfig, "edit", Icons.Edit))
                                            </button>
                                            <button type="button" class="btn btn-sm btn-danger" @onclick="() => DeleteManualExtState(group)">
                                                @(DisplayService.DisplayButton(userConfig, "delete", Icons.Delete))
                                            </button>
                                        </div>
                                    </td>
                                    <td>@group.Name</td>
                                    <td>@DisplaySelectedStateNames(group)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </Body>
    <Footer>
        <div class="btn-group">
            <button type="button" class="btn btn-sm btn-primary" @onclick="Close">@(DisplayService.DisplayButton(userConfig, "ok", Icons.Confirm))</button>
        </div>
    </Footer>
</PopUp>

<PopUp Title="@GetEditPopupTitle()" Show="@SelectStateMode" Size=PopupSize.Small OnClose="CloseSelect">
    <Body>
        @if (SelectStateMode)
        {
            <div class="form-group row mb-3">
                <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("external_state_name")):</label>
                <div class="col-sm-8">
                    @if (editGroup.IsStatic)
                    {
                        <label class="col-form-label col-form-label-sm">@editGroup.Name</label>
                    }
                    else
                    {
                        <input type="text" class="form-control form-control-sm" @bind="editGroup.Name" />
                    }
                </div>
            </div>
            <div class="form-group row">
                <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("assigned_internal_states")):</label>
                <div class="col-sm-8">
                    <Dropdown ElementType="WfState" Multiselect="true" SelectedElements="editGroup.SelectedStates" SelectedElementsChanged="SetSelectedStates"
                              ElementToString="@(s => s.Name)" Elements="States">
                        <ElementTemplate Context="state">
                            @state.Name
                        </ElementTemplate>
                    </Dropdown>
                </div>
            </div>
        }
    </Body>
    <Footer>
        <div class="btn-group">
            <ExecutionModeAuthorizeView Roles="@Roles.Admin">
                <Authorized>
                    <button type="button" class="btn btn-sm btn-primary" disabled="@(!CanSaveEditingGroup())" @onclick="ApplySelection">
                        @(DisplayService.DisplayButton(userConfig, "save", Icons.Save))
                    </button>
                </Authorized>
                <NotAuthorized>
                    <button type="button" class="btn btn-sm btn-primary" disabled>@(DisplayService.DisplayButton(userConfig, "save", Icons.Save))</button>
                </NotAuthorized>
            </ExecutionModeAuthorizeView>
            <button type="button" class="btn btn-sm btn-secondary" @onclick="CloseSelect">@(DisplayService.DisplayButton(userConfig, "cancel", Icons.Cancel))</button>
        </div>
    </Footer>
</PopUp>

@code
{
    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;

    [Parameter]
    public bool Display { get; set; } = false;

    [Parameter]
    public EventCallback<bool> DisplayChanged { get; set; }

    [Parameter]
    public List<WfState> States { get; set; } = [];

    private List<WfExtState> dbExtStates = [];
    private List<WfExtState> allExtStates = [];
    private List<ExtStateGroup> staticExternalStates = [];
    private List<ExtStateGroup> manualExternalStates = [];
    private ExtStateGroup editGroup = new();
    private bool SelectStateMode = false;

    protected override async Task OnInitializedAsync()
    {
        await RefreshExtStates();
    }

    private async Task RefreshExtStates()
    {
        try
        {
            dbExtStates = await apiConnection.SendQueryAsync<List<WfExtState>>(RequestQueries.getExtStates) ?? [];
            allExtStates = [..dbExtStates];
            foreach (string extState in Enum.GetNames(typeof(ExtStates)))
            {
                if (allExtStates.FirstOrDefault(x => x.Name == extState) == null)
                {
                    allExtStates.Add(new() { Name = extState });
                }
            }

            BuildStateGroups();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("fetch_data"), "", true);
        }
    }

    private void BuildStateGroups()
    {
        string[] staticStateNames = Enum.GetNames(typeof(ExtStates));
        HashSet<string> staticNames = new(staticStateNames);
        staticExternalStates = staticStateNames
            .Select(name => BuildGroup(name, true))
            .ToList();
        manualExternalStates = dbExtStates
            .Where(extState => !staticNames.Contains(extState.Name))
            .GroupBy(extState => extState.Name)
            .OrderBy(group => group.Key)
            .Select(group => BuildGroup(group.Key, false, group.ToList()))
            .ToList();
    }

    private ExtStateGroup BuildGroup(string name, bool isStatic, List<WfExtState>? source = null)
    {
        List<WfExtState> extStates = source ?? dbExtStates.Where(extState => extState.Name == name).ToList();
        List<WfState> selectedStates = extStates
            .Where(extState => extState.StateId.HasValue)
            .Select(extState => States.FirstOrDefault(state => state.Id == extState.StateId))
            .Where(state => state != null)
            .Select(state => state!)
            .GroupBy(state => state.Id)
            .Select(group => group.First())
            .OrderBy(state => state.Id)
            .ToList();

        return new ExtStateGroup
        {
            Name = name,
            OriginalName = name,
            IsStatic = isStatic,
            ExistingIds = extStates.Where(extState => extState.Id.HasValue).Select(extState => extState.Id!.Value).ToList(),
            SelectedStates = selectedStates
        };
    }

    private ExtStateGroup? FindGroup(string name)
    {
        return staticExternalStates.FirstOrDefault(group => group.Name == name)
            ?? manualExternalStates.FirstOrDefault(group => group.Name == name);
    }

    private void EditExtStateGroup(ExtStateGroup group)
    {
        editGroup = CloneGroup(group);
        SelectStateMode = true;
    }

    private void EditExtState(WfExtState extState)
    {
        ExtStateGroup group = FindGroup(extState.Name) ?? new ExtStateGroup
        {
            Name = extState.Name,
            OriginalName = extState.Name,
            IsStatic = Enum.GetNames(typeof(ExtStates)).Contains(extState.Name),
            SelectedStates = extState.StateId.HasValue
                ? States.Where(state => state.Id == extState.StateId.Value).ToList()
                : []
        };

        editGroup = CloneGroup(group);
        SelectStateMode = true;
    }

    private void AddManualExtState()
    {
        editGroup = new ExtStateGroup
        {
            Name = "",
            OriginalName = "",
            IsStatic = false,
            SelectedStates = []
        };
        SelectStateMode = true;
    }

    private async Task DeleteManualExtState(ExtStateGroup group)
    {
        try
        {
            foreach (int id in group.ExistingIds)
            {
                await apiConnection.SendQueryAsync<ReturnId>(RequestQueries.removeExtState, new { id });
            }

            await RefreshExtStates();
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("save_ext_states"), "", true);
        }
    }

    private async Task ApplySelection()
    {
        try
        {
            editGroup.SelectedStates = editGroup.SelectedStates
                .GroupBy(state => state.Id)
                .Select(group => group.First())
                .OrderBy(state => state.Id)
                .ToList();

            if (string.IsNullOrWhiteSpace(editGroup.Name))
            {
                DisplayMessageInUi(null, userConfig.GetText("save_ext_states"), userConfig.GetText("external_state_name_required"), true);
                return;
            }

            if (IsDuplicateName(editGroup.Name.Trim(), editGroup.OriginalName))
            {
                DisplayMessageInUi(null, userConfig.GetText("save_ext_states"), userConfig.GetText("duplicate_external_state_name"), true);
                return;
            }

            await PersistEditingGroup();
            CloseSelect();
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("save_ext_states"), "", true);
        }
    }

    private bool IsDuplicateName(string name, string originalName)
    {
        return staticExternalStates.Concat(manualExternalStates)
            .Any(group => !string.Equals(group.OriginalName, originalName, StringComparison.OrdinalIgnoreCase) &&
                          string.Equals(group.Name, name, StringComparison.OrdinalIgnoreCase));
    }

    private async Task PersistEditingGroup()
    {
        if (!string.IsNullOrWhiteSpace(editGroup.OriginalName))
        {
            List<int> idsToDelete = dbExtStates
                .Where(extState => extState.Name == editGroup.OriginalName && extState.Id.HasValue)
                .Select(extState => extState.Id!.Value)
                .ToList();

            foreach (int id in idsToDelete)
            {
                await apiConnection.SendQueryAsync<ReturnId>(RequestQueries.removeExtState, new { id });
            }
        }

        List<int?> selectedStateIds = editGroup.SelectedStates
            .Select(state => (int?)state.Id)
            .Distinct()
            .ToList();

        if (selectedStateIds.Count == 0)
        {
            await apiConnection.SendQueryAsync<ReturnIdWrapper>(RequestQueries.addExtState, new
            {
                name = editGroup.Name.Trim(),
                stateId = (int?)null
            });
        }
        else
        {
            foreach (int? stateId in selectedStateIds)
            {
                await apiConnection.SendQueryAsync<ReturnIdWrapper>(RequestQueries.addExtState, new
                {
                    name = editGroup.Name.Trim(),
                    stateId
                });
            }
        }

        await RefreshExtStates();
    }

    private void CloseSelect()
    {
        ResetEditorState();
        SelectStateMode = false;
    }

    private void Close()
    {
        ResetEditorState();
        SelectStateMode = false;
        Display = false;
        DisplayChanged.InvokeAsync(Display);
    }

    private static ExtStateGroup CloneGroup(ExtStateGroup group)
    {
        return new ExtStateGroup
        {
            Name = group.Name,
            OriginalName = group.OriginalName,
            IsStatic = group.IsStatic,
            ExistingIds = [..group.ExistingIds],
            SelectedStates = [..group.SelectedStates]
        };
    }

    private string GetEditPopupTitle()
    {
        return editGroup.IsStatic
            ? userConfig.GetText("edit_external_state")
            : string.IsNullOrWhiteSpace(editGroup.OriginalName)
                ? userConfig.GetText("add_external_state")
                : userConfig.GetText("edit_external_state");
    }

    private bool CanSaveEditingGroup()
    {
        return !string.IsNullOrWhiteSpace(editGroup.Name);
    }

    private string DisplaySelectedStateNames(ExtStateGroup group)
    {
        return group.SelectedStates.Any()
            ? string.Join(", ", group.SelectedStates.Select(state => state.Name))
            : "-";
    }

    private sealed class ExtStateGroup
    {
        public string Name { get; set; } = "";
        public string OriginalName { get; set; } = "";
        public bool IsStatic { get; set; }
        public List<int> ExistingIds { get; set; } = [];
        public List<WfState> SelectedStates { get; set; } = [];
    }

    private Task SetSelectedStates(IEnumerable<WfState> states)
    {
        editGroup.SelectedStates = states
            .GroupBy(state => state.Id)
            .Select(group => group.First())
            .OrderBy(state => state.Id)
            .ToList();
        return Task.CompletedTask;
    }

    private void ResetEditorState()
    {
        editGroup = new ExtStateGroup();
    }
}
