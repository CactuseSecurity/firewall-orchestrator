@using Newtonsoft.Json;
@using System.Text.Json;
@using System.Text.Json.Serialization;
@using FWO.Ui.Services;

@attribute [Authorize(Roles = $"{Roles.Admin}, {Roles.FwAdmin}, {Roles.Auditor}")]

@inject UserConfig userConfig
@inject ApiConnection apiConnection

<PopUp Title="@(userConfig.GetText("edit_fix_crit"))" Size=PopupSize.Small Show="@Display" OnClose="Cancel">
    <Body>
        @if(Display)
        {
           <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5512"))">
            <label class="col-sm-2 col-form-label col-form-label-sm">@(userConfig.GetText("name"))*:</label>
            @if(AddMode)
            {
                <input type="text" class="col-sm-9" @bind="SelectedCriterion.Name" />
            }
            else
            {
                <label class="col-sm-9 col-form-label col-form-label-sm"><b>@(SelectedCriterion.Name)</b></label>
            }
            </div>
            <div class="form-group row mt-2">
                <label class="col-sm-2 col-form-label col-form-label-sm">@(userConfig.GetText("type"))*:</label>
             @if(AddMode)
            {
               <div class="col-sm-9">
                    <Dropdown ElementType="string" @bind-SelectedElement="SelectedCriterion.CriterionType" 
                            Elements="SupportedCriterionTypes()" >
                        <ElementTemplate Context="crittype">
                            @(crittype)
                        </ElementTemplate>
                    </Dropdown>
                </div>
            }
            else
            {
                <label class="col-sm-9 col-form-label col-form-label-sm"><b>@(SelectedCriterion.CriterionType)</b></label>
            }
            </div>
 
            @if(SelectedCriterion.CriterionType == CriterionType.ForbiddenService.ToString())
            {
                <div class="form-group row me-auto mt-2">
                    <label class="col-sm-2 col-form-label col-form-label-sm">@(userConfig.GetText("content_mode")):</label>
                    <div class="col-sm-10">
                        <Dropdown ElementType="ForbiddenServiceInputMode" @bind-SelectedElement="SelectedForbiddenServiceMode"
                                  Elements="ForbiddenServiceInputModes()" Nullable="false" ElementToString="GetForbiddenServiceModeText">
                            <ElementTemplate Context="mode">
                                @GetForbiddenServiceModeText(mode)
                            </ElementTemplate>
                        </Dropdown>
                    </div>
                </div>
                <div class="form-group row me-auto mt-2">
                    <label class="col-sm-2 col-form-label col-form-label-sm">@(userConfig.GetText("elements")):</label>
                    <div class="col-sm-10">
                        <EditList ElementType="string" Elements="ActElements.ToArray()" ElementsToAdd="ForbiddenElementsToAdd"
                                ElementsToDelete="ForbiddenElementsToDelete" StdLayout="false">
                            <Display>
                                <div class="row">
                                    <div class="col-sm-12 border bg-transparent">@context</div>
                                </div>
                            </Display>
                        </EditList>
                        <div class="row col-sm-12 mt-1">
                            @if(SelectedForbiddenServiceMode == ForbiddenServiceInputMode.Uid)
                            {
                                <input type="text" class="col-sm-10" @bind="ActForbiddenElement" />
                                <button type="button" class="col-sm-2 btn btn-sm btn-primary" @onclick="AddForbiddenElement"
                                    @onclick:preventDefault>@(DisplayService.DisplayButton(userConfig, "add", Icons.Add))</button>
                            }
                            else
                            {
                                <div class="col-sm-4">
                                    <PortRangeInput @bind-Port="ActForbiddenPortStart" @bind-PortEnd="ActForbiddenPortEnd" />
                                </div>
                                <div class="col-sm-4">
                                    <input type="text" class="form-control form-control-sm" placeholder="@userConfig.GetText("protocol")" @bind="ActForbiddenProtocolText" />
                                </div>
                                <button type="button" class="col-sm-2 btn btn-sm btn-primary" @onclick="AddForbiddenElement"
                                    @onclick:preventDefault>@(DisplayService.DisplayButton(userConfig, "add", Icons.Add))</button>
                            }
                        </div>
                        <small class="form-text text-muted">@userConfig.GetText(GetForbiddenServiceHintKey())</small>
                    </div>
                </div>
            }
            else if (RequiresTextContent())
            {
                <div class="form-group row mt-2">
                    <label class="col-sm-2 col-form-label col-form-label-sm">@(userConfig.GetText("content"))*:</label>
                    <div class="col-sm-10">
                        <input type="text" class="form-control form-control-sm" @bind="ActContent" />
                        <small class="form-text text-muted">@userConfig.GetText(GetContentHintKey())</small>
                    </div>
                </div>
            }
            else if (!string.IsNullOrEmpty(SelectedCriterion.CriterionType))
            {
                <div class="form-group row mt-2">
                    <label class="col-sm-2 col-form-label col-form-label-sm">@(userConfig.GetText("content")):</label>
                    <div class="col-sm-10">
                        <label class="col-form-label col-form-label-sm">@userConfig.GetText("criterion_no_content_required")</label>
                    </div>
                </div>
            }
        }
    </Body>
    <Footer>
        <div class="btn-group">
            <AuthorizeView Roles="@($"{Roles.Admin}, {Roles.FwAdmin}")">
                <Authorized>
                    <button type="button" class="btn btn-sm btn-danger" @onclick="Save">@(userConfig.GetText("save"))</button>
                </Authorized>
                <NotAuthorized>
                    <button type="button" class="btn btn-sm btn-danger" disabled>@(userConfig.GetText("save"))</button>
                </NotAuthorized> 
            </AuthorizeView>
            <button type="button" class="btn btn-sm btn-secondary" @onclick="Cancel">@(userConfig.GetText("cancel"))</button>
        </div>
    </Footer>
</PopUp>

@code
{
    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;

    [Parameter]
    public bool Display { get; set; } = false;

    [Parameter]
    public EventCallback<bool> DisplayChanged { get; set; }

    [Parameter]
    public ComplianceCriterion SelectedCriterion { get; set; } = new();

    [Parameter]
    public EventCallback<ComplianceCriterion> SelectedCriterionChanged { get; set; }

    [Parameter]
    public bool AddMode { get; set; } = false;

    [Parameter]
    public List<ComplianceCriterion> CriteriaList { get; set; } = [];

    [Parameter]
    public EventCallback<List<ComplianceCriterion>> CriteriaListChanged { get; set; }


    private List<string> ForbiddenElementsToAdd = [];
    private List<string> ForbiddenElementsToDelete = [];
    private string ActForbiddenElement = "";
    private List<string> ActElements = [];
    private string ActContent = "";
    private string ActForbiddenProtocolText = "";
    private int? ActForbiddenPortStart;
    private int? ActForbiddenPortEnd;
    private ForbiddenServiceInputMode SelectedForbiddenServiceMode = ForbiddenServiceInputMode.Uid;

    private enum ForbiddenServiceInputMode
    {
        Uid,
        ProtocolPort
    }


    protected override void OnParametersSet()
    {
        if(Display)
        {
            ActContent = SelectedCriterion.Content ?? "";
            ActElements = [.. ActContent.Split(',').Select(s => s.Trim())
                .Where(s => !string.IsNullOrEmpty(s))];
            SelectedForbiddenServiceMode = InferForbiddenServiceInputMode(ActElements);
            ResetForbiddenServiceInput();
        }
    }

    private void AddForbiddenElement()
    {
        string? forbiddenElement = SelectedForbiddenServiceMode switch
        {
            ForbiddenServiceInputMode.Uid => GetUidForbiddenElement(),
            ForbiddenServiceInputMode.ProtocolPort => GetProtocolPortForbiddenElement(),
            _ => null
        };

        if (!string.IsNullOrEmpty(forbiddenElement))
        {
            if (!ActElements.Contains(forbiddenElement) && !ForbiddenElementsToAdd.Contains(forbiddenElement))
            {
                ForbiddenElementsToAdd.Add(forbiddenElement);
            }

            ResetForbiddenServiceInput();
        }
    }

    private void Cancel()
    {
        Close();
    }

    private async Task Save()
    {
        try
        {
            int oldCritId = SelectedCriterion.Id;
            if (!TryPrepareCriterionContent())
            {
                return;
            }

            await PersistCriterionAsync(oldCritId);
            Close();
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("edit_fix_crit"), "", true);
        }
    }

    private bool TryPrepareCriterionContent()
    {
        if (SelectedCriterion.CriterionType == nameof(CriterionType.ForbiddenService))
        {
            PrepareForbiddenServiceContent();
            return true;
        }

        if (RequiresTextContent())
        {
            if (!TryValidateTextContent(out string content))
            {
                return false;
            }

            SelectedCriterion.Content = content;
            return true;
        }

        SelectedCriterion.Content = SupportedCriterionTypes().Contains(SelectedCriterion.CriterionType)
            ? ""
            : ActContent;
        return true;
    }

    private void PrepareForbiddenServiceContent()
    {
        if (!string.IsNullOrWhiteSpace(GetPendingForbiddenElement()))
        {
            AddForbiddenElement();
        }

        if (ForbiddenElementsToAdd.Count > 0 || ForbiddenElementsToDelete.Count > 0)
        {
            foreach (string elem in ForbiddenElementsToDelete)
            {
                ActElements.Remove(elem);
            }

            ActElements.AddRange(ForbiddenElementsToAdd);
        }

        SelectedCriterion.Content = string.Join(",", ActElements);
    }

    private async Task PersistCriterionAsync(int oldCritId)
    {
        if (!AddMode)
        {
            await RemoveCriterion(SelectedCriterion);
        }

        await AddCriterion();

        if (AddMode)
        {
            CriteriaList.Add(SelectedCriterion);
            return;
        }

        await UpdateUsingPolicies(oldCritId);
    }

    private async Task AddCriterion()
    {
        ReturnId[]? returnIds = (await apiConnection.SendQueryAsync<ReturnIdWrapper>(ComplianceQueries.addCriterion,
            new { name = SelectedCriterion.Name, CriterionType = SelectedCriterion.CriterionType, content = SelectedCriterion.Content })).ReturnIds;
        if(returnIds != null && returnIds.Length > 0)
        {
            SelectedCriterion.Id = returnIds[0].InsertedId;
        }
    }

    private async Task UpdateUsingPolicies(int oldCritId)
    {
        List<LinkedPolicy> linkedPolicies = await apiConnection.SendQueryAsync<List<LinkedPolicy>>(ComplianceQueries.getPolicyIdsForCrit, new{ critId = oldCritId });
        if(linkedPolicies.Count > 0)
        {
            List<CompliancePolicy> activePolicies = await apiConnection.SendQueryAsync<List<CompliancePolicy>>(ComplianceQueries.getPolicies);
    
            foreach(var linkedPolicy in linkedPolicies.Where(p => activePolicies.FirstOrDefault(x => x.Id == p.PolicyId) != null))
            {
                await apiConnection.SendQueryAsync<ReturnId>(ComplianceQueries.removeCritFromPolicy,
                    new{ policyId = linkedPolicy.PolicyId, criterionId = oldCritId, removed = DateTime.UtcNow});
                await apiConnection.SendQueryAsync<ReturnId>(ComplianceQueries.addCritToPolicy,
                    new{ policyId = linkedPolicy.PolicyId, criterionId = SelectedCriterion.Id });
            }
        }
    }

    private async Task RemoveCriterion(ComplianceCriterion criterion)
    {
        if(criterion.Removed == null)
        {
            await apiConnection.SendQueryAsync<ReturnId>(ComplianceQueries.removeCriterion,
                new { id = criterion.Id, removed = DateTime.UtcNow });
        }
    }

    private static IEnumerable<string> SupportedCriterionTypes()
    {
        return
        [
            nameof(CriterionType.Assessability),
            nameof(CriterionType.ForbiddenService),
            nameof(CriterionType.MinimumCIDRLength),
            nameof(CriterionType.ForbidZonesAsSource),
            nameof(CriterionType.ForbidZonesAsDestination),
            nameof(CriterionType.ForbidBidirectionalDuplicate)
        ];
    }

    private bool RequiresTextContent()
    {
        return SelectedCriterion.CriterionType is nameof(CriterionType.MinimumCIDRLength)
            or nameof(CriterionType.ForbidZonesAsSource)
            or nameof(CriterionType.ForbidZonesAsDestination);
    }

    private string GetContentHintKey()
    {
        return SelectedCriterion.CriterionType switch
        {
            nameof(CriterionType.MinimumCIDRLength) => "criterion_hint_minimum_cidr_length",
            nameof(CriterionType.ForbidZonesAsSource) => "criterion_hint_forbid_source_name",
            nameof(CriterionType.ForbidZonesAsDestination) => "criterion_hint_forbid_destination_name",
            _ => "criterion_no_content_required"
        };
    }

    private bool TryValidateTextContent(out string content)
    {
        content = ActContent.Trim();

        if (SelectedCriterion.CriterionType == nameof(CriterionType.MinimumCIDRLength))
        {
            if (!int.TryParse(content, out int minPrefixLength) || minPrefixLength < 0 || minPrefixLength > 32)
            {
                DisplayMessageInUi(null, userConfig.GetText("edit_fix_crit"), userConfig.GetText("criterion_error_minimum_cidr_length"), true);
                return false;
            }

            content = minPrefixLength.ToString();
        }
        else if (SelectedCriterion.CriterionType is nameof(CriterionType.ForbidZonesAsSource) or nameof(CriterionType.ForbidZonesAsDestination) && string.IsNullOrWhiteSpace(content))
        {
            DisplayMessageInUi(null, userConfig.GetText("edit_fix_crit"), userConfig.GetText("criterion_error_non_empty_content"), true); 
            return false;
        }

        return true;
    }

    private void Close()
    {
        ForbiddenElementsToAdd = [];
        ForbiddenElementsToDelete = [];
        ActContent = "";
        ResetForbiddenServiceInput();
        Display = false;
        DisplayChanged.InvokeAsync(Display);
    }

    private static IEnumerable<ForbiddenServiceInputMode> ForbiddenServiceInputModes()
    {
        return
        [
            ForbiddenServiceInputMode.Uid,
            ForbiddenServiceInputMode.ProtocolPort
        ];
    }

    private string GetForbiddenServiceModeText(ForbiddenServiceInputMode mode)
    {
        return mode switch
        {
            ForbiddenServiceInputMode.Uid => userConfig.GetText("uid"),
            ForbiddenServiceInputMode.ProtocolPort => userConfig.GetText("port_protocol"),
            _ => ""
        };
    }

    private string GetForbiddenServiceHintKey()
    {
        return SelectedForbiddenServiceMode switch
        {
            ForbiddenServiceInputMode.Uid => "criterion_hint_forbidden_service_uid",
            ForbiddenServiceInputMode.ProtocolPort => "criterion_hint_forbidden_service_protocol_port",
            _ => "criterion_no_content_required"
        };
    }

    private static ForbiddenServiceInputMode InferForbiddenServiceInputMode(IEnumerable<string> forbiddenElements)
    {
        List<string> elements = [.. forbiddenElements];
        return elements.Count > 0 && elements.All(IsProtocolPortForbiddenElement)
            ? ForbiddenServiceInputMode.ProtocolPort
            : ForbiddenServiceInputMode.Uid;
    }

    private string? GetUidForbiddenElement()
    {
        string forbiddenElement = ActForbiddenElement.Trim();
        if (string.IsNullOrEmpty(forbiddenElement))
        {
            return null;
        }

        return forbiddenElement;
    }

    private string? GetProtocolPortForbiddenElement()
    {
        string protocolToken = GetForbiddenProtocolToken();
        if (string.IsNullOrWhiteSpace(protocolToken) || ActForbiddenPortStart == null)
        {
            DisplayMessageInUi(null, userConfig.GetText("edit_fix_crit"), userConfig.GetText("criterion_error_forbidden_service_protocol_port"), true);
            return null;
        }

        int rangeEnd = ActForbiddenPortEnd ?? ActForbiddenPortStart.Value;
        if (ActForbiddenPortStart > rangeEnd)
        {
            DisplayMessageInUi(null, userConfig.GetText("edit_fix_crit"), userConfig.GetText("criterion_error_forbidden_service_protocol_port"), true);
            return null;
        }

        return ActForbiddenPortStart == rangeEnd
            ? $"{ActForbiddenPortStart}/{protocolToken}"
            : $"{ActForbiddenPortStart}-{rangeEnd}/{protocolToken}";
    }

    private string? GetPendingForbiddenElement()
    {
        return SelectedForbiddenServiceMode switch
        {
            ForbiddenServiceInputMode.Uid => string.IsNullOrWhiteSpace(ActForbiddenElement) ? null : ActForbiddenElement.Trim(),
            ForbiddenServiceInputMode.ProtocolPort => ActForbiddenPortStart == null ? null : GetProtocolPortForbiddenElement(),
            _ => null
        };
    }

    private static bool IsProtocolPortForbiddenElement(string forbiddenElement)
    {
        string[] contentParts = forbiddenElement.Split('/', StringSplitOptions.TrimEntries);
        if (contentParts.Length != 2 || string.IsNullOrWhiteSpace(contentParts[1]))
        {
            return false;
        }

        string[] portParts = contentParts[0].Split('-', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
        return portParts.Length switch
        {
            1 => int.TryParse(portParts[0], out int port) && port is > 0 and <= GlobalConst.kMaxPortNumber,
            2 => int.TryParse(portParts[0], out int startPort)
                && int.TryParse(portParts[1], out int endPort)
                && startPort is > 0 and <= GlobalConst.kMaxPortNumber
                && endPort is > 0 and <= GlobalConst.kMaxPortNumber
                && startPort <= endPort,
            _ => false
        };
    }

    private void ResetForbiddenServiceInput()
    {
        ActForbiddenElement = "";
        ActForbiddenProtocolText = "";
        ActForbiddenPortStart = null;
        ActForbiddenPortEnd = null;
    }

    private string GetForbiddenProtocolToken()
    {
        return ActForbiddenProtocolText.Trim();
    }
}
