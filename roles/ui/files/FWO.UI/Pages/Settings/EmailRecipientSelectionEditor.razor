@using FWO.Basics

@inject UserConfig userConfig

<div class="d-flex flex-column gap-1">
    @if (ShowOwnerResponsibleTypes)
    {
        @foreach (OwnerResponsibleType ownerResponsibleType in OrderedOwnerResponsibleTypes)
        {
            <div class="form-check">
                <input id="@($"{CheckboxIdPrefix}_ort_{ownerResponsibleType.Id}")" class="form-check-input" type="checkbox"
                    checked="@Selection.OwnerResponsibleTypeIds.Contains(ownerResponsibleType.Id)"
                    @onchange="@(args => ToggleOwnerResponsibleTypeSelection(ownerResponsibleType.Id, args))" />
                <label class="form-check-label" for="@($"{CheckboxIdPrefix}_ort_{ownerResponsibleType.Id}")">@GetOwnerResponsibleTypeDisplayName(ownerResponsibleType)</label>
            </div>
        }
    }

    <div class="form-check">
        <input id="@($"{CheckboxIdPrefix}_other")" class="form-check-input" type="checkbox"
            checked="@Selection.OtherAddresses"
            @onchange="ToggleOtherAddressSelection" />
        <label class="form-check-label" for="@($"{CheckboxIdPrefix}_other")">@(userConfig.GetText(nameof(EmailRecipientOption.OtherAddresses)))</label>
    </div>
    @if (Selection.OtherAddresses)
    {
        <div class="ps-4">
            @foreach (string address in Selection.OtherAddressList)
            {
                <div class="d-flex mb-1">
                    <div class="border bg-transparent flex-grow-1">@address</div>
                    <button type="button" class="btn btn-sm btn-danger ms-1" @onclick="() => RemoveOtherAddress(address)" @onclick:preventDefault>
                        @(DisplayService.DisplayButton(userConfig, "delete", Icons.Delete))
                    </button>
                </div>
            }
            <div class="d-flex mt-1">
                <input type="text" class="form-control form-control-sm flex-grow-1" @bind="actOtherAddress" />
                <button type="button" class="btn btn-sm btn-primary ms-1" @onclick="AddOtherAddress" @onclick:preventDefault>
                    @(DisplayService.DisplayButton(userConfig, "add", Icons.Add))
                </button>
            </div>
        </div>
    }
    @if (ShowEnsureAtLeastOneNotification)
    {
        <div class="form-check">
            <input id="@($"{CheckboxIdPrefix}_ensure_one")" class="form-check-input" type="checkbox"
                checked="@Selection.EnsureAtLeastOneNotification"
                @onchange="ToggleEnsureAtLeastOneNotification" />
            <label class="form-check-label" for="@($"{CheckboxIdPrefix}_ensure_one")">@(userConfig.GetText("modEnsureAtLeastOneEmailNotification"))</label>
        </div>
    }
</div>

@code
{
    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;

    [Parameter]
    public EmailRecipientSelection Selection { get; set; } = new();

    [Parameter]
    public List<OwnerResponsibleType> OwnerResponsibleTypes { get; set; } = [];

    [Parameter]
    public string CheckboxIdPrefix { get; set; } = "cbx_mod_mail";

    [Parameter]
    public NotificationClient Client { get; set; } = NotificationClient.None;

    private bool ShowOwnerResponsibleTypes => Client == NotificationClient.None || Client.IsModellingRecipientClient();
    private bool ShowEnsureAtLeastOneNotification => ShowOwnerResponsibleTypes;
    private List<OwnerResponsibleType> OrderedOwnerResponsibleTypes => OwnerResponsibleTypes
        .Where(type => type.Active)
        .OrderBy(type => type.SortOrder)
        .ThenBy(type => type.Name, StringComparer.OrdinalIgnoreCase)
        .ToList();
    private string actOtherAddress = "";

    private void ToggleOtherAddressSelection(ChangeEventArgs args)
    {
        bool isChecked = IsChecked(args);
        Selection.OtherAddresses = isChecked;
        if (isChecked)
        {
            Selection.None = false;
        }
        else
        {
            UpdateDerivedNone();
        }
    }

    private void AddOtherAddress()
    {
        bool shortened = false;
        string address = actOtherAddress.SanitizeEmailAddressMand(ref shortened);
        actOtherAddress = "";
        if (address == "" || Selection.OtherAddressList.Contains(address, StringComparer.OrdinalIgnoreCase))
        {
            return;
        }
        Selection.OtherAddressList.Add(address);
        Selection.OtherAddresses = true;
        Selection.None = false;
        if (shortened)
        {
            DisplayMessageInUi(null, userConfig.GetText("email_address"), userConfig.GetText("U0001"), true);
        }
    }

    private void RemoveOtherAddress(string address)
    {
        Selection.OtherAddressList.RemoveAll(storedAddress => storedAddress.Equals(address, StringComparison.OrdinalIgnoreCase));
    }

    private void ToggleEnsureAtLeastOneNotification(ChangeEventArgs args)
    {
        Selection.EnsureAtLeastOneNotification = IsChecked(args);
    }

    private void ToggleOwnerResponsibleTypeSelection(int typeId, ChangeEventArgs args)
    {
        bool isChecked = IsChecked(args);
        if (isChecked)
        {
            if (!Selection.OwnerResponsibleTypeIds.Contains(typeId))
            {
                Selection.OwnerResponsibleTypeIds.Add(typeId);
            }
            Selection.None = false;
            return;
        }

        Selection.OwnerResponsibleTypeIds.RemoveAll(selectedTypeId => selectedTypeId == typeId);
        UpdateDerivedNone();
    }

    private void UpdateDerivedNone()
    {
        Selection.None = !Selection.OtherAddresses && Selection.OwnerResponsibleTypeIds.Count == 0;
    }

    private static bool IsChecked(ChangeEventArgs args)
    {
        if (args.Value is bool checkedValue)
        {
            return checkedValue;
        }
        return bool.TryParse(args.Value?.ToString(), out bool parsedValue) && parsedValue;
    }

    private string GetOwnerResponsibleTypeDisplayName(OwnerResponsibleType type)
    {
        string localized = userConfig.GetText(type.Name);
        return localized == GlobalConst.kUndefinedText ? type.Name : localized;
    }
}
