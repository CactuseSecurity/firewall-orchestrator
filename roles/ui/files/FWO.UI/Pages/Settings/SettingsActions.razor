@using System.Text.Json
@using FWO.Config.Api.Data
@using FWO.Data.Modelling
@using FWO.Ui.Services
@using FWO.Middleware.Client

@page "/settings/stateactions"
@attribute [Authorize(Roles = $"{Roles.Admin}, {Roles.Auditor}")]

@inject ApiConnection apiConnection
@inject MiddlewareClient middlewareClient
@inject GlobalConfig globalConfig
@inject UserConfig userConfig

@if(InitComplete)
{
    <div class="input-group">
        <h3>@(userConfig.GetText("state_actions"))</h3>
        <HelpLink Page="settings/stateactions"/>
    </div>
    @(userConfig.GetText("U5317"))<br>
    @(userConfig.GetText("H5501"))
    <hr />
    <button type="button" class="btn btn-sm btn-success" @onclick="AddAction">@(DisplayService.DisplayButton(userConfig, "add_action", Icons.Add))</button>
    <br><br>
    <div class="m-2 vheight75">
        <Table class="table table-bordered th-bg-secondary table-responsive overflow-auto sticky-header" TableItem="WfStateAction" Items="actions" PageSize="0" ColumnReorder="true">
            <Column TableItem="WfStateAction" Title="@(userConfig.GetText("actions"))" Field="(x => x.Id)" Sortable="false" Filterable="false">
                <Template>
                    <div class="btn-group">
                        <button type="button" class="btn btn-sm btn-warning" @onclick="() => EditAction(context)">@(DisplayService.DisplayButton(userConfig, "edit", Icons.Edit))</button>
                        <button type="button" class="btn btn-sm btn-danger" @onclick="() => RequestDeleteAction(context)">@(DisplayService.DisplayButton(userConfig, "delete", Icons.Delete))</button>
                    </div>
                </Template>
            </Column>
            <Column TableItem="WfStateAction" Title="@(userConfig.GetText("id"))" Field="@(x => x.Id)" Sortable="true" Filterable="true" />
            <Column TableItem="WfStateAction" Title="@(userConfig.GetText("name"))" Field="@(x => x.Name)" Sortable="true" Filterable="true" />
            <Column TableItem="WfStateAction" Title="@(userConfig.GetText("action_type"))" Field="@(x => x.ActionType)" Sortable="true" Filterable="true" >
                <Template>
                    @(context.ActionType != "" ? userConfig.GetText(context.ActionType) : "")
                </Template>
            </Column>
            <Column TableItem="WfStateAction" Title="@(userConfig.GetText("scope"))" Field="@(x => x.Scope)" Sortable="true" Filterable="true" >
                <Template>
                    @(context.Scope != "" ? userConfig.GetText(context.Scope) : "")
                </Template>
            </Column>
            <Column TableItem="WfStateAction" Title="@(userConfig.GetText("task_type"))" Field="@(x => x.TaskType)" Sortable="true" Filterable="true" >
                <Template>
                    @(context.TaskType != "" ? userConfig.GetText(context.TaskType) : "")
                </Template>
            </Column>
            <Column TableItem="WfStateAction" Title="@(userConfig.GetText("phase"))" Field="@(x => x.Phase)" Sortable="true" Filterable="true" >
                <Template>
                    @(context.Phase != "" ? userConfig.GetText(context.Phase) : "")
                </Template>
            </Column>
            <Column TableItem="WfStateAction" Title="@(userConfig.GetText("event"))" Field="@(x => x.Event)" Sortable="true" Filterable="true" >
                <Template>
                    @(context.Event != null && context.Event != "" ? userConfig.GetText(context.Event) : "")
                </Template>
            </Column>
            <Column TableItem="WfStateAction" Title="@(userConfig.GetText("button_text"))" Field="@(x => x.ButtonText)" Sortable="true" Filterable="true" />
            <Column TableItem="WfStateAction" Title="@(userConfig.GetText("external_params"))" Field="@(x => x.ExternalParams)" Sortable="true" Filterable="true" />
        </Table>
    </div>

    <PopUp Title="@(userConfig.GetText("edit_action"))" Show="@EditActionMode" Size=PopupSize.Large OnClose="CancelActionPopup">
        <Body>
            @if (EditActionMode)
            {
                <div class="form-group row col-sm-12">
                    <div class="col-sm-2">
                        <div class="form-group row">
                            <label class="col-sm-6 col-form-label col-form-label-sm">@(userConfig.GetText("id")):</label>
                            <label class="col-sm-6 col-form-label col-form-label-sm">@(actAction.Id)</label>
                        </div>
                    </div>
                    <div class="col-sm-10">
                        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5512"))">
                            <label class="col-sm-3 col-form-label col-form-label-sm">@(userConfig.GetText("name"))*:</label>
                            <input type="text" class="col-sm-9" @bind="actAction.Name" />
                        </div>
                    </div>
                </div>
                <div class="form-group row col-sm-12 mt-2">
                    <div class="col-sm-4">
                        <div class="form-group row">
                            <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("action_type"))*:</label>
                            <div class="col-sm-8">
                                <Dropdown ElementType="string" @bind-SelectedElement="actAction.ActionType" ElementToString="@(a => userConfig.GetText(a))" Elements="Enum.GetNames(typeof(StateActionTypes))" >
                                    <ElementTemplate Context="action">
                                        @(userConfig.GetText(action))
                                    </ElementTemplate>
                                </Dropdown>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5513"))">
                            <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("event")):</label>
                            <div class="col-sm-8">
                                <Dropdown ElementType="string" @bind-SelectedElement="actAction.Event" ElementToString="@(e => userConfig.GetText(e))" Elements="Enum.GetNames(typeof(StateActionEvents))" >
                                    <ElementTemplate Context="eventt">
                                        @(userConfig.GetText(eventt))
                                    </ElementTemplate>
                                </Dropdown>
                            </div>
                        </div>
                    </div>
                    @if(actAction.Event == StateActionEvents.OfferButton.ToString())
                    {
                        <div class="col-sm-4">
                            <div class="form-group row">
                                <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("button_text")):</label>
                                <input type="text" class="col-sm-8" @bind="actAction.ButtonText" />
                            </div>
                        </div>
                    }
                </div>
                <div class="form-group row col-sm-12 mt-2">
                    <div class="col-sm-4">
                        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5514"))">
                            <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("phase")):</label>
                            <div class="col-sm-8">
                                <Dropdown ElementType="string" @bind-SelectedElement="selectedPhase" ElementToString="@(p => userConfig.GetText(p))" 
                                        Elements="Enum.GetNames(typeof(WorkflowPhases))" Nullable="true" NoneSelectedText="@(userConfig.GetText("all"))" >
                                    <ElementTemplate Context="phase">
                                        @(userConfig.GetText(phase))
                                    </ElementTemplate>
                                </Dropdown>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5515"))">
                            <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("scope")):</label>
                            <div class="col-sm-8">
                                <Dropdown ElementType="string" @bind-SelectedElement="actAction.Scope" ElementToString="@(s => userConfig.GetText(s))" Elements="Enum.GetNames(typeof(WfObjectScopes))" >
                                    <ElementTemplate Context="scope">
                                        @(userConfig.GetText(scope))
                                    </ElementTemplate>
                                </Dropdown>
                            </div>
                        </div>
                    </div>
                    @if(actAction.Scope == WfObjectScopes.RequestTask.ToString() || actAction.Scope == WfObjectScopes.ImplementationTask.ToString())
                    {
                        <div class="col-sm-4">
                            <div class="form-group row">
                                <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("task_type")):</label>
                                <div class="col-sm-8">
                                    <Dropdown ElementType="WfTaskType?" @bind-SelectedElement="selectedTaskType" ElementToString="@(t => userConfig.GetText(t?.ToString() ?? "undefined"))" 
                                            Elements="availableTaskTypes.Where(x => x != WfTaskType.master).Cast<WfTaskType?>()" Nullable="true" NoneSelectedText="@(userConfig.GetText("all"))">
                                        <ElementTemplate Context="type">
                                            @(userConfig.GetText(type?.ToString() ?? "undefined"))
                                        </ElementTemplate>
                                    </Dropdown>
                            </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="form-group row col-sm-12 mt-2">
                    @switch (actAction.ActionType)
                    {
                        case nameof(StateActionTypes.AutoPromote):
                            <div class="col-sm-4">
                                <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5522"))">
                                    <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("to_state")):</label>
                                    <div class="col-sm-8">
                                        <Dropdown ElementType="WfState" ElementToString="@(s => DisplaySelectableState(s))" @bind-SelectedElement="selectedToState" Elements="statesPlus">
                                            <ElementTemplate Context="state">
                                                @DisplaySelectableState(state)
                                            </ElementTemplate>
                                        </Dropdown>
                                    </div>
                                </div>
                            </div>
                            @if(selectedToState.Id == ConditionalState.Id)
                            {
                                <div class="col-sm-4">
                                    <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5528"))">
                                        <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("to_be_called")):</label>
                                        <div class="col-sm-8">
                                            <Dropdown ElementType="ToBeCalled" @bind-SelectedElement="selectedToBeCalled"
                                                    ElementToString="@(t => userConfig.GetText(t.ToString()))"
                                                    Elements="Enum.GetValues(typeof(ToBeCalled)).Cast<ToBeCalled>()">
                                                <ElementTemplate Context="callTarget">
                                                    @(userConfig.GetText(callTarget.ToString()))
                                                </ElementTemplate>
                                            </Dropdown>
                                        </div>
                                    </div>
                                </div>
                                @if(selectedToBeCalled == ToBeCalled.PolicyCheck)
                                {
                                    <div class="form-group row mt-2">
                                        <div class="col-sm-8">
                                            <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5528"))">
                                                <label class="col-sm-2 col-form-label col-form-label-sm">@(userConfig.GetText("policies")):</label>
                                                <div class="col-sm-10">
                                                    <Dropdown ElementType="CompliancePolicy" Multiselect="true" @bind-SelectedElements="selectedPolicies"
                                                            ElementToString="@(p => p.Name)" Elements="policies">
                                                        <ElementTemplate Context="policy">
                                                            @policy.Name
                                                        </ElementTemplate>
                                                    </Dropdown>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-sm-4">
                                            <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5528"))">
                                                <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("checkResultLabel")):</label>
                                                <div class="col-sm-8">
                                                    <input type="text" class="form-control form-control-sm" @bind="actConditionalAutoPromoteParams.CheckResultLabel" />
                                                </div>
                                            </div>
                                         </div>
                                     </div>
                                     <div class="form-group row mt-2">
                                         <div class="col-sm-4">
                                             <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5528"))">
                                                <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("ifCompliantState")):</label>
                                                <div class="col-sm-8">
                                                    <Dropdown ElementType="WfState" ElementToString="@(s => DisplaySelectableState(s))" @bind-SelectedElement="selectedStateOk"
                                                            Elements="statesPlus.Where(x => x.Id != ConditionalState.Id)">
                                                        <ElementTemplate Context="state">
                                                            @DisplaySelectableState(state)
                                                        </ElementTemplate>
                                                    </Dropdown>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-sm-4">
                                            <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5528"))">
                                                <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("ifNotCompliantState")):</label>
                                                <div class="col-sm-8">
                                                    <Dropdown ElementType="WfState" ElementToString="@(s => DisplaySelectableState(s))" @bind-SelectedElement="selectedStateNotOk"
                                                            Elements="statesPlus.Where(x => x.Id != ConditionalState.Id)">
                                                        <ElementTemplate Context="state">
                                                            @DisplaySelectableState(state)
                                                        </ElementTemplate>
                                                    </Dropdown>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                            break;
                        case nameof(StateActionTypes.AddApproval):
                            <div class="col-sm-4">
                                <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5523"))">
                                    <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("state"))*:</label>
                                    <div class="col-sm-8">
                                        <Dropdown ElementType="WfState" ElementToString="@(s => s.Name)" @bind-SelectedElement="selectedState" Elements="states">
                                            <ElementTemplate Context="state">
                                                @state.Name
                                            </ElementTemplate>
                                        </Dropdown>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5523"))">
                                    <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("group")):</label>
                                    <div class="col-sm-8">
                                        <Dropdown ElementType="UiUser" @bind-SelectedElement="selectedUserGroup" ElementToString="@(g => g.Name)" Elements="userAndGroupList" Nullable="true">
                                            <ElementTemplate Context="group">
                                                @group.Name
                                            </ElementTemplate>
                                        </Dropdown>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5523"))">
                                    <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("deadline")):</label>
                                    <input type="number" class="col-sm-8" @bind="actApprovalParams.Deadline" />
                                </div>
                            </div>
                            break;
                        case nameof(StateActionTypes.SetAlert):
                            <div class="col-sm-12">
                                <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5524"))">
                                    <label class="col-sm-2 col-form-label col-form-label-sm">@(userConfig.GetText("message_text")):</label>
                                    <input type="text" class="col-sm-10" @bind="message" />
                                </div>
                            </div>
                            break;
                        case nameof(StateActionTypes.TrafficPathAnalysis):
                            <div class="col-sm-4">
                                <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5526"))">
                                    <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("option")):</label>
                                    <div class="col-sm-8">
                                        <Dropdown ElementType="PathAnalysisOptions" @bind-SelectedElement="actPathAnalysisParams.Option" 
                                                ElementToString="@(o => userConfig.GetText(o.ToString()))"
                                                Elements="Enum.GetValues(typeof(PathAnalysisOptions)).Cast<PathAnalysisOptions>()">
                                            <ElementTemplate Context="opt">
                                                @(userConfig.GetText(opt.ToString()))
                                            </ElementTemplate>
                                        </Dropdown>
                                    </div>
                                </div>
                            </div>
                            break;
                        case nameof(StateActionTypes.SendEmail):
                            <div class="col-sm-4">
                                <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5527"))">
                                    <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("attached_content")):</label>
                                    <div class="col-sm-8">
                                        <Dropdown ElementType="EmailAttachedContent" @bind-SelectedElement="actAttachedContent"
                                                  ElementToString="@(c => userConfig.GetText(c.ToString()))"
                                                  Elements="Enum.GetValues(typeof(EmailAttachedContent)).Cast<EmailAttachedContent>()">
                                            <ElementTemplate Context="content">
                                                @(userConfig.GetText(content.ToString()))
                                            </ElementTemplate>
                                        </Dropdown>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5530"))">
                                    <label class="col-sm-4 col-form-label col-form-label-sm" for="confirmSentMail">@(userConfig.GetText("confirm_sent_mail")):</label>
                                    <div class="col-sm-8">
                                        <input id="confirmSentMail" class="form-check-input mt-2" type="checkbox" @bind="actConfirmSentMail" />
                                    </div>
                                </div>
                            </div>
                            break;
                        case nameof(StateActionTypes.UpdateModelling):
                            <div class="col-sm-4">
                                <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5529"))">
                                    <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("modIntegrationStates")):</label>
                                    <div class="col-sm-8">
                                        <Dropdown ElementType="string" @bind-SelectedElement="selectedModIntegrationState"
                                                  ElementToString="@(state => state)"
                                                  Elements="availableModIntegrationStateNames"
                                                  Nullable="true" NoneSelectedText="@(userConfig.GetText("none"))">
                                            <ElementTemplate Context="state">
                                                @state
                                            </ElementTemplate>
                                        </Dropdown>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5534"))">
                                    <label class="col-sm-4 col-form-label col-form-label-sm" for="confirmUpdateModelling">@(userConfig.GetText("confirm_modelling_update")):</label>
                                    <div class="col-sm-8">
                                        <input id="confirmUpdateModelling" class="form-check-input mt-2" type="checkbox" @bind="actConfirmSentMail" />
                                    </div>
                                </div>
                            </div>
                            break;
                        default:
                            break;
                    }
                </div>
                @if(actAction.ActionType == nameof(StateActionTypes.SendEmail))
                {
                    <EditNotifications Client="NotificationClient.WfAction" NotificationIds="@actActionNotificationIds" NotificationIdsChanged="@SetActionNotificationIds" />
                }
            }
        </Body>
        <Footer>
            <div class="btn-group">
                <AuthorizeView Roles="@($"{Roles.Admin}, {Roles.FwAdmin}")">
                    <Authorized>
                        <button type="button" class="btn btn-sm btn-primary" @onclick="SaveAction">@(DisplayService.DisplayButton(userConfig, "save", Icons.Save))</button>
                    </Authorized>
                    <NotAuthorized>
                        <button type="button" class="btn btn-sm btn-primary" disabled>@(DisplayService.DisplayButton(userConfig, "save", Icons.Save))</button>
                    </NotAuthorized> 
                </AuthorizeView>
                <button type="button" class="btn btn-sm btn-secondary" @onclick="Cancel">@(DisplayService.DisplayButton(userConfig, "cancel", Icons.Cancel))</button>
            </div>
        </Footer>
    </PopUp>

    <ConfirmDelete @bind-Display="DeleteActionMode" PerformAction="DeleteAction" Title="@userConfig.GetText("delete_action")" DeleteMessage="@(userConfig.GetText("U5502") + actAction.Name + "?")"/>
}
else
{
    <Loading/>
}

@code
{
    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;

    private List<WfStateAction> actions = [];
    private List<WfState> states = [];
    private List<WfState> statesPlus = [];
    private List<CompliancePolicy> policies = [];
    private IEnumerable<CompliancePolicy> selectedPolicies = [];
    private List<UiUser> userAndGroupList = [];
    private List<WfTaskType> availableTaskTypes { get; set; } = [];

    private WfStateAction actAction = new ();
    private ApprovalParams actApprovalParams = new ();
    private int toState = -1;
    private string message = "";
    private PathAnalysisActionParams actPathAnalysisParams = new ();
    private List<int> actActionNotificationIds = [];
    private EmailAttachedContent actAttachedContent = EmailAttachedContent.None;
    private bool actConfirmSentMail;
    private string? selectedModIntegrationState;
    private List<string> availableModIntegrationStateNames = [];
    private FwoNotification? legacyActionNotification;
    private WfStateAction persistedActionSnapshot = new ();
    private ConditionalAutoPromoteParams actConditionalAutoPromoteParams = new ();

    private string? selectedPhase;
    private WfTaskType? selectedTaskType;
    private WfState selectedState = new ();
    private static WfState AutomaticState = new (){ Id = -1, Name = "automatic" };
    private static WfState ConditionalState = new (){ Id = -2, Name = "Conditional" };
    private WfState selectedToState = AutomaticState;
    private WfState selectedStateOk = AutomaticState;
    private WfState selectedStateNotOk = AutomaticState;
    private UiUser? selectedUserGroup;
    private ToBeCalled selectedToBeCalled = ToBeCalled.PolicyCheck;

    private bool EditActionMode = false;
    private bool AddActionMode = false;
    private bool DeleteActionMode = false;
    private bool InitComplete = false;

    protected override async Task OnInitializedAsync()
    {
        await RefreshActions();
        InitComplete = true;
    }

    private async Task RefreshActions()
    {
        try
        {
            actions = await apiConnection.SendQueryAsync<List<WfStateAction>>(RequestQueries.getActions);
            states = await apiConnection.SendQueryAsync<List<WfState>>(RequestQueries.getStates);
            policies = await apiConnection.SendQueryAsync<List<CompliancePolicy>>(ComplianceQueries.getPolicies);
            ConfigData editableConfig = await globalConfig.GetEditableConfig();
            statesPlus =
            [
                AutomaticState,
                ConditionalState,
                .. states
            ];
            availableTaskTypes = System.Text.Json.JsonSerializer.Deserialize<List<WfTaskType>>(userConfig.ReqAvailableTaskTypes) ?? throw new JsonException("Config data could not be parsed.");
            availableModIntegrationStateNames = ModIntegrationStateConfig.Parse(editableConfig.ModIntegrationStates).Select(state => state.Name).ToList();
            userAndGroupList = await RoleAccess.GetRoleMembers(middlewareClient, Roles.Approver);
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("fetch_data"), "", true);
        }
    }

    private void AddAction()
    {
        AddActionMode = true;
        EditAction(new WfStateAction());
    }

    private void EditAction(WfStateAction action)
    {
        actAction = action;
        persistedActionSnapshot = new WfStateAction(action);
        ResetActionEditState();
        SelectActionTaskType();
        LoadActionExternalParams(action);
        ResolveActionSelections();
        EditActionMode = true;
    }

    private void ResetActionEditState()
    {
        actApprovalParams = new();
        actPathAnalysisParams = new();
        actActionNotificationIds = [];
        actAttachedContent = EmailAttachedContent.None;
        actConfirmSentMail = false;
        legacyActionNotification = null;
        actConditionalAutoPromoteParams = new();
        toState = -1;
        message = "";
        selectedToState = AutomaticState;
        selectedStateOk = AutomaticState;
        selectedStateNotOk = AutomaticState;
        selectedPolicies = [];
        selectedToBeCalled = ToBeCalled.PolicyCheck;
        selectedModIntegrationState = null;
        selectedPhase = actAction.Phase != "" ? actAction.Phase : null;
    }

    private void SelectActionTaskType()
    {
        if (actAction.TaskType != "")
        {
            selectedTaskType = Enum.TryParse(actAction.TaskType, out WfTaskType tmpTaskType)
                ? tmpTaskType
                : null;
            return;
        }

        selectedTaskType = null;
    }

    private void LoadActionExternalParams(WfStateAction action)
    {
        if (action.ExternalParams == "" || action.ExternalParams == "{}")
        {
            return;
        }

        switch(action.ActionType)
        {
            case nameof(StateActionTypes.AutoPromote):
                LoadAutoPromoteParams(action.ExternalParams);
                break;
            case nameof(StateActionTypes.AddApproval):
                actApprovalParams = System.Text.Json.JsonSerializer.Deserialize<ApprovalParams>(action.ExternalParams) ?? throw new JsonException("Extparams could not be parsed.");
                break;
            case nameof(StateActionTypes.SetAlert):
                message = actAction.ExternalParams;
                break;
            case nameof(StateActionTypes.TrafficPathAnalysis):
                actPathAnalysisParams = System.Text.Json.JsonSerializer.Deserialize<PathAnalysisActionParams>(action.ExternalParams) ?? throw new JsonException("Extparams could not be parsed.");
                break;
            case nameof(StateActionTypes.SendEmail):
                LoadEmailParams(action.ExternalParams);
                break;
            case nameof(StateActionTypes.UpdateModelling):
                LoadUpdateModellingParams(action.ExternalParams);
                break;
            default:
                break;
        }
    }

    private void LoadAutoPromoteParams(string externalParams)
    {
        if (!WfStateAction.TryParseAutoPromoteParams(externalParams, out int? parsedToState, out ConditionalAutoPromoteParams? conditionalParams))
        {
            return;
        }

        if (conditionalParams != null)
        {
            actConditionalAutoPromoteParams = conditionalParams;
            selectedToBeCalled = conditionalParams.ToBeCalled;
            selectedPolicies = policies.Where(p => conditionalParams.PolicyIds.Contains(p.Id)).ToList();
            selectedToState = ConditionalState;
            return;
        }

        toState = parsedToState ?? -1;
    }

    private void LoadEmailParams(string externalParams)
    {
        EmailActionParams emailActionParams = System.Text.Json.JsonSerializer.Deserialize<EmailActionParams>(externalParams) ?? throw new JsonException("Extparams could not be parsed.");
        actAttachedContent = emailActionParams.AttachedContent;
        actConfirmSentMail = emailActionParams.ConfirmSentMail;
        SelectActionNotification(emailActionParams);
    }

    private void LoadUpdateModellingParams(string externalParams)
    {
        UpdateModellingActionParams updateModellingParams = UpdateModellingActionParams.FromExternalParams(externalParams);
        selectedModIntegrationState = availableModIntegrationStateNames.Contains(updateModellingParams.ModellingState) ? updateModellingParams.ModellingState : null;
        actConfirmSentMail = updateModellingParams.ConfirmUiMessage;
    }

    private void ResolveActionSelections()
    {
        selectedState = states.FirstOrDefault(x => x.Id == actApprovalParams.StateId) ?? new WfState();
        if (selectedToState.Id != ConditionalState.Id)
        {
            selectedToState = statesPlus.FirstOrDefault(x => x.Id == toState) ?? AutomaticState;
        }
        selectedStateOk = statesPlus.Where(x => x.Id != ConditionalState.Id).FirstOrDefault(x => x.Id == actConditionalAutoPromoteParams.IfCompliantState) ?? AutomaticState;
        selectedStateNotOk = statesPlus.Where(x => x.Id != ConditionalState.Id).FirstOrDefault(x => x.Id == actConditionalAutoPromoteParams.IfNotCompliantState) ?? AutomaticState;
        selectedUserGroup = userAndGroupList.FirstOrDefault(x => x.Dn == actApprovalParams.ApproverGroup);
    }

    private async Task SaveAction()
    {
        try
        {
            UpdateActionSelections();
            if (!await TryUpdateExternalParams())
            {
                return;
            }

            if(AddActionMode)
            {
                await SaveNewAction();
            }
            else
            {
                await SaveExistingAction();
            }
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("save_action"), "", true);
        }
    }

    private void UpdateActionSelections()
    {
        actAction.Phase = selectedPhase ?? "";
        actAction.TaskType = selectedTaskType?.ToString() ?? "";
        actApprovalParams.StateId = selectedState.Id;
        actApprovalParams.ApproverGroup = selectedUserGroup?.Dn ?? "";
    }

    private async Task<bool> TryUpdateExternalParams()
    {
        switch(actAction.ActionType)
        {
            case nameof(StateActionTypes.AutoPromote):
                actAction.ExternalParams = AutoPromoteExternalParams();
                return true;
            case nameof(StateActionTypes.AddApproval):
                actAction.ExternalParams = JsonSerializer.Serialize(actApprovalParams);
                return true;
            case nameof(StateActionTypes.SetAlert):
                actAction.ExternalParams = message;
                return true;
            case nameof(StateActionTypes.TrafficPathAnalysis):
                actAction.ExternalParams = JsonSerializer.Serialize(actPathAnalysisParams);
                return true;
            case nameof(StateActionTypes.SendEmail):
                return await TryUpdateEmailExternalParams();
            case nameof(StateActionTypes.UpdateModelling):
                actAction.ExternalParams = UpdateModellingExternalParams();
                return true;
            default:
                return true;
        }
    }

    private string AutoPromoteExternalParams()
    {
        if (selectedToState.Id != ConditionalState.Id)
        {
            return selectedToState.Id.ToString();
        }

        actConditionalAutoPromoteParams.ToBeCalled = selectedToBeCalled;
        actConditionalAutoPromoteParams.PolicyIds = selectedPolicies.Select(p => p.Id).ToList();
        actConditionalAutoPromoteParams.CheckResultLabel = actConditionalAutoPromoteParams.CheckResultLabel?.Trim() ?? "";
        actConditionalAutoPromoteParams.IfCompliantState = selectedStateOk.Id;
        actConditionalAutoPromoteParams.IfNotCompliantState = selectedStateNotOk.Id;
        return JsonSerializer.Serialize(actConditionalAutoPromoteParams);
    }

    private async Task<bool> TryUpdateEmailExternalParams()
    {
        if (!await TryEnsureSelectedActionNotification())
        {
            return false;
        }

        actAction.ExternalParams = EmailExternalParams();
        return true;
    }

    private async Task SaveNewAction()
    {
        var Variables = new
        {
            name = actAction.Name,
            actionType = actAction.ActionType,
            scope = actAction.Scope,
            taskType = actAction.TaskType,
            phase = actAction.Phase,
            eventt = actAction.Event,
            buttonText = actAction.ButtonText,
            externalParameters = actAction.ExternalParams
        };
        ReturnId[]? returnIds = (await apiConnection.SendQueryAsync<ReturnIdWrapper>(RequestQueries.newAction, Variables)).ReturnIds;
        if (returnIds == null)
        {
            DisplayMessageInUi(null, userConfig.GetText("save_action"), userConfig.GetText("E8011"), true);
            return;
        }

        actAction.Id = returnIds[0].NewId;
        actions.Add(actAction);
        EditActionMode = false;
        AddActionMode = false;
    }

    private async Task SaveExistingAction()
    {
        int updatedId = await UpdateAction(actAction, actAction.ExternalParams);
        if(updatedId != actAction.Id)
        {
            DisplayMessageInUi(null, userConfig.GetText("save_action"), userConfig.GetText("E8011"), true);
            return;
        }

        actions[actions.FindIndex(x => x.Id == actAction.Id)] = actAction;
        EditActionMode = false;
    }

    private void CancelActionPopup()
    {
        _ = Cancel();
    }

    private async Task Cancel()
    {
        try
        {
            if (AddActionMode)
            {
                await DeleteActionNotifications(actActionNotificationIds);
            }
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("delete_notification"), "", true);
        }
        EditActionMode = false;
        AddActionMode = false;
        DeleteActionMode = false;
    }

    private void RequestDeleteAction(WfStateAction action)
    {
        actAction = action;
        DeleteActionMode = true;
    }

    private async Task DeleteAction()
    {
        try
        {
            List<int> notificationIds = ActionNotificationIds(actAction);
            await apiConnection.SendQueryAsync<object>(RequestQueries.deleteAction, new { id = actAction.Id });
            actions.Remove(actAction);
            await DeleteActionNotifications(notificationIds);
            DeleteActionMode = false;
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("delete_action"), "", true);
        }
        StateHasChanged();
    }

    private void SelectActionNotification(EmailActionParams actionParams)
    {
        actActionNotificationIds = [.. actionParams.NotificationIds.Where(id => id > 0).Distinct()];
        if (actActionNotificationIds.Count > 0)
        {
            return;
        }

        legacyActionNotification = actionParams.ToNotification();
    }

    private async Task<bool> TryEnsureSelectedActionNotification()
    {
        if (actActionNotificationIds.Count > 0)
        {
            return true;
        }

        if (legacyActionNotification != null && !string.IsNullOrWhiteSpace(legacyActionNotification.EmailSubject))
        {
            legacyActionNotification.NotificationClient = NotificationClient.WfAction;
            legacyActionNotification.Channel = NotificationChannel.Email;
            legacyActionNotification.Deadline = NotificationDeadline.None;
            if (string.IsNullOrWhiteSpace(legacyActionNotification.Name))
            {
                legacyActionNotification.Name = actAction.Name;
            }

            FwoNotification savedNotification = await NotificationMutationHelper.AddAsync(apiConnection, NotificationClient.WfAction, legacyActionNotification);
            actActionNotificationIds = [savedNotification.Id];
            return true;
        }

        DisplayMessageInUi(null, userConfig.GetText("save_action"), userConfig.GetText("E4011"), true);
        return false;
    }

    private Task SetActionNotificationIds(List<int> notificationIds)
    {
        actActionNotificationIds = [.. notificationIds.Distinct()];
        return PersistActionNotificationIds();
    }

    private async Task PersistActionNotificationIds()
    {
        if (AddActionMode || actAction.Id <= 0 || actAction.ActionType != nameof(StateActionTypes.SendEmail))
        {
            return;
        }

        string externalParams = EmailExternalParams();
        int updatedId = await UpdateAction(persistedActionSnapshot, externalParams);
        if (updatedId != actAction.Id)
        {
            DisplayMessageInUi(null, userConfig.GetText("save_action"), userConfig.GetText("E8011"), true);
            return;
        }
        persistedActionSnapshot.ExternalParams = externalParams;
        actAction.ExternalParams = externalParams;
    }

    private string EmailExternalParams()
    {
        return JsonSerializer.Serialize(new
        {
            notification_ids = actActionNotificationIds,
            attached_content = actAttachedContent,
            confirm_sent_mail = actConfirmSentMail
        });
    }

    private string UpdateModellingExternalParams()
    {
        return JsonSerializer.Serialize(new
        {
            modelling_state = selectedModIntegrationState ?? "",
            confirm_ui_message = actConfirmSentMail
        });
    }

    private async Task<int> UpdateAction(WfStateAction action, string externalParams)
    {
        var Variables = new
        {
            id = action.Id,
            name = action.Name,
            actionType = action.ActionType,
            scope = action.Scope,
            taskType = action.TaskType,
            phase = action.Phase,
            eventt = action.Event,
            buttonText = action.ButtonText,
            externalParameters = externalParams
        };
        return (await apiConnection.SendQueryAsync<ReturnId>(RequestQueries.updateAction, Variables)).UpdatedId;
    }

    private static List<int> ActionNotificationIds(WfStateAction action)
    {
        if (action.ActionType != nameof(StateActionTypes.SendEmail) || string.IsNullOrWhiteSpace(action.ExternalParams))
        {
            return [];
        }

        try
        {
            EmailActionParams? actionParams = JsonSerializer.Deserialize<EmailActionParams>(action.ExternalParams);
            return actionParams == null
                ? []
                : [.. actionParams.NotificationIds.Where(id => id > 0).Distinct()];
        }
        catch (JsonException)
        {
            return [];
        }
    }

    private async Task DeleteActionNotifications(IEnumerable<int> notificationIds)
    {
        foreach (int notificationId in notificationIds.Where(id => id > 0).Distinct())
        {
            await NotificationMutationHelper.DeleteAsync(apiConnection, notificationId);
        }
    }

    private string DisplaySelectableState(WfState state)
    {
        return state.Id switch
        {
            -1 => userConfig.GetText("automatic"),
            -2 => userConfig.GetText("Conditional"),
            _ => state.Name
        };
    }
}
