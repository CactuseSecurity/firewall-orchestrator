@page "/settings/changetrigger"
@attribute [Authorize(Roles = $"{Roles.Admin}, {Roles.Auditor}")]

@inject ApiConnection apiConnection
@inject GlobalConfig globalConfig
@inject UserConfig userConfig

<div class="input-group">
    <h3>@(userConfig.GetText("change_trigger"))</h3>
    <HelpLink Page="settings/changetrigger" />
</div>
@(userConfig.GetText("U5326"))
<hr />

@if (configData != null)
{
    <form onsubmit="return false">

        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5484"))">
            <h5>
                @(userConfig.GetText("change_notification_sub"))
            </h5>
            <label class="col-form-label col-sm-4">@(userConfig.GetText("impChangeNotifyType")):</label>
            <div class="col-sm-2">
                <Dropdown ElementType="NotificationLayout" @bind-SelectedElement="selectedImpChgNotType" ElementToString="@(i => userConfig.GetText(i.ToString()))"
                Elements="NotificationLayoutGroups.ListWithoutCsv()">
                    <ElementTemplate Context="type">
                        @(userConfig.GetText(type.ToString()))
                    </ElementTemplate>
                </Dropdown>
            </div>
        </div>
        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5487"))">
            <label class="col-form-label col-sm-4">@(userConfig.GetText("impChangeNotifyRecipients")):</label>
            <div class="col-sm-7" data-toggle="tooltip" title="@(userConfig.GetText("U5320"))">
                <input type="text" @bind="configData!.ImpChangeNotifyRecipients" />
            </div>
        </div>
        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5488"))">
            <label class="col-form-label col-sm-4">@(userConfig.GetText("impChangeNotifySubject")):</label>
            <div class="col-sm-7">
                <input type="text" @bind="configData!.ImpChangeNotifySubject" />
            </div>
        </div>
        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5489"))">
            <label class="col-form-label col-sm-4">@(userConfig.GetText("impChangeNotifyBody")):</label>
            <div class="col-sm-7">
                <textarea rows="6" cols="60" name="text" placeholder=@(userConfig.GetText("impChangeNotifyBody")) @bind="configData!.ImpChangeNotifyBody"></textarea>
            </div>
        </div>
        <hr />
        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5483"))">
            <label for="cbx_change_notify_active" class="col-form-label col-sm-4">@(userConfig.GetText("impChangeNotifyActive")):</label>
            <div class="col-sm-1">
                <input id="cbx_change_notify_active" type="checkbox" class="w-100" @bind="configData!.ImpChangeNotifyActive" />
            </div>
        </div>
        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5851"))">
            <label for="cbx_change_notify_active" class="col-form-label col-sm-4">@(userConfig.GetText("U1004")):</label>
            <div class="col-sm-1">
                <input id="cbx_change_notify_active" type="checkbox" class="w-100" @bind="configData!.ImpChangeIncludeObjectChanges" />
            </div>
        </div>
        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5485"))">
            <label class="col-form-label col-sm-4">@(userConfig.GetText("impChangeNotifySleepTime")):</label>
            <div class="col-sm-2">
                <input type="number" min="0" @bind="configData!.ImpChangeNotifySleepTime" />
            </div>
        </div>
        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5486"))">
            <label class="col-form-label col-sm-4">@(userConfig.GetText("impChangeNotifyStartAt")):</label>
            <div class="col-sm-4">
                <div class="row">
                    <input type="time" step="60" class="ml-13 col-sm-5" @bind="impChangeNotifyStartTime" />
                    <input type="date" class="col-sm-5" @bind="impChangeNotifyStartDate" />
                </div>
            </div>
        </div>
        <hr />
        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5483a"))">
            <h5>
                @(userConfig.GetText("update_rule_owner_mapping_sub"))
            </h5>
            <label for="cbx_change_notify_active" class="col-form-label col-sm-4">@(userConfig.GetText("updateRuleOwnerMappingActive")):</label>
            <div class="col-sm-1">
                <input id="cbx_change_notify_active" type="checkbox" class="w-100" @bind="configData!.UpdateRuleOwnerMappingActive" />
            </div>
        </div>
        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5485a"))">
            <label class="col-form-label col-sm-4">@(userConfig.GetText("updateRuleOwnerMappingSleepTime")):</label>
            <div class="col-sm-2">
                <input type="number" min="0" @bind="configData!.UpdateRuleOwnerMappingSleepTime" />
            </div>
        </div>
        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5486a"))">
            <label class="col-form-label col-sm-4">@(userConfig.GetText("updateRuleOwnerMappingStartAt")):</label>
            <div class="col-sm-4">
                <div class="row">
                    <input type="time" step="60" class="ml-13 col-sm-5" @bind="updateRuleOwnerMappingStartTime" />
                    <input type="date" class="col-sm-5" @bind="updateRuleOwnerMappingStartDate" />
                </div>
            </div>
        </div>
    </form>
    <hr />
    <AuthorizeView Roles="@Roles.Admin">
        <Authorized>
            <button type="button" class="btn btn-sm btn-primary" @onclick="Save" @onclick:preventDefault>@(userConfig.GetText("save"))</button>
        </Authorized>
        <NotAuthorized>
            <button type="button" class="btn btn-sm btn-primary" disabled>@(userConfig.GetText("save"))</button>
        </NotAuthorized>
    </AuthorizeView>
}
else
{
    <Loading />
}

@code {
    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;

    private ConfigData? configData;
    private Language selectedLanguage = new Language();
    private NotificationLayout selectedImpChgNotType;
    private DateTime impChangeNotifyStartDate = DateTime.Today;
    private DateTime impChangeNotifyStartTime = DateTime.Now.AddSeconds(-DateTime.Now.Second);
    private DateTime updateRuleOwnerMappingStartDate = DateTime.Today;
    private DateTime updateRuleOwnerMappingStartTime = DateTime.Now.AddSeconds(-DateTime.Now.Second);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            configData = await globalConfig.GetEditableConfig();
            selectedLanguage = globalConfig.UiLanguages.FirstOrDefault(l => l.Name == configData.DefaultLanguage) ?? new Language();
            selectedImpChgNotType = (NotificationLayout)configData.ImpChangeNotifyType;
            impChangeNotifyStartDate = impChangeNotifyStartTime = configData.ImpChangeNotifyStartAt;
            updateRuleOwnerMappingStartDate = updateRuleOwnerMappingStartTime = configData.UpdateRuleOwnerMappingStartAt;
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("read_config"), userConfig.GetText("E5301"), false);
        }
    }

    private async Task Save()
    {
        try
        {
            if (configData != null)
            {
                configData.DefaultLanguage = selectedLanguage.Name;
                configData.ImpChangeNotifyType = (int)selectedImpChgNotType;
                configData.ImpChangeNotifyStartAt = impChangeNotifyStartDate.Date.Add(impChangeNotifyStartTime.TimeOfDay);
                configData.UpdateRuleOwnerMappingStartAt = updateRuleOwnerMappingStartDate.Date.Add(updateRuleOwnerMappingStartTime.TimeOfDay);
                await globalConfig.WriteToDatabase(configData, apiConnection);
                DisplayMessageInUi(null, userConfig.GetText("change_default"), userConfig.GetText("U5301"), false);
            }
            else
            {
                throw new ArgumentException("Data saved before loaded. This should be impossible.");
            }
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("change_default"), "", true);
        }
    }
}
