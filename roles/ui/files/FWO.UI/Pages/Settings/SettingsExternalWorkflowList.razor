@using FWO.Logging
@using FWO.ExternalSystems.Tufin.SecureChange
@using System.Text.Json

@page "/settings/exttickettemplates"
@attribute [Authorize(Roles = $"{Roles.Admin}, {Roles.Auditor}")]

@inject ApiConnection apiConnection
@inject GlobalConfig globalConfig
@inject UserConfig userConfig

@if (InitComplete && configData != null)
{
    <div class="input-group">
        <h3>@(userConfig.GetText("ext_ticket_templates"))</h3>
        <HelpLink Page="settings/exttickettemplates" />
    </div>
    @(userConfig.GetText("H5598"))
    <hr />
    <div class="row">
        <div class="col-sm-12">
            <div class="form-group row">
                <div class="form-group row col-sm-6" data-toggle="tooltip" title="@(userConfig.PureLine("H5426a"))">
                    <label class="col-form-label col-sm-6">@(userConfig.GetText("externalRequestSleepTime")):</label>
                    <div class="col-sm-4">
                        <input type="number" min="0" @bind="configData!.ExternalRequestSleepTime" />
                    </div>
                </div>
                <div class="form-group row col-sm-6" data-toggle="tooltip" title="@(userConfig.PureLine("H5426b"))">
                    <label class="col-form-label col-sm-6">@(userConfig.GetText("externalRequestWaitCycles")):</label>
                    <div class="col-sm-4">
                        <input type="number" min="0" @bind="configData!.ExternalRequestWaitCycles" />
                    </div>
                </div>
            </div>
            <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5427a"))">
                <label class="col-form-label col-sm-3">@(userConfig.GetText("externalRequestStartAt")):</label>
                <div class="col-sm-4">
                    <div class="row">
                        <input type="time" step="60" class="ml-13 col-sm-5" @bind="extReqStartTime" />
                        <input type="date" class="col-sm-5" @bind="extReqStartDate" />
                    </div>
                </div>
            </div>
            <AuthorizeView Roles="@Roles.Admin">
                <Authorized>
                    <button type="button" class="btn btn-sm btn-primary" @onclick="SaveServiceData">@(userConfig.GetText("save"))</button>
                </Authorized>
                <NotAuthorized>
                    <button type="button" class="btn btn-sm btn-primary" disabled>@(userConfig.GetText("save"))</button>
                </NotAuthorized>
            </AuthorizeView>
            <hr />
            <div class="row mb-2">
                <div class="col-sm-12">
                    <AuthorizeView Roles="@Roles.Admin">
                        <Authorized>
                            <button type="button" class="btn btn-sm btn-success" @onclick="AddExternalTicketSystem">@(DisplayService.DisplayButton(userConfig, "add_ext_ticket_system", Icons.Add))</button>
                        </Authorized>
                    </AuthorizeView>
                </div>
            </div>
            <Table class="table table-bordered th-bg-secondary table-responsive overflow-auto sticky-header" TableItem="ExternalTicketSystem" Items="extTicketSystems" PageSize="0" ColumnReorder="true">
                <Column TableItem="ExternalTicketSystem" Title="@(userConfig.GetText("actions"))" Field="(x => x.Id)" Sortable="false" Filterable="false">
                    <Template Context="item">
                        <div class="btn-group">
                            <AuthorizeView Roles="@Roles.Admin">
                                <Authorized>
                                    <button type="button" class="btn btn-sm btn-warning" @onclick="() => EditExternalTicketSystem(item)">@(DisplayService.DisplayButton(userConfig, "edit", Icons.Edit))</button>
                                    <button type="button" class="btn btn-sm btn-danger" @onclick="() => RequestDeleteExternalTicketSystem(item)">@(DisplayService.DisplayButton(userConfig, "delete", Icons.Delete))</button>
                                </Authorized>
                                <NotAuthorized>
                                    <button type="button" disabled class="btn btn-sm btn-warning">@(DisplayService.DisplayButton(userConfig, "edit", Icons.Edit))</button>
                                    <button type="button" disabled class="btn btn-sm btn-danger">@(DisplayService.DisplayButton(userConfig, "delete", Icons.Delete))</button>
                                </NotAuthorized>
                            </AuthorizeView>
                        </div>
                    </Template>
                </Column>
                <Column TableItem="ExternalTicketSystem" Title="@(userConfig.GetText("id"))" Field="@(x => x.Id)" Sortable="true" Filterable="true" />
                <Column TableItem="ExternalTicketSystem" Title="@(userConfig.GetText("name"))" Field="@(x => x.Name)" Sortable="true" Filterable="true" />
                <Column TableItem="ExternalTicketSystem" Title="@(userConfig.GetText("ext_ticket_system_type"))" Field="@(x => x.TypeId)" Sortable="true" Filterable="true">
                    <Template Context="item">
                        @FormatExternalTicketSystemType(item)
                    </Template>
                </Column>
            </Table>
        </div>
    </div>
    <PopUp Title="@(curExternalTicketSystem == null ? userConfig.GetText("new_ext_ticket_system") : userConfig.GetText("edit_ext_ticket_system"))" Show="@editMode" Size="PopupSize.XLarge" OnClose="() => editMode = false">
        <Body>
            @if (editMode && configData != null)
            {
                <div class="form-group row mt-2">
                    <div class="form-group row mt-2">
                        <label class="col-sm-3 col-form-label col-form-label-sm">@(userConfig.GetText("name")):</label>
                        <div class="col-sm-8">
                            <input type="text" class="col-sm-8" @bind="editModel.Name" />
                        </div>
                    </div>
                    <div class="form-group row mt-2" data-toggle="tooltip" title="@(userConfig.PureLine("H5597"))">
                        <label class="col-sm-3 col-form-label col-form-label-sm">@(userConfig.GetText("ext_ticket_system_type")):</label>
                        <div class="col-sm-4">
                            <Dropdown ElementType="ExternalTicketSystemTypeDefinition" SelectedElement="selectedType" SelectedElementChanged="OnTypeChanged"
                                      ElementToString="@(type => string.IsNullOrWhiteSpace(type.Version) ? type.Name : $"{type.Name} {type.Version}")"
                                      Elements="availableExternalTicketTypes">
                                <ElementTemplate Context="type">
                                    @(string.IsNullOrWhiteSpace(type.Version) ? type.Name : $"{type.Name} {type.Version}")
                                </ElementTemplate>
                            </Dropdown>
                        </div>
                    </div>
                    @if (selectedType.IsBuiltIn)
                    {
                        <div class="form-group row mt-2" data-toggle="tooltip" title="@(userConfig.PureLine("H5593"))">
                            <label class="col-sm-3 col-form-label col-form-label-sm">@(userConfig.GetText("ext_ticket_url")):</label>
                            <div class="col-sm-8">
                                <input type="text" class="col-sm-8" @bind="editModel.Url" />
                            </div>
                        </div>
                        <div class="form-group row mt-2" data-toggle="tooltip" title="@(userConfig.PureLine("H5594"))">
                            <label class="col-sm-3 col-form-label col-form-label-sm">@(userConfig.GetText("ext_ticket_auth")):</label>
                            <div class="col-sm-8">
                                <input type="text" class="col-sm-8" @bind="editModel.Authorization" />
                            </div>
                        </div>
                    }
                    <div class="form-group row mt-2">
                        <label class="col-sm-2 col-form-label col-form-label-sm">@(userConfig.GetText("response_timeout")):</label>
                        <div class="col-sm-2" data-toggle="tooltip" title="@(userConfig.PureLine("H5593a"))">
                            <input type="number" class="col-sm-6" @bind="editModel.ResponseTimeout" />
                        </div>
                        <label class="col-sm-2 col-form-label col-form-label-sm">@(userConfig.GetText("max_attempts")):</label>
                        <div class="col-sm-2" data-toggle="tooltip" title="@(userConfig.PureLine("H5593b"))">
                            <input type="number" class="col-sm-6" @bind="editModel.MaxAttempts" />
                        </div>
                        <label class="col-sm-2 col-form-label col-form-label-sm">@(userConfig.GetText("cycles_between")):</label>
                        <div class="col-sm-2" data-toggle="tooltip" title="@(userConfig.PureLine("H5593c"))">
                            <input type="number" class="col-sm-6" @bind="editModel.CyclesBetweenAttempts" />
                        </div>
                    </div>
                    @if (editModel.IsTufinSecureChange())
                    {
                        <label for="cbx_ext_ticket_lookup_id" class="col-sm-3 col-form-label col-form-label-sm">@(userConfig.GetText("ext_ticket_lookup_id")):</label>
                        <div class="col-sm-2">
                            <input id="cbx_ext_ticket_lookup_id" type="checkbox" class="w-100" @bind="editModel.LookupRequesterId">
                        </div>
                    }
                    <br>
                    <TabSet WholeWidth="false" DarkMode="false" KeepPanelsAlive="false">
                        @{
                            int pos = 0;
                        }
                        @foreach (var template in editModel.Templates)
                        {
                            <Tab Title="@(template.TaskType)" Position=pos++>
                                <ExtTicketTemplates Template="template" IsBuiltIn="selectedType.IsBuiltIn" />
                            </Tab>
                        }
                        <Tab Title="  +  " Position=pos>
                            <div class="form-group row mt-2" data-toggle="tooltip" title="@(userConfig.PureLine("H5599"))">
                                <label class="col-sm-3 col-form-label col-form-label-sm">@(userConfig.GetText("task_type")):</label>
                                <div class="col-sm-4">
                                    <Dropdown ElementType="string" @bind-SelectedElement="newTemplate.TaskType" Elements="GetAvailableTaskTypesForNewTemplate()" />
                                </div>
                            </div>
                            <ExtTicketTemplates Template="newTemplate" IsBuiltIn="selectedType.IsBuiltIn" />
                        </Tab>
                    </TabSet>
                </div>
                <hr />
            }

        </Body>
        <Footer>
            <div class="btn-group">
                <AuthorizeView Roles="@Roles.Admin">
                    <Authorized>
                        <button type="button" class="btn btn-sm btn-primary" @onclick="Save">@(userConfig.GetText("save"))</button>
                    </Authorized>
                    <NotAuthorized>
                        <button type="button" class="btn btn-sm btn-primary" disabled>@(userConfig.GetText("save"))</button>
                    </NotAuthorized>
                </AuthorizeView>
                <button type="button" class="btn btn-sm btn-secondary" @onclick="CancelEdit">@(DisplayService.DisplayButton(userConfig, "cancel", Icons.Cancel))</button>
            </div>
        </Footer>

    </PopUp>

    <ConfirmDelete @bind-Display="DeleteExternalTicketSystemMode" PerformAction="DeleteExternalTicketSystem" Title="@userConfig.GetText("delete_ext_ticket_system")" DeleteMessage="@(userConfig.GetText("delete_ext_ticket_system_confirm") + " " + externalTicketSystemToDelete.Name + "?")" />
}
else
{
    <Loading />
}

@code
{
    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;
    private ConfigData? configData;
    private bool InitComplete = false;

    private ExternalTicketSystem? curExternalTicketSystem = null;
    private ExternalTicketSystem editModel = new();
    private bool editMode = false;
    private bool DeleteExternalTicketSystemMode = false;
    private ExternalTicketSystem externalTicketSystemToDelete = new();

    private List<ExternalTicketSystem> extTicketSystems = [];
    private DateTime extReqStartDate = DateTime.Today;
    private DateTime extReqStartTime = DateTime.Now.AddSeconds(-DateTime.Now.Second);
    private ExternalTicketTemplate newTemplate = new();
    private List<string> actTaskTypes = [];
    private readonly List<ExternalTicketSystemTypeDefinition> availableExternalTicketTypes = BuiltInExternalTicketSystemTypes.AllBuiltInTicketTypes.ToList();
    private ExternalTicketSystemTypeDefinition selectedType = BuiltInExternalTicketSystemTypes.GetById(BuiltInExternalTicketSystemTypes.GenericId);

    private List<ManagementFwConfigChangeState> fwConfigChangeManagementStates = new();


    protected override async Task OnInitializedAsync()
    {
        try
        {
            configData = await globalConfig.GetEditableConfig();
            extReqStartDate = extReqStartTime = configData.ExternalRequestStartAt;
            extTicketSystems = string.IsNullOrWhiteSpace(configData.ExtTicketSystems) ? new List<ExternalTicketSystem>()
                                                        : JsonSerializer.Deserialize<List<ExternalTicketSystem>>(configData.ExtTicketSystems)
                                                        ?? new List<ExternalTicketSystem>();

            List<Management> managements = await apiConnection.SendQueryAsync<List<Management>>(DeviceQueries.getUsedMgmDeviceTypes);

            foreach (Management management in managements)
            {
                DeviceType dbType = management.DeviceType;

                if (dbType == null || dbType.Id <= 0 || string.IsNullOrWhiteSpace(dbType.Name))
                {
                    continue;
                }

                if (availableExternalTicketTypes.All(type => type.Id != dbType.Id))
                {
                    availableExternalTicketTypes.Add(new ExternalTicketSystemTypeDefinition
                    {
                        Id = dbType.Id,
                        Name = dbType.Name,
                        Version = dbType.Version,
                        IsBuiltIn = false
                    });
                }
            }


            foreach (ExternalTicketSystem system in extTicketSystems.Where(system =>
                system.Templates.Count == 0 &&
                (!string.IsNullOrWhiteSpace(system.TicketTemplate) || !string.IsNullOrWhiteSpace(system.TasksTemplate))))
            {
                system.Templates.Add(new ExternalTicketTemplate
                {
                    TaskType = SCTaskType.AccessRequest.ToString(),
                    TicketTemplate = system.TicketTemplate,
                    TasksTemplate = system.TasksTemplate
                });
            }

            InitComplete = true;
        }
        catch (Exception exception)
        {
            extTicketSystems = [];
            DisplayMessageInUi(exception, userConfig.GetText("read_config"), userConfig.GetText("E5301"), false);
        }
    }

    private async Task Save()
    {
        try
        {
            if (configData == null)
            {
                throw new ArgumentException("Data saved before loaded. This should be impossible.");
            }

            AddNewTemplateIfNeeded();

            if (curExternalTicketSystem != null)
            {
                var system = extTicketSystems.First(x => x.Id == curExternalTicketSystem.Id);

                system.Name = editModel.Name;
                system.TypeId = editModel.TypeId;
                system.Url = editModel.Url;
                system.ResponseTimeout = editModel.ResponseTimeout;
                system.MaxAttempts = editModel.MaxAttempts;
                system.CyclesBetweenAttempts = editModel.CyclesBetweenAttempts;
                system.Authorization = selectedType.IsBuiltIn ? editModel.Authorization : "";
                system.LookupRequesterId = editModel.LookupRequesterId;
                system.Templates = editModel.Templates
                    .Select(t => new ExternalTicketTemplate
                    {
                        TaskType = t.TaskType,
                        TicketTemplate = t.TicketTemplate,
                        TasksTemplate = t.TasksTemplate,
                        ObjectTemplate = t.ObjectTemplate,
                        ObjectTemplateShort = t.ObjectTemplateShort,
                        IpTemplate = t.IpTemplate,
                        NwObjGroupTemplate = t.NwObjGroupTemplate,
                        ServiceTemplate = t.ServiceTemplate,
                        IcmpTemplate = t.IcmpTemplate,
                        IpProtocolTemplate = t.IpProtocolTemplate
                    })
                    .ToList();

                system.Sanitize();
            }
            else
            {
                editModel.Id = GetNextExternalTicketSystemId(extTicketSystems);
                editModel.Authorization = selectedType.IsBuiltIn ? editModel.Authorization : "";
                editModel.Sanitize();
                extTicketSystems.Add(editModel);
                curExternalTicketSystem = editModel;
            }

            configData.ExtTicketSystems = System.Text.Json.JsonSerializer.Serialize(extTicketSystems);
            await globalConfig.WriteToDatabase(configData, apiConnection);

            extTicketSystems = string.IsNullOrWhiteSpace(configData.ExtTicketSystems)
                ? new List<ExternalTicketSystem>()
                : JsonSerializer.Deserialize<List<ExternalTicketSystem>>(configData.ExtTicketSystems)
                ?? new List<ExternalTicketSystem>();


            StateHasChanged();

            DisplayMessageInUi(null, userConfig.GetText("ext_ticket_templates"), userConfig.GetText("U5301"), false);
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("ext_ticket_templates"), "", true);
        }
    }

    private int GetNextExternalTicketSystemId(List<ExternalTicketSystem> systems)
    {
        int maxSystemId = systems.Count > 0 ? systems.Max(s => s.Id) : 0;
        int maxReferencedId = GetMaxReferencedExternalTicketSystemId();

        return Math.Max(maxSystemId, maxReferencedId) + 1;
    }

    private int GetMaxReferencedExternalTicketSystemId()
    {
        if (string.IsNullOrWhiteSpace(configData?.FwConfigChangeMgmSettings))
        {
            return 0;
        }

        try
        {
            List<ManagementFwConfigChangeState> states =
                JsonSerializer.Deserialize<List<ManagementFwConfigChangeState>>(configData.FwConfigChangeMgmSettings)
                ?? new();

            return states
                .SelectMany(state => (state.SelectedChanges ?? new Dictionary<string, string>()).Values)
                .Select(value => int.TryParse(value, out int parsedId) ? parsedId : 0)
                .DefaultIfEmpty(0)
                .Max();
        }
        catch (JsonException)
        {
            return 0;
        }
    }

    private void AddNewTemplateIfNeeded()
    {
        if ((!string.IsNullOrWhiteSpace(newTemplate.TicketTemplate) || !string.IsNullOrWhiteSpace(newTemplate.TasksTemplate))
        && !string.IsNullOrWhiteSpace(newTemplate.TaskType) && editModel.Templates.All(template => template.TaskType != newTemplate.TaskType))
        {
            editModel.Templates.Add(new ExternalTicketTemplate
            {
                TaskType = newTemplate.TaskType,
                TicketTemplate = newTemplate.TicketTemplate,
                TasksTemplate = newTemplate.TasksTemplate,
                ObjectTemplate = newTemplate.ObjectTemplate,
                ObjectTemplateShort = newTemplate.ObjectTemplateShort,
                IpTemplate = newTemplate.IpTemplate,
                NwObjGroupTemplate = newTemplate.NwObjGroupTemplate,
                ServiceTemplate = newTemplate.ServiceTemplate,
                IcmpTemplate = newTemplate.IcmpTemplate,
                IpProtocolTemplate = newTemplate.IpProtocolTemplate
            });
        }

        newTemplate = new ExternalTicketTemplate();
        SyncNewTemplateTaskType();
    }

    private async Task SaveServiceData()
    {
        if (configData != null)
        {
            configData.ExternalRequestStartAt = extReqStartDate.Date.Add(extReqStartTime.TimeOfDay);
            await globalConfig.WriteToDatabase(configData, apiConnection);
            DisplayMessageInUi(null, userConfig.GetText("ext_ticket_templates"), userConfig.GetText("U5301"), false);
        }
    }

    private void InitTaskTypeList()
    {
        actTaskTypes = Enum.GetNames(typeof(SCTaskType)).ToList();
        SyncNewTemplateTaskType();
    }

    private void AddExternalTicketSystem()
    {
        curExternalTicketSystem = null;
        editModel = new ExternalTicketSystem
        {
            TypeId = BuiltInExternalTicketSystemTypes.GenericId,
            Templates = new()
        };

        newTemplate = new ExternalTicketTemplate();
        selectedType = ResolveSelectedType(editModel.TypeId);
        InitTaskTypeList();
        editMode = true;
    }

    private void EditExternalTicketSystem(ExternalTicketSystem externalTicketSystem)
    {
        curExternalTicketSystem = externalTicketSystem;
        editModel = Clone(externalTicketSystem);
        newTemplate = new ExternalTicketTemplate();
        selectedType = ResolveSelectedType(editModel.TypeId);
        InitTaskTypeList();
        editMode = true;
    }

    private void RequestDeleteExternalTicketSystem(ExternalTicketSystem externalTicketSystem)
    {
        externalTicketSystemToDelete = externalTicketSystem;
        DeleteExternalTicketSystemMode = true;
    }

    private async Task DeleteExternalTicketSystem()
    {
        if (configData != null)
        {
            try
            {
                Log.WriteAudit(
                    Title: $"External Ticket System Settings",
                    Text: $"Deleted External Ticket System: {externalTicketSystemToDelete.Name}");

                CleanupFwConfigChangeReferences(externalTicketSystemToDelete.Id);

                extTicketSystems.Remove(externalTicketSystemToDelete);
                configData.ExtTicketSystems = JsonSerializer.Serialize(extTicketSystems);
                configData.FwConfigChangeMgmSettings = JsonSerializer.Serialize(fwConfigChangeManagementStates);

                await globalConfig.WriteToDatabase(configData, apiConnection);
                extTicketSystems = string.IsNullOrWhiteSpace(configData.ExtTicketSystems)
                       ? new List<ExternalTicketSystem>()
                       : JsonSerializer.Deserialize<List<ExternalTicketSystem>>(configData.ExtTicketSystems)
                       ?? new List<ExternalTicketSystem>();

                DeleteExternalTicketSystemMode = false;
                externalTicketSystemToDelete = new();
                StateHasChanged();
            }
            catch (Exception exception)
            {
                DisplayMessageInUi(exception, userConfig.GetText("delete_ext_ticket_system"), "", true);
            }
        }
    }

    private void CleanupFwConfigChangeReferences(int deletedSystemId)
    {
        if (string.IsNullOrWhiteSpace(configData?.FwConfigChangeMgmSettings))
        {
            fwConfigChangeManagementStates = new();
            return;
        }

        try
        {
            fwConfigChangeManagementStates =
                JsonSerializer.Deserialize<List<ManagementFwConfigChangeState>>(configData.FwConfigChangeMgmSettings)
                ?? new();
        }
        catch (JsonException)
        {
            fwConfigChangeManagementStates = new();
            return;
        }

        string deletedId = deletedSystemId.ToString();

        foreach (ManagementFwConfigChangeState state in fwConfigChangeManagementStates)
        {
            state.SelectedChanges ??= new Dictionary<string, string>();

            foreach (string change in state.SelectedChanges.Keys.ToList())
            {
                if (state.SelectedChanges[change] == deletedId)
                {
                    state.SelectedChanges[change] = ManagementFwConfigChangeTargets.Disabled;
                }
            }
        }
    }

    private void CancelEdit()
    {
        curExternalTicketSystem = null;
        editMode = false;
        DeleteExternalTicketSystemMode = false;
        newTemplate = new ExternalTicketTemplate();

        editModel = new ExternalTicketSystem();
        curExternalTicketSystem = null;
    }

    private ExternalTicketSystem Clone(ExternalTicketSystem s)
    {
        return new ExternalTicketSystem
        {
            Id = s.Id,
            Name = s.Name,
            TypeId = s.TypeId,
            Url = s.Url,
            ResponseTimeout = s.ResponseTimeout,
            MaxAttempts = s.MaxAttempts,
            CyclesBetweenAttempts = s.CyclesBetweenAttempts,
            Authorization = s.Authorization,
            LookupRequesterId = s.LookupRequesterId,
            Templates = s.Templates
                    .Select(t => new ExternalTicketTemplate
                    {
                        TaskType = t.TaskType,
                        TicketTemplate = t.TicketTemplate,
                        TasksTemplate = t.TasksTemplate,
                        ObjectTemplate = t.ObjectTemplate,
                        ObjectTemplateShort = t.ObjectTemplateShort,
                        IpTemplate = t.IpTemplate,
                        NwObjGroupTemplate = t.NwObjGroupTemplate,
                        ServiceTemplate = t.ServiceTemplate,
                        IcmpTemplate = t.IcmpTemplate,
                        IpProtocolTemplate = t.IpProtocolTemplate
                    })
                    .ToList(),
        };
    }

    private void OnTypeChanged(ExternalTicketSystemTypeDefinition type)
    {
        selectedType = type;
        editModel.TypeId = type.Id;
        InitTaskTypeList();
    }

    private ExternalTicketSystemTypeDefinition ResolveSelectedType(int typeId)
    {
        return availableExternalTicketTypes.FirstOrDefault(type => type.Id == typeId)
            ?? new ExternalTicketSystemTypeDefinition
            {
                Id = typeId,
                Name = typeId.ToString(),
                IsBuiltIn = false
            };
    }

    private string FormatExternalTicketSystemType(ExternalTicketSystem system)
    {
        ExternalTicketSystemTypeDefinition type = ResolveSelectedType(system.TypeId);
        return string.IsNullOrWhiteSpace(type.Version)
            ? type.Name
           : $"{type.Name} {type.Version}";
    }

    private IEnumerable<string> GetAvailableTaskTypesForNewTemplate()
    {
        return actTaskTypes
            .Where(taskType => editModel.Templates.All(template => template.TaskType != taskType));
    }

    private void SyncNewTemplateTaskType()
    {
        newTemplate.TaskType = GetAvailableTaskTypesForNewTemplate().FirstOrDefault() ?? "";
    }
}
