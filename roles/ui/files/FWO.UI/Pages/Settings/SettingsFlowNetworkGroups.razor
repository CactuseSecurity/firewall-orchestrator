@page "/settings/flows/networkgroups"

@using FWO.Api.Client.Queries
@using FWO.Config.Api
@using FWO.Data
@using FWO.Data.Flow
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize(Roles = $"{Roles.Admin}")]

@inject ApiConnection apiConnection
@inject UserConfig userConfig

<InProgress Display="workInProgress" />

<div class="input-group">
    <h3>@(userConfig.GetText("network_groups"))</h3>
    <HelpLink Page="settings/flows/networkgroups" />
</div>

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mt-4 mb-2">
    <h4 class="mb-0">@(userConfig.GetText("duplicate_objects"))</h4>
</div>
<div class="text-muted small mb-2">@DuplicateGroups.Count</div>

@if (DuplicateGroups.Count > 0)
{
    <Table TableClass="table table-sm table-bordered th-bg-secondary table-responsive overflow-auto sticky-header"
           TableItem="FlowNwGroupDuplicateGroup"
           Items="DuplicateGroups"
           PageSize="10"
           ColumnReorder="true">
        <Column TableItem="FlowNwGroupDuplicateGroup" Title="@(userConfig.GetText("flow_object"))" Field="@(group => group.FlowNwGroupName)" Sortable="true" Filterable="true" Context="group">
            <Template>
                <div>@($"{group.FlowNwGroupName} (#{group.FlowNwGroupId})")</div>
                <div class="text-muted small">@BuildFlowNwGroupTechnicalDetails(group.FlowNwGroupId)</div>
            </Template>
        </Column>
        <Column TableItem="FlowNwGroupDuplicateGroup" Title="@(userConfig.GetText("management"))" Field="@(group => group.ManagementName)" Sortable="true" Filterable="true" />
        <Column TableItem="FlowNwGroupDuplicateGroup" Title="@(userConfig.GetText("objects"))" Field="@(group => group.Objects.Count)" Sortable="true" Filterable="false" Context="group">
            <Template>
                @FlowAdminHelper.FormatDuplicateObjectSummary(group.Objects)
            </Template>
        </Column>
        <Column TableItem="FlowNwGroupDuplicateGroup" Title="@(userConfig.GetText("actions"))" Field="@(group => group.ManagementId)" Sortable="false" Filterable="false" Context="group">
            <Template>
                <button type="button" class="btn btn-sm btn-warning" @onclick:stopPropagation="true" @onclick="() => OpenDuplicateResolver(group)">
                    @(DisplayService.DisplayButton(userConfig, "select", Icons.Select))
                </button>
            </Template>
        </Column>
        <Pager ShowPageNumber="true" ShowTotalCount="true" />
    </Table>
}
else
{
    <div class="text-muted small mb-3">@(userConfig.GetText("no_duplicate_conflicts"))</div>
}

<FlowObjectTable TItem="FlowNwGroup"
                 FilteredItems="FilteredFlowNwGroups"
                 FilteredCount="FilteredFlowNwGroups.Count"
                 TotalCount="flowNwGroups.Count"
                 PageSize="25"
                 SearchLabel="@(userConfig.GetText("search_name"))"
                 @bind-SearchText="groupSearchText">
    <ChildContent>
        <Column TableItem="FlowNwGroup" Title="@(userConfig.GetText("actions"))" Field="@(nwGroup => nwGroup.Id)" Sortable="false" Filterable="false" Context="nwGroup">
            <Template>
                <button type="button" class="btn btn-sm btn-warning" @onclick="() => EditNwGroup(nwGroup)">
                    @(DisplayService.DisplayButton(userConfig, "edit", Icons.Edit))
                </button>
            </Template>
        </Column>
        <Column TableItem="FlowNwGroup" Title="@(userConfig.GetText("id"))" Field="@(nwGroup => nwGroup.Id)" Sortable="true" Filterable="true" />
        <Column TableItem="FlowNwGroup" Title="@(userConfig.GetText("name"))" Field="@(nwGroup => nwGroup.Name)" Sortable="true" Filterable="true" />
        <Column TableItem="FlowNwGroup" Title="@(userConfig.GetText("state"))" Field="@(nwGroup => nwGroup.State)" Sortable="true" Filterable="true" />
        <Column TableItem="FlowNwGroup" Title="@(userConfig.GetText("show_in_request_module"))" Field="@(nwGroup => nwGroup.ShowInRequestModule)" Sortable="true" Context="nwGroup">
            <Template>
                @nwGroup.ShowInRequestModule.ShowAsHtml()
            </Template>
        </Column>
        <Column TableItem="FlowNwGroup" Title="@(userConfig.GetText("objects"))" Field="@(nwGroup => nwGroup.Id)" Sortable="false" Filterable="false" Context="nwGroup">
            <Template>
                @(nwGroup.Objects?.Count ?? 0)
            </Template>
        </Column>
        <Pager ShowPageNumber="true" ShowTotalCount="true" />
    </ChildContent>
</FlowObjectTable>

<PopUp Title="@(userConfig.GetText("edit_flow_object"))" Show="@EditMode" Size=PopupSize.Small OnClose="CloseEditor">
    <Body>
        @if (EditMode)
        {
            <form onsubmit="return false">
                <div class="form-group row">
                    <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("id")):</label>
                    <label class="col-sm-8 col-form-label col-form-label-sm">@EditFlowNwGroup.Id</label>
                </div>
                <div class="form-group row mt-2">
                    <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("name")):</label>
                    <div class="col-sm-8">
                        <input type="text" class="form-control form-control-sm" @bind="EditFlowNwGroup.Name" />
                    </div>
                </div>
                <div class="form-check form-check-inline mt-3">
                    <input class="form-check-input" id="flowNwGroupShowInRequestModule" type="checkbox" @bind="EditFlowNwGroup.ShowInRequestModule">
                    <label class="form-check-label" for="flowNwGroupShowInRequestModule"><small>@(userConfig.GetText("show_in_request_module"))</small></label>
                </div>
            </form>
        }
    </Body>
    <Footer>
        <div class="btn-group">
            <button type="button" class="btn btn-sm btn-primary" @onclick="SaveNwGroup">@(DisplayService.DisplayButton(userConfig, "save", Icons.Save))</button>
            <button type="button" class="btn btn-sm btn-secondary" @onclick="CloseEditor">@(DisplayService.DisplayButton(userConfig, "cancel", Icons.Cancel))</button>
        </div>
    </Footer>
</PopUp>

<FlowDuplicateResolver TItem="NetworkObject"
                       Title="@(userConfig.GetText("duplicate_objects"))"
                       Show="@ResolveDuplicateMode"
                       Size=PopupSize.Auto
                       OnClose="CloseDuplicateResolver"
                       OnResolve="ResolveDuplicateMapping"
                       CanResolve="@(SelectedDuplicateObject != null)"
                       Items="@(SelectedDuplicateGroup?.Objects ?? [])"
                       PageSize="10"
                       TableRowClass="@(nwObject => nwObject == SelectedDuplicateObject ? "table-warning" : "")">
    <SummaryContent>
        @if (SelectedDuplicateGroup != null)
        {
            <div><span class="fw-bold">@(userConfig.GetText("flow_object")):</span> @SelectedDuplicateGroup.FlowNwGroupName (#@SelectedDuplicateGroup.FlowNwGroupId)</div>
            <div class="text-muted small">@BuildFlowNwGroupTechnicalDetails(SelectedDuplicateGroup.FlowNwGroupId)</div>
            <div><span class="fw-bold">@(userConfig.GetText("management")):</span> @SelectedDuplicateGroup.ManagementName</div>
        }
    </SummaryContent>
    <ChildContent>
        <Column TableItem="NetworkObject" Title="@(userConfig.GetText("uid"))" Field="@(nwObject => nwObject.Uid)" Sortable="true" Filterable="true" />
        <Column TableItem="NetworkObject" Title="@(userConfig.GetText("details"))" Field="@(nwObject => nwObject.Name)" Sortable="false" Filterable="false" Context="nwObject">
            <Template>
                <span class="d-inline-block rounded px-2 py-1 @(nwObject == SelectedDuplicateObject ? "bg-warning-subtle fw-bold" : "")">
                    @FlowAdminHelper.FormatNetworkObjectTechnicalDetails(nwObject)
                </span>
            </Template>
        </Column>
        <Column TableItem="NetworkObject" Title="@(userConfig.GetText("state"))" Field="@(nwObject => nwObject.FlowActive)" Sortable="true" Filterable="true" Context="nwObject">
            <Template>
                @nwObject.FlowActive.ShowAsHtml()
            </Template>
        </Column>
        <Column TableItem="NetworkObject" Title="@(userConfig.GetText("actions"))" Field="@(nwObject => nwObject.Id)" Sortable="false" Filterable="false" Context="nwObject">
            <Template>
                <button type="button" class="btn btn-sm @(nwObject == SelectedDuplicateObject ? "btn-success" : "btn-outline-primary")" @onclick:stopPropagation="true" @onclick="() => SelectDuplicateObject(nwObject)">
                    @(DisplayService.DisplayButton(userConfig, "select", Icons.Select))
                </button>
            </Template>
        </Column>
        <Pager ShowPageNumber="true" ShowTotalCount="true" />
    </ChildContent>
</FlowDuplicateResolver>

@code
{
    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;

    private List<FlowNwGroup> flowNwGroups = [];
    private List<Management> selectableManagements = [];
    private List<Management> customObjectManagements = [];
    private FlowNwGroupDuplicateGroup? SelectedDuplicateGroup;
    private NetworkObject? SelectedDuplicateObject;
    private bool workInProgress = false;
    private bool EditMode = false;
    private bool ResolveDuplicateMode = false;
    private string groupSearchText = "";
    private FlowNwGroup EditFlowNwGroup = new();

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
    }

    private async Task Refresh()
    {
        try
        {
            workInProgress = true;
            StateHasChanged();

            flowNwGroups = await apiConnection.SendQueryAsync<List<FlowNwGroup>>(FlowQueries.getFlowAddressGroups) ?? [];
            selectableManagements = await apiConnection.SendQueryAsync<List<Management>>(FlowQueries.getFlowSelectableManagements) ?? [];

            List<int> managementIds = [.. selectableManagements.Select(management => management.Id)];
            customObjectManagements = managementIds.Count == 0
                ? []
                : await apiConnection.SendQueryAsync<List<Management>>(FlowQueries.getFlowCustomObjectCandidates, new
                {
                    management_id = managementIds
                }) ?? [];

            workInProgress = false;
        }
        catch (Exception exception)
        {
            workInProgress = false;
            DisplayMessageInUi(exception, userConfig.GetText("network_groups"), "", true);
        }

        StateHasChanged();
    }

    private List<FlowNwGroupDuplicateGroup> DuplicateGroups =>
        FlowAdminHelper.BuildDuplicateGroups(flowNwGroups, customObjectManagements);

    private List<FlowNwGroup> FilteredFlowNwGroups =>
        string.IsNullOrWhiteSpace(groupSearchText)
            ? flowNwGroups
            : [.. flowNwGroups.Where(nwGroup => BuildFlowNwGroupSearchText(nwGroup)
                .Contains(groupSearchText.Trim().ToLowerInvariant(), StringComparison.OrdinalIgnoreCase))];

    private void EditNwGroup(FlowNwGroup nwGroup)
    {
        EditFlowNwGroup = new FlowNwGroup
        {
            Id = nwGroup.Id,
            Name = nwGroup.Name,
            State = nwGroup.State,
            RemovedDate = nwGroup.RemovedDate,
            ShowInRequestModule = nwGroup.ShowInRequestModule,
            NwGroupMembers = [.. nwGroup.NwGroupMembers]
        };
        EditMode = true;
    }

    private void CloseEditor()
    {
        EditMode = false;
    }

    private void OpenDuplicateResolver(FlowNwGroupDuplicateGroup group)
    {
        SelectedDuplicateGroup = group;
        SelectedDuplicateObject = group.Objects.FirstOrDefault();
        ResolveDuplicateMode = true;
    }

    private void CloseDuplicateResolver()
    {
        ResolveDuplicateMode = false;
        SelectedDuplicateGroup = null;
        SelectedDuplicateObject = null;
    }

    private void SelectDuplicateObject(NetworkObject nwObject)
    {
        SelectedDuplicateObject = nwObject;
    }

    private async Task ResolveDuplicateMapping()
    {
        try
        {
            if (SelectedDuplicateGroup == null || SelectedDuplicateObject == null)
            {
                return;
            }

            workInProgress = true;
            StateHasChanged();

            foreach (NetworkObject candidate in SelectedDuplicateGroup.Objects)
            {
                await apiConnection.SendQueryAsync<NetworkObject>(FlowMutations.upsertFlowNwGroupMapping, new
                {
                    objId = candidate.Id,
                    flowNwgrpId = SelectedDuplicateGroup.FlowNwGroupId,
                    activeOnMgm = candidate.Id == SelectedDuplicateObject.Id
                });
            }

            CloseDuplicateResolver();
            await Refresh();
            workInProgress = false;
        }
        catch (Exception exception)
        {
            workInProgress = false;
            DisplayMessageInUi(exception, userConfig.GetText("duplicate_objects"), "", true);
        }

        StateHasChanged();
    }

    private async Task SaveNwGroup()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(EditFlowNwGroup.Name))
            {
                DisplayMessageInUi(null, userConfig.GetText("edit_flow_object"), userConfig.GetText("E5102"), true);
                return;
            }

            workInProgress = true;
            StateHasChanged();

            await apiConnection.SendQueryAsync<FlowNwGroup>(FlowMutations.updateFlowNwGroup, new
            {
                nwgroupId = EditFlowNwGroup.Id,
                name = EditFlowNwGroup.Name.Trim(),
                showInRequestModule = EditFlowNwGroup.ShowInRequestModule
            });

            EditMode = false;
            await Refresh();
            workInProgress = false;
        }
        catch (Exception exception)
        {
            workInProgress = false;
            DisplayMessageInUi(exception, userConfig.GetText("edit_flow_object"), "", true);
        }

        StateHasChanged();
    }

    private static string BuildFlowNwGroupSearchText(FlowNwGroup nwGroup)
    {
        return string.Join(' ', [
            nwGroup.Id.ToString(),
            nwGroup.Name ?? "",
            nwGroup.State,
            nwGroup.ShowInRequestModule.ToString(),
            nwGroup.NwGroupMembers.Count.ToString()
        ]).ToLowerInvariant();
    }

    private string BuildFlowNwGroupTechnicalDetails(long flowNwGroupId)
    {
        FlowNwGroup? flowNwGroup = flowNwGroups.FirstOrDefault(item => item.Id == flowNwGroupId);
        string details = flowNwGroup == null ? "" : FlowAdminHelper.FormatFlowNwGroupTechnicalDetails(flowNwGroup);
        return string.IsNullOrWhiteSpace(details) ? "-" : details;
    }
}
