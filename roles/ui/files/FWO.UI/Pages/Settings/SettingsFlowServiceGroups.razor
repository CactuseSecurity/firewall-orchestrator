@page "/settings/flows/servicegroups"

@using FWO.Api.Client.Queries
@using FWO.Config.Api
@using FWO.Data
@using FWO.Data.Flow
@using FWO.Middleware.Client
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize(Roles = $"{Roles.Admin}")]

@inject ApiConnection apiConnection
@inject UserConfig userConfig

<div class="input-group">
    <h3>@(userConfig.GetText("service_groups"))</h3>
    <HelpLink Page="settings/flows/servicegroups"/>
</div>

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
    <div class="input-group input-group-sm cwidth-400">
        <span class="input-group-text">@(userConfig.GetText("search_name"))</span>
        <input type="text" class="form-control" @bind="groupSearchText" @bind:event="oninput" />
        @if (!string.IsNullOrWhiteSpace(groupSearchText))
        {
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ClearGroupSearch">
                @(userConfig.GetText("cancel"))
            </button>
        }
    </div>
</div>

<hr class="my-4" />
<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
    <h4 class="mb-0">@(userConfig.GetText("duplicate_objects"))</h4>
</div>
<div class="text-muted small mb-2">
    @($"{DuplicateGroups.Count}")
</div>

@if (DuplicateGroups.Count > 0)
{
    <Table TableClass="table table-sm table-bordered th-bg-secondary table-responsive overflow-auto sticky-header"
           TableItem="FlowSvcGroupDuplicateGroup"
           Items="DuplicateGroups"
           PageSize="10"
           ColumnReorder="true">
        <Column TableItem="FlowSvcGroupDuplicateGroup" Title="@(userConfig.GetText("service_groups"))" Field="@(group => group.FlowSvcGroupName)" Sortable="true" Filterable="true" Context="group">
            <Template>
                @($"{group.FlowSvcGroupName} (#{group.FlowSvcGroupId})")
            </Template>
        </Column>
        <Column TableItem="FlowSvcGroupDuplicateGroup" Title="@(userConfig.GetText("services"))" Field="@(group => group.ServiceCount)" Sortable="true" Filterable="false" Context="group">
            <Template>
                @BuildServiceSummary(group.Services)
            </Template>
        </Column>
        <Column TableItem="FlowSvcGroupDuplicateGroup" Title="@(userConfig.GetText("actions"))" Field="@(group => group.ManagementId)" Sortable="false" Filterable="false" Context="group">
            <Template>
                <button type="button" class="btn btn-sm btn-warning" @onclick="() => OpenDuplicateResolver(group)">
                    @(userConfig.GetText("select"))
                </button>
            </Template>
        </Column>
        <Pager ShowPageNumber="true" ShowTotalCount="true" />
    </Table>
}
else
{
    <div class="text-muted small mb-3">@(userConfig.GetText("no_duplicate_conflicts"))</div>
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mt-4 mb-2">
    <h4 class="mb-0">@(userConfig.GetText("objects"))</h4>
</div>

<div class="text-muted small mb-2">
    @($"{FilteredFlowSvcGroups.Count} / {svcGroups.Count}")
</div>

<Table TableClass="table table-sm table-bordered th-bg-secondary table-responsive overflow-auto sticky-header"
       TableItem="FlowSvcGroup"
       Items="FilteredFlowSvcGroups"
       PageSize="25"
       ColumnReorder="true">
    <Column TableItem="FlowSvcGroup" Title="@(userConfig.GetText("actions"))" Field="@(svcGroup => svcGroup.Id)" Sortable="false" Filterable="false" Context="svcGroup">
        <Template>
            <button type="button" class="btn btn-sm btn-warning" @onclick="() => EditSvcGroup(svcGroup)">
                @(userConfig.GetText("edit"))
            </button>
        </Template>
    </Column>
    <Column TableItem="FlowSvcGroup" Title="@(userConfig.GetText("id"))" Field="@(svcGroup => svcGroup.Id)" Sortable="true" Filterable="true" />
    <Column TableItem="FlowSvcGroup" Title="@(userConfig.GetText("name"))" Field="@(svcGroup => svcGroup.Name)" Sortable="true" Filterable="true" />
    <Column TableItem="FlowSvcGroup" Title="@(userConfig.GetText("state"))" Field="@(svcGroup => svcGroup.State)" Sortable="true" Filterable="true" />
    <Column TableItem="FlowSvcGroup" Title="@(userConfig.GetText("show_in_request_module"))" Field="@(svcGroup => svcGroup.ShowInRequestModule)" Sortable="true" Context="svcGroup">
        <Template>
            @svcGroup.ShowInRequestModule.ShowAsHtml()
        </Template>
    </Column>
    <Column TableItem="FlowSvcGroup" Title="@(userConfig.GetText("members"))" Field="@(svcGroup => svcGroup.ServiceCount)" Sortable="true" Filterable="false" Context="svcGroup">
        <Template>
            @BuildServiceSummary(svcGroup.Services)
        </Template>
    </Column>
    <Pager ShowPageNumber="true" ShowTotalCount="true" />
</Table>

<PopUp Title="@(userConfig.GetText("edit_flow_object"))" Show="@EditMode" Size=PopupSize.Small OnClose="CloseEditor">
    <Body>
        @if (EditMode)
        {
            <form onsubmit="return false">
                <div class="form-group row">
                    <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("id")):</label>
                    <label class="col-sm-8 col-form-label col-form-label-sm">@EditFlowSvcGroup.Id</label>
                </div>
                <div class="form-group row mt-2">
                    <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("name")):</label>
                    <div class="col-sm-8">
                        <input type="text" class="form-control form-control-sm" @bind="EditFlowSvcGroup.Name" />
                    </div>
                </div>
                <div class="form-check form-check-inline mt-3">
                    <input class="form-check-input" id="svcGroupShowInRequestModule" type="checkbox" @bind="EditFlowSvcGroup.ShowInRequestModule">
                    <label class="form-check-label" for="svcGroupShowInRequestModule"><small>@(userConfig.GetText("show_in_request_module"))</small></label>
                </div>
            </form>
        }
    </Body>
    <Footer>
        <div class="btn-group">
            <button type="button" class="btn btn-sm btn-primary" @onclick="SaveSvcGroup">@(userConfig.GetText("save"))</button>
            <button type="button" class="btn btn-sm btn-secondary" @onclick="CloseEditor">@(userConfig.GetText("cancel"))</button>
        </div>
    </Footer>
</PopUp>

<PopUp Title="@(userConfig.GetText("duplicate_objects"))" Show="@ResolveDuplicateMode" Size=PopupSize.Auto OnClose="CloseDuplicateResolver">
    <Body>
        @if (SelectedDuplicateGroup != null)
        {
            <div class="mb-2">
                <div><span class="fw-bold">@(userConfig.GetText("service_groups")):</span> @SelectedDuplicateGroup.FlowSvcGroupName (#@SelectedDuplicateGroup.FlowSvcGroupId)</div>
                <div><span class="fw-bold">@(userConfig.GetText("management")):</span> @SelectedDuplicateGroup.ManagementName</div>
            </div>
            <Table TableClass="table table-sm table-bordered th-bg-secondary table-responsive overflow-auto sticky-header"
                   TableItem="NetworkService"
                   Items="SelectedDuplicateGroup.Services"
                   PageSize="10"
                   ColumnReorder="true">
                <Column TableItem="NetworkService" Title="@(userConfig.GetText("id"))" Field="@(svcObject => svcObject.Id)" Sortable="true" Filterable="true" />
                <Column TableItem="NetworkService" Title="@(userConfig.GetText("name"))" Field="@(svcObject => svcObject.Name)" Sortable="true" Filterable="true" Context="svcObject">
                    <Template>
                        <span class="d-inline-block rounded px-2 py-1 @(svcObject == SelectedDuplicateService ? "bg-warning-subtle fw-bold" : "")">
                            @DisplayBase.DisplayService(svcObject, false)
                        </span>
                    </Template>
                </Column>
                <Column TableItem="NetworkService" Title="@(userConfig.GetText("state"))" Field="@(svcObject => svcObject.FlowActive)" Sortable="true" Filterable="true" Context="svcObject">
                    <Template>
                        @svcObject.FlowActive.ShowAsHtml()
                    </Template>
                </Column>
                <Column TableItem="NetworkService" Title="@(userConfig.GetText("actions"))" Field="@(svcObject => svcObject.Id)" Sortable="false" Filterable="false" Context="svcObject">
                    <Template>
                        <button type="button" class="btn btn-sm @(svcObject == SelectedDuplicateService ? "btn-success" : "btn-outline-primary")" @onclick="() => SelectDuplicateService(svcObject)">
                            @(userConfig.GetText("select"))
                        </button>
                    </Template>
                </Column>
                <Pager ShowPageNumber="true" ShowTotalCount="true" />
            </Table>
        }
    </Body>
    <Footer>
        <div class="btn-group">
            <button type="button" class="btn btn-sm btn-warning" disabled="@(SelectedDuplicateService == null)" @onclick="ResolveDuplicateMapping">
                @(userConfig.GetText("save"))
            </button>
            <button type="button" class="btn btn-sm btn-secondary" @onclick="CloseDuplicateResolver">
                @(userConfig.GetText("cancel"))
            </button>
        </div>
    </Footer>
</PopUp>

<InProgress Display="workInProgress"/>

@code
{
    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;

    [CascadingParameter]
    private Task<AuthenticationState>? authenticationStateTask { get; set; }

    private List<FlowSvcGroup> svcGroups = [];
    private List<Management> selectableManagements = [];
    private List<Management> candidateManagements = [];
    private string groupSearchText = "";
    private bool workInProgress;
    private bool EditMode;
    private bool ResolveDuplicateMode;
    private FlowSvcGroup EditFlowSvcGroup = new();
    private FlowSvcGroupDuplicateGroup? SelectedDuplicateGroup;
    private NetworkService? SelectedDuplicateService;

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
    }

    private async Task Refresh()
    {
        try
        {
            workInProgress = true;
            StateHasChanged();

            apiConnection.SetProperRole(authenticationStateTask!.Result.User, [Roles.Admin]);
            selectableManagements = await apiConnection.SendQueryAsync<List<Management>>(FlowQueries.getFlowSelectableManagements);
            svcGroups = await apiConnection.SendQueryAsync<List<FlowSvcGroup>>(FlowQueries.getFlowSvcGroupCatalog);

            List<int> managementIds = [.. selectableManagements.Select(management => management.Id)];
            candidateManagements = managementIds.Count == 0
                ? []
                : await apiConnection.SendQueryAsync<List<Management>>(FlowQueries.getFlowSvcGroupCandidates, new
                {
                    management_id = managementIds
                });

            workInProgress = false;
        }
        catch (Exception exception)
        {
            workInProgress = false;
            DisplayMessageInUi(exception, userConfig.GetText("service_groups"), "", true);
        }

        StateHasChanged();
    }

    private List<FlowSvcGroup> FilteredFlowSvcGroups =>
        string.IsNullOrWhiteSpace(groupSearchText)
            ? svcGroups
            : [.. svcGroups.Where(svcGroup =>
                BuildSearchText(svcGroup).Contains(groupSearchText.Trim(), StringComparison.OrdinalIgnoreCase))];

    private List<FlowSvcGroupDuplicateGroup> DuplicateGroups =>
        BuildDuplicateGroups();

    private void ClearGroupSearch()
    {
        groupSearchText = "";
    }

    private void EditSvcGroup(FlowSvcGroup svcGroup)
    {
        EditFlowSvcGroup = new FlowSvcGroup
        {
            Id = svcGroup.Id,
            Name = svcGroup.Name,
            Hash = svcGroup.Hash,
            State = svcGroup.State,
            RemovedDate = svcGroup.RemovedDate,
            ShowInRequestModule = svcGroup.ShowInRequestModule
        };
        EditMode = true;
    }

    private void CloseEditor()
    {
        EditMode = false;
    }

    private void OpenDuplicateResolver(FlowSvcGroupDuplicateGroup group)
    {
        SelectedDuplicateGroup = group;
        SelectedDuplicateService = group.Services.FirstOrDefault();
        ResolveDuplicateMode = true;
    }

    private void CloseDuplicateResolver()
    {
        ResolveDuplicateMode = false;
        SelectedDuplicateGroup = null;
        SelectedDuplicateService = null;
    }

    private void SelectDuplicateService(NetworkService svcObject)
    {
        SelectedDuplicateService = svcObject;
    }

    private async Task ResolveDuplicateMapping()
    {
        try
        {
            if (SelectedDuplicateGroup == null || SelectedDuplicateService == null)
            {
                return;
            }

            workInProgress = true;
            StateHasChanged();

            List<object> updates = [];
            foreach (NetworkService candidate in SelectedDuplicateGroup.Services)
            {
                updates.Add(new
                {
                    where = new { svc_id = new { _eq = candidate.Id } },
                    _set = new
                    {
                        flow_svcgrp_id = SelectedDuplicateGroup.FlowSvcGroupId,
                        flow_active = candidate.FlowServiceObjectId.HasValue
                            ? candidate.FlowActive
                            : candidate.Id == SelectedDuplicateService.Id
                    }
                });
            }

            await apiConnection.SendQueryAsync<MutationResult>(FlowQueries.updateServiceFlowMappings, new
            {
                updates
            });

            await Refresh();
            CloseDuplicateResolver();
            workInProgress = false;
        }
        catch (Exception exception)
        {
            workInProgress = false;
            DisplayMessageInUi(exception, userConfig.GetText("duplicate_objects"), "", true);
        }

        StateHasChanged();
    }

    private async Task SaveSvcGroup()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(EditFlowSvcGroup.Name))
            {
                DisplayMessageInUi(null, userConfig.GetText("edit_flow_object"), userConfig.GetText("E5102"), true);
                return;
            }

            workInProgress = true;
            StateHasChanged();

            FlowSvcGroup updatedObject = await apiConnection.SendQueryAsync<FlowSvcGroup>(FlowMutations.updateFlowSvcGroup, new
            {
                svcgroupId = EditFlowSvcGroup.Id,
                name = EditFlowSvcGroup.Name.Trim(),
                showInRequestModule = EditFlowSvcGroup.ShowInRequestModule
            });

            int objectIndex = svcGroups.FindIndex(flowGroup => flowGroup.Id == updatedObject.Id);
            if (objectIndex >= 0)
            {
                svcGroups[objectIndex] = updatedObject;
            }

            EditMode = false;
            workInProgress = false;
        }
        catch (Exception exception)
        {
            workInProgress = false;
            DisplayMessageInUi(exception, userConfig.GetText("edit_flow_object"), "", true);
        }

        StateHasChanged();
    }

    private List<FlowSvcGroupDuplicateGroup> BuildDuplicateGroups()
    {
        List<FlowSvcGroupDuplicateGroup> duplicateGroups = [];

        foreach (FlowSvcGroup flowGroup in svcGroups)
        {
            foreach (Management management in candidateManagements)
            {
                List<NetworkService> linkedServices = [.. management.Services.Where(service => service.FlowServiceGroupId == flowGroup.Id)];
                if (linkedServices.Count <= 1 || linkedServices.Any(service => service.FlowActive))
                {
                    continue;
                }

                duplicateGroups.Add(new FlowSvcGroupDuplicateGroup
                {
                    FlowSvcGroupId = flowGroup.Id,
                    FlowSvcGroupName = flowGroup.Name,
                    ManagementId = management.Id,
                    ManagementName = management.Name,
                    Services = [.. linkedServices
                        .OrderBy(service => service.Name ?? "", StringComparer.OrdinalIgnoreCase)
                        .ThenBy(service => service.Id)]
                });
            }
        }

        return [.. duplicateGroups
            .OrderBy(group => group.FlowSvcGroupName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(group => group.ManagementName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(group => group.FlowSvcGroupId)
            .ThenBy(group => group.ManagementId)];
    }

    private static string BuildSearchText(FlowSvcGroup svcGroup)
    {
        return string.Join(' ', [
            svcGroup.Id.ToString(),
            svcGroup.Name,
            svcGroup.State,
            svcGroup.ShowInRequestModule.ToString(),
            svcGroup.Services?.Count.ToString() ?? "0"
        ]);
    }

    private static string BuildServiceSummary(IEnumerable<NetworkService>? services)
    {
        return string.Join(", ", (services ?? []).Select(service => DisplayBase.DisplayService(service, false).ToString()));
    }

    private sealed class FlowSvcGroupDuplicateGroup
    {
        public long FlowSvcGroupId { get; set; }
        public string FlowSvcGroupName { get; set; } = "";
        public int ManagementId { get; set; }
        public string ManagementName { get; set; } = "";
        public List<NetworkService> Services { get; set; } = [];
        public int ServiceCount => Services.Count;
    }
}
