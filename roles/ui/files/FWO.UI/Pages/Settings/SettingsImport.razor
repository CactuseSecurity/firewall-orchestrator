@page "/settings/importer"
@using System.Text.Json
@using FWO.Services
@using FWO.Services.EventMediator.Events
@using FWO.Services.EventMediator.Interfaces
@attribute [Authorize(Roles = $"{Roles.Admin}, {Roles.Auditor}")]

@inject ApiConnection apiConnection
@inject GlobalConfig globalConfig
@inject UserConfig userConfig
@inject IEventMediator EventMediator

@implements IDisposable

<div class="input-group">
    <h3>@(userConfig.GetText("importer_settings"))</h3>
    <HelpLink Page="settings/importer" />
</div>
@(userConfig.GetText("U5311"))
<hr />

@if (configData != null)
{
    <form onsubmit="return false">
        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5496"))">
            <label class="col-form-label col-sm-4">@(userConfig.GetText("importSleepTime")):</label>
            <div class="col-sm-2">
                <input type="number" min="0" @bind="configData!.ImportSleepTime" />
            </div>
        </div>
        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5497"))">
            <label for="cbx_check_certificates" class="col-form-label col-sm-4">@(userConfig.GetText("importCheckCertificates")):</label>
            <div class="col-sm-1">
                <input id="cbx_check_certificates" type="checkbox" class="w-100" @bind="configData!.ImportCheckCertificates" />
            </div>
        </div>
        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5498"))">
            <label for="cbx_suppress_certificate_warnings" class="col-form-label col-sm-4">@(userConfig.GetText("importSuppressCertificateWarnings")):</label>
            <div class="col-sm-1">
                <input id="cbx_suppress_certificate_warnings" type="checkbox" class="w-100" @bind="configData!.ImportSuppressCertificateWarnings" />
            </div>
        </div>
        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5499"))">
            <label class="col-form-label col-sm-4">@(userConfig.GetText("fwApiElementsPerFetch")):</label>
            <div class="col-sm-2">
                <input type="number" min="0" @bind="configData!.FwApiElementsPerFetch" />
            </div>
        </div>
    </form>
    <hr />
    <h3>@(userConfig.GetText("custom_field_import_Settings"))</h3>
    <div class="form-group row mt-2 align-items-center">
        <label class="col-sm-4 col-form-label me-2" for="ownerMappingSourceDropdown">@(userConfig.GetText("source"))</label>
        <div class="col-sm-5">
            <Dropdown ElementType="OwnerMappingSourceStm?" ElementToString="GetOwnerMappingSourceText" SelectedElement="@SelectedOwnerMappingSource"
                      SelectedElementChanged="@(src => { SelectedOwnerMappingSource = src; StateHasChanged(); })" Elements="OwnerMappingSources" Nullable="true" id="ownerMappingSourceDropdown">
                <ElementTemplate Context="source">
                    @GetOwnerMappingSourceText(source)
                </ElementTemplate>
            </Dropdown>
        </div>
    </div>
    @if (SelectedOwnerMappingSource == OwnerMappingSourceStm.CustomField)
    {
        <div class="form-group row mb-4" data-toggle="tooltip" title="@(userConfig.PureLine("H5677"))">
            <label class="col-form-label col-sm-4">@userConfig.GetText("custom_field_Owner_key"):</label>
            <div class="col-sm-5">
                <EditList ElementType="string" Elements="OwnerKeys.ToArray()" ElementsToAdd="OwnerKeysToAdd"
                          ElementsToDelete="OwnerKeysToDelete" StdLayout="false">
                    <Display>
                        <div class="row">
                            <div class="col-sm-12 border bg-transparent">@context</div>
                        </div>
                    </Display>
                </EditList>
                <div class="row col-sm-12 mt-1">
                    <input type="text" class="col-sm-10" @bind="actOwnerKey" />
                    <button type="button" class="col-sm-2 btn btn-sm btn-primary" @onclick="AddOwnerKey"
                            @onclick:preventDefault>
                        @(DisplayService.DisplayButton(userConfig, "add", Icons.Add))
                    </button>
                </div>
            </div>
        </div>

        <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5678"))">
            <label class="col-form-label col-sm-4">@userConfig.GetText("custom_field_ChangeID_key"):</label>
            <div class="col-sm-5">
                <EditList ElementType="string" Elements="ChangeIdKeys.ToArray()" ElementsToAdd="ChangeIdsToAdd"
                          ElementsToDelete="ChangeIdsToDelete" StdLayout="false">
                    <Display>
                        <div class="row">
                            <div class="col-sm-12 border bg-transparent">@context</div>
                        </div>
                    </Display>
                </EditList>
                <div class="row col-sm-12 mt-1">
                    <input type="text" class="col-sm-10" @bind="actChangeIdKey" />
                    <button type="button" class="col-sm-2 btn btn-sm btn-primary" @onclick="AddChangeIdKey"
                            @onclick:preventDefault>
                        @(DisplayService.DisplayButton(userConfig, "add", Icons.Add))
                    </button>
                </div>
            </div>
        </div>
    }
    @if (SelectedOwnerMappingSource == OwnerMappingSourceStm.NameField)
    {
        <div class="form-group row mt-2 align-items-center" data-toggle="tooltip" title="@(userConfig.PureLine("H5648"))">
            <label class="col-sm-4 col-form-label me-2">@userConfig.GetText("modelledMarker"):</label>
            <div class="col-sm-5">
                <input type="text" class="form-control" @bind="actModelledMarker" />
            </div>
        </div>
    }
    <AuthorizeView Roles="@Roles.Admin">
        <Authorized>
            <button type="button" class="btn btn-sm btn-primary" @onclick="Save" @onclick:preventDefault>@(userConfig.GetText("save"))</button>
        </Authorized>
        <NotAuthorized>
            <button type="button" class="btn btn-sm btn-primary" disabled>@(userConfig.GetText("save"))</button>
        </NotAuthorized>
    </AuthorizeView>
}
else
{
    <Loading />
}



@code
{
    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;

    private ConfigData? configData;
    private List<OwnerMappingSourceStm?> OwnerMappingSources = [];
    private OwnerMappingSourceStm? SelectedOwnerMappingSource = null;
    private UpdateRuleOwnerMapping? updateOwnerRuleMappings;

    private string actOwnerKey = "";
    private List<string> OwnerKeys = [];
    private List<string> OwnerKeysToAdd = [];
    private List<string> OwnerKeysToDelete = [];

    private string actChangeIdKey = "";
    private List<string> ChangeIdKeys = [];
    private List<string> ChangeIdsToAdd = [];
    private List<string> ChangeIdsToDelete = [];
    private string actModelledMarker = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            updateOwnerRuleMappings = new UpdateRuleOwnerMapping(apiConnection, globalConfig);
            EventMediator.Subscribe<UpdateRuleOwnerMappingEvent>("UpdateOwnerRuleMappings", evt => _ = updateOwnerRuleMappings.HandleEvent(evt));
            configData = await globalConfig.GetEditableConfig();
            OwnerMappingSources = Enum.GetValues(typeof(OwnerMappingSourceStm))
                .Cast<OwnerMappingSourceStm>()
                .Where(oms => oms != OwnerMappingSourceStm.Manual)
                .Cast<OwnerMappingSourceStm?>()
                .ToList();

            if (Enum.IsDefined(typeof(OwnerMappingSourceStm), userConfig.OwnerSoruceMappingID))
            {
                SelectedOwnerMappingSource = (OwnerMappingSourceStm)userConfig.OwnerSoruceMappingID;
            }

            if (!string.IsNullOrWhiteSpace(userConfig.CustomFieldOwnerKey))
            {
                var json = userConfig.CustomFieldOwnerKey.Trim();

                if (json.StartsWith("[") && json.EndsWith("]"))
                {
                    OwnerKeys = JsonSerializer.Deserialize<string[]>(json)?.ToList() ?? new List<string>();
                }
                else
                {
                    OwnerKeys = new List<string> { json };
                }
            }

            if (!string.IsNullOrWhiteSpace(userConfig.CustomFieldChangeIdKey))
            {
                var json = userConfig.CustomFieldChangeIdKey.Trim();

                if (json.StartsWith("[") && json.EndsWith("]"))
                {
                    ChangeIdKeys = JsonSerializer.Deserialize<string[]>(json)?.ToList() ?? new List<string>();
                }
                else
                {
                    ChangeIdKeys = new List<string> { json };
                }
            }

            actModelledMarker = configData.ModModelledMarker ?? "";
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("read_config"), userConfig.GetText("E5301"), false);
        }
    }

    /// <summary>
    /// Triggers a full rule-owner mapping rebuild after mapping configuration changes were saved.
    /// </summary>
    private async Task<bool> TriggerFullRuleOwnerReinitialize()
    {
        var tcs = new TaskCompletionSource<bool>();
        var args = new UpdateRuleOwnerMappingEventArgs { isFullReInitialize = true, Completion = tcs };
        EventMediator.Publish("UpdateOwnerRuleMappings", new UpdateRuleOwnerMappingEvent(args));
        return await tcs.Task;
    }

    private async Task Save()
    {
        try
        {
            if (configData != null)
            {
                int oldSource = configData.OwnerSoruceMappingID;
                string oldOwnerKey = configData.CustomFieldOwnerKey ?? "";
                string oldChangeIdKey = configData.CustomFieldChangeIdKey ?? "";
                string oldModelledMarker = configData.ModModelledMarker ?? "";

                if (SelectedOwnerMappingSource == null)
                {
                    DisplayMessageInUi(null, userConfig.GetText("modelling_settings"), userConfig.GetText("E5504"), true);
                    return;
                }
                PrepareOwnerKeys();
                PrepareChangeIdKeys();
                if (SelectedOwnerMappingSource == OwnerMappingSourceStm.CustomField && !OwnerKeys.Any())
                {
                    DisplayMessageInUi(null, userConfig.GetText("modelling_settings"), userConfig.GetText("E5505"), true);
                    return;
                }

                configData.OwnerSoruceMappingID = (int)SelectedOwnerMappingSource.Value;
                configData.CustomFieldOwnerKey = JsonSerializer.Serialize(OwnerKeys);
                configData.CustomFieldChangeIdKey = JsonSerializer.Serialize(ChangeIdKeys);
                configData.ModModelledMarker = actModelledMarker;

                await globalConfig.WriteToDatabase(configData, apiConnection);

                if (ShouldTriggerRuleOwnerReinitialize(oldSource, oldOwnerKey, oldChangeIdKey, oldModelledMarker, configData))
                {
                    bool rebuildSuccess = await TriggerFullRuleOwnerReinitialize();
                    if (!rebuildSuccess)
                    {
                        DisplayMessageInUi(null, userConfig.GetText("owner_mapping"), userConfig.GetText("E5502"), true);
                        return;
                    }
                }

                DisplayMessageInUi(null, userConfig.GetText("change_default"), userConfig.GetText("U5301"), false);
            }
            else
            {
                throw new ArgumentException("Data saved before loaded. This should be impossible.");
            }
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("change_default"), "", true);
        }
    }

    private static bool ShouldTriggerRuleOwnerReinitialize(int oldSource, string oldOwnerKey, string oldChangeIdKey, string oldModelledMarker, ConfigData configData)
    {
        bool sourceChanged = oldSource != configData.OwnerSoruceMappingID;
        bool customFieldConfigChanged = oldOwnerKey != configData.CustomFieldOwnerKey || oldChangeIdKey != configData.CustomFieldChangeIdKey;
        bool nameFieldConfigChanged = oldModelledMarker != configData.ModModelledMarker;

        if (sourceChanged)
        {
            return true;
        }

        if (configData.OwnerSoruceMappingID == (int)OwnerMappingSourceStm.CustomField && customFieldConfigChanged)
        {
            return true;
        }

        return configData.OwnerSoruceMappingID == (int)OwnerMappingSourceStm.NameField && nameFieldConfigChanged;
    }

    private void AddOwnerKey()
    {
        if (actOwnerKey != "")
        {
            OwnerKeysToAdd.Add(actOwnerKey);
            actOwnerKey = "";
        }
    }

    private void PrepareOwnerKeys()
    {
        foreach (var key in OwnerKeysToDelete)
        {
            OwnerKeys.Remove(key);
        }
        foreach (var key in OwnerKeysToAdd)
        {
            OwnerKeys.Add(key);
        }
        OwnerKeysToDelete = [];
        OwnerKeysToAdd = [];
    }

    private void AddChangeIdKey()
    {
        if (actChangeIdKey != "")
        {
            ChangeIdsToAdd.Add(actChangeIdKey);
            actChangeIdKey = "";
        }
    }

    private void PrepareChangeIdKeys()
    {
        foreach (var key in ChangeIdsToDelete)
        {
            ChangeIdKeys.Remove(key);
        }
        foreach (var key in ChangeIdsToAdd)
        {
            ChangeIdKeys.Add(key);
        }
        ChangeIdsToDelete = [];
        ChangeIdsToAdd = [];
    }

    private string GetOwnerMappingSourceText(OwnerMappingSourceStm? source)
    {
        return userConfig.GetText(source?.ToString() ?? "");
    }

    public void Dispose()
    {
        EventMediator.Unsubscribe<UpdateRuleOwnerMappingEvent>("UpdateOwnerRuleMappings");
    }
}
