@using FWO.Data.Middleware
@using FWO.Config.Api.Data
@using FWO.Logging
@using FWO.Middleware.Client
@using FWO.Services.EventMediator.Events
@using FWO.Ui.Services
@using RestSharp
@using System
@using System.Linq
@using System.Net
@using FWO.Services.EventMediator.Interfaces
@using FWO.Services

@page "/settings/owners"
@attribute [Authorize(Roles = $"{Roles.Admin}, {Roles.Auditor}")]

@implements IDisposable
@inject ApiConnection apiConnection
@inject GlobalConfig globalConfig
@inject UserConfig userConfig
@inject MiddlewareClient middlewareClient
@inject IEventMediator EventMediator


@if(InitComplete)
{
    <div class="input-group">
        <h3>@(userConfig.GetText("owners"))</h3>
        <HelpLink Page="settings/owners"/>
    </div>
    @(userConfig.GetText("U5216"))
    <hr />
    <div class="form-group row mt-2 align-items-center">
        <label class="col-auto col-form-label me-2" for="ownerMappingSourceDropdown">@(userConfig.GetText("U5018"))</label>
        <div class="col-sm-2">
            <Dropdown ElementType="OwnerMappingSource" ElementToString="@(x => x.Name)" SelectedElement="@SelectedOwnerMappingSources"
                      SelectedElementChanged="@(src => { SelectedOwnerMappingSources = src; StateHasChanged(); })" Elements="OwnerMappingSources" Nullable="true" id="ownerMappingSourceDropdown">
                <ElementTemplate Context="source">
                    @source.Name
                </ElementTemplate>
            </Dropdown>
        </div>
        @if (SelectedOwnerMappingSources != null && SelectedOwnerMappingSources.Id == OwnerMappingSourceStm.CUSTOM_FIELD)
        {
            <div class="col-auto">
                <input type="text" class="form-control form-control-sm" placeholder="Custom Field key" @bind="OwnerMappingCustomFieldkey" />
            </div>                          
        }
        <div class="col-auto">
            <button type="button" class="btn btn-sm btn-primary" @onclick="SaveOwnerMappingSourceConfig" @onclick:preventDefault>@(userConfig.GetText("save"))</button>
        </div>
    </div>
    <div class="btn-group m-1">
        @if(userConfig.AllowManualOwnerAdmin)
        {
            <button type="button" class="btn btn-sm btn-success" @onclick="AddOwner">@(userConfig.GetText("add_owner"))</button>
        }
        <AuthorizeView Roles="@Roles.Admin" Context="ctx">
            <Authorized>
                @if (!OwnerMappingCalcInProgress)
                {
                    <button type="button" class="btn btn-sm btn-info" @onclick:preventDefault="true" @onclick="@(OwnerSourceImportNotifier)">@(userConfig.GetText("U5017"))</button>
                }
                else
                {
                    <Loading/>
                }
            </Authorized>
            <NotAuthorized>
                <button type="button" disabled class="btn btn-sm btn-info">@(userConfig.GetText("U5017"))</button>
            </NotAuthorized>
        </AuthorizeView>
        @if (userConfig.AllowManualOwnerAdmin)
        {
            <button type="button" class="btn btn-sm btn-warning" @onclick="ManageLifeCycles">@(userConfig.GetText("manage_lifecycles"))</button>
        }
        @if (ShowCleanupButton)
        {
            <button type="button" class="btn btn-sm btn-danger" @onclick="RequestRemoveSampleData">@(userConfig.GetText("remove_sample_data"))</button>
        }
        <br><br>
    </div>

    <div class="m-2 vheight75">
        <Table class="table table-bordered th-bg-secondary table-responsive overflow-auto sticky-header" TableItem="FwoOwner" Items="Owners" PageSize="0" ColumnReorder="true">
            <Column TableItem="FwoOwner" Title="@(userConfig.GetText("owners"))" Field="(x => x.Id)" Sortable="false" Filterable="false">
                <Template>
                    <div class="btn-group">
                    <button type="button" class="btn btn-sm btn-primary" @onclick="async () => await DisplayOwner(context)">@(userConfig.GetText("details"))</button>
                    @if(userConfig.AllowManualOwnerAdmin)
                    {
                        <button type="button" class="btn btn-sm btn-warning" @onclick="async () => await EditOwner(context)">@(userConfig.GetText("edit"))</button>
                        @if(!context.IsDefault)
                        {
                            <AuthorizeView Roles="@Roles.Admin" Context="ctx">
                                <Authorized>
                                    <button type="button" class="btn btn-sm btn-danger" @onclick="() => RequestDeleteOwner(context)">@(userConfig.GetText("delete"))</button>
                                </Authorized>
                                <NotAuthorized>
                                    <button type="button" disabled class="btn btn-sm btn-danger">@(userConfig.GetText("delete"))</button>
                                </NotAuthorized>
                            </AuthorizeView>
                        }
                    }
                    </div>
                </Template>
            </Column>
            <Column TableItem="FwoOwner" Title="@(userConfig.GetText("id"))" Field="@(x => x.Id)" Sortable="true" Filterable="true" />
            <Column TableItem="FwoOwner" Title="@(userConfig.GetText("name"))" Field="@(x => x.Name)" Sortable="true" Filterable="true" />
            @foreach (OwnerResponsibleType type in OwnerResponsibleTypes)
            {
                <Column TableItem="FwoOwner" Title="@(GetResponsibleTypeDisplayName(type))" Field="@(x => x.Id)" Sortable="false" Filterable="false">
                    <Template>
                        @FormatOwnerResponsibles(context.GetOwnerResponsiblesByType(type.Id))
                    </Template>
                </Column>
            }
            <Column TableItem="FwoOwner" Title="@(userConfig.GetText("tenant"))" Field="@(x => x.TenantId)" Sortable="true">
                <Template>
                    @(context.TenantId != null ? Tenants.FirstOrDefault(x => x.Id == context.TenantId)?.Name ?? "" : "" )
                </Template>
            </Column>
            <Column TableItem="FwoOwner" Title="@(userConfig.GetText("recert_interval"))" Field="@(x => x.RecertInterval)" Sortable="true" Filterable="true" />
            <Column TableItem="FwoOwner" Title="@(userConfig.GetText("ext_app_id"))" Field="@(x => x.ExtAppId)" Sortable="true" Filterable="true" />
            <Column TableItem="FwoOwner" Title="@(userConfig.GetText("import_source"))" Field="@(x => x.ImportSource)" Sortable="true" Filterable="true" />
        </Table>
    </div>

    <EditOwner @bind-Display="EditOwnerMode" Readonly="Readonly" ActOwner="ActOwner" OwnerResponsibleTypes="OwnerResponsibleTypes" Tenants="Tenants"
        OwnerLifeCycleStates="OwnerLifeCycleStates" ExistingOwners="Owners" OnSaved="HandleOwnerSaved" OnCancel="CancelOwnerEdit" />
    <ConfirmDelete @bind-Display="DeleteOwnerMode" PerformAction="DeleteOwner" Title="@userConfig.GetText("delete_owner")" DeleteMessage="@(userConfig.GetText("U5217") + ActOwner.Name + "?")"/>
    <ConfirmDelete @bind-Display="CleanupMode" PerformAction="RemoveSampleData" Title="@userConfig.GetText("remove_sample_data")" DeleteMessage="@CleanupMessage"/>
    <ManageOwnerLifeCycle @bind-Display="ManageLifeCyclesMode" OwnerLifeCycleStates="OwnerLifeCycleStates" Readonly="Readonly" />
}
else
{
    <Loading/>
}

@code
{
    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;

    private ConfigData? ConfigData;    
    private List<FwoOwner> Owners = [];
    private List<OwnerMappingSource> OwnerMappingSources = [];
    private OwnerMappingSource? SelectedOwnerMappingSources = null;
    private string OwnerMappingCustomFieldkey = "";
    private List<FwoOwner> SampleOwners = [];
    private FwoOwner ActOwner = new();
    private List<Tenant> Tenants = [];
    private List<OwnerLifeCycleState> OwnerLifeCycleStates = [];
    private List<OwnerResponsibleType> OwnerResponsibleTypes = [];

    private bool ShowCleanupButton = false;
    private bool CleanupMode = false;
    private string CleanupMessage = "";
    private bool EditOwnerMode = false;
    private bool Readonly = false;
    private bool DeleteOwnerMode = false;
    private bool InitComplete = false;
    private bool OwnerMappingCalcInProgress = false;
    private bool ManageLifeCyclesMode = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ConfigData = await globalConfig.GetEditableConfig();
            var updateOwnerRuleMappings = new UpdateRuleOwnerMapping(apiConnection, globalConfig);
            EventMediator.Subscribe<UpdateRuleOwnerMappingEvent>("UpdateOwnerRuleMappings", evt => _ = updateOwnerRuleMappings.HandleEvent(evt));
            Owners = await apiConnection.SendQueryAsync<List<FwoOwner>>(OwnerQueries.getOwners);
            OwnerMappingSources = (await apiConnection.SendQueryAsync<List<OwnerMappingSource>>(StmQueries.getOwnerMappingSources))
                .Where(oms => oms.Id != OwnerMappingSourceStm.MANUEL)
                .ToList();

            if (userConfig != null && userConfig.OwnerSoruceMappingID != 0)
            {
                SelectedOwnerMappingSources = OwnerMappingSources
                    .FirstOrDefault(oms => oms.Id == userConfig.OwnerSoruceMappingID);
            }
            if (userConfig != null && !string.IsNullOrWhiteSpace(userConfig.OwnerSourceCustomFieldKey))
            {
                OwnerMappingCustomFieldkey = userConfig.OwnerSourceCustomFieldKey;
            }

            OwnerLifeCycleStates = await apiConnection.SendQueryAsync<List<OwnerLifeCycleState>>(OwnerQueries.getOwnerLifeCycleStates);
            OwnerResponsibleTypes = await apiConnection.SendQueryAsync<List<OwnerResponsibleType>>(OwnerQueries.getOwnerResponsibleTypes);
            NormalizeResponsibleTypeInputs();
            AnalyseSampleOwners();

            RestResponse<List<TenantGetReturnParameters>> middlewareServerResponse = await middlewareClient.GetTenants();
            if (middlewareServerResponse.StatusCode != HttpStatusCode.OK || middlewareServerResponse.Data == null)
            {
                DisplayMessageInUi(null, userConfig!.GetText("get_tenant_data"), userConfig.GetText("E5284"), true);
            }
            else
            {
                Tenants = [];
                foreach (TenantGetReturnParameters apiTenant in middlewareServerResponse.Data)
                {
                    Tenants.Add(new Tenant(apiTenant));
                }
            }
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("fetch_data"), "", true);
        }
        InitComplete = true;
    }

    private async Task OwnerSourceImportNotifier()
    {
        try
        {
            var tcs = new TaskCompletionSource<bool>();

            var args = new UpdateRuleOwnerMappingEventArgs { isFullReInitialize = true, Completion = tcs };
            EventMediator.Publish("UpdateOwnerRuleMappings", new UpdateRuleOwnerMappingEvent(args));

            bool success = await tcs.Task;

            if (!success)   
            {
                DisplayMessageInUi(null, "No Rules/Owner or wrong Key-Field", "", true);
                return;
            }
            DisplayMessageInUi(null, "Import successful", "", false);
        }
        catch (Exception ex)
        {
            DisplayMessageInUi(ex, "Import error", "", true);
        }
    }

    private async Task SaveOwnerMappingSourceConfig()
    {
        try
        {
            if (ConfigData == null)
            {
                throw new ArgumentException("Data saved before loaded. This should be impossible.");
            }

            if (SelectedOwnerMappingSources == null)
            {
                DisplayMessageInUi(null, userConfig.GetText("modelling_settings"), userConfig.GetText("please_select_owner_mapping_source"), // eigenen Textkey anlege
                true);

                return;
            }
            if (SelectedOwnerMappingSources.Id == 2 && string.IsNullOrWhiteSpace(OwnerMappingCustomFieldkey))
            {
                DisplayMessageInUi(null, userConfig.GetText("modelling_settings"), userConfig.GetText("custom_field_key_missing"), // eigenen Textkey anlegen
                    true);

                return;
            }

            ConfigData.OwnerSoruceMappingID = SelectedOwnerMappingSources.Id;
            ConfigData.OwnerSourceCustomFieldKey = OwnerMappingCustomFieldkey;

            await globalConfig.WriteToDatabase(ConfigData, apiConnection);
            DisplayMessageInUi(null, userConfig.GetText("modelling_settings"), userConfig.GetText("U5301"), false); //TODO - message text new                        
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("modelling_settings"), "", true);
        }

    }

    private void AnalyseSampleOwners()
    {
        SampleOwners = [.. Owners.Where(o => o.Name.EndsWith(GlobalConst.k_demo))];
        ShowCleanupButton = (SampleOwners.Count > 0);
    }

    private void NormalizeResponsibleTypeInputs()
    {
        OwnerResponsibleTypes = OwnerResponsibleTypes
            .OrderBy(type => type.SortOrder)
            .ThenBy(type => type.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private async Task AddOwner()
    {
        await EditOwner(new FwoOwner());
    }

    private void ManageLifeCycles()
    {
        ManageLifeCyclesMode = true;
    }

    private async Task DisplayOwner(FwoOwner owner)
    {
        Readonly = true;
        await EditOwner(owner);
    }

    private async Task EditOwner(FwoOwner owner)
    {
        ActOwner = owner;
        ActOwner.OwnerResponsibles ??= [];
        EditOwnerMode = true;
        await Task.CompletedTask;
    }

    private Task HandleOwnerSaved()
    {
        AnalyseSampleOwners();
        EditOwnerMode = false;
        Readonly = false;
        return Task.CompletedTask;
    }

    private Task CancelOwnerEdit()
    {
        EditOwnerMode = false;
        Readonly = false;
        return Task.CompletedTask;
    }

    private void RequestDeleteOwner(FwoOwner owner)
    {
        ActOwner = owner;
        DeleteOwnerMode = true;
    }

    private async Task DeleteOwner()
    {
        try
        {
            await apiConnection.SendQueryAsync<ReturnId>(OwnerQueries.deleteOwner, new { id = ActOwner.Id });
            Owners.Remove(ActOwner);
            DeleteOwnerMode = false;

            Log.WriteAudit(
                Title: $"Owners Settings",
                Text: $"Deleted Owner: {ActOwner.Name} (Responsibles: {FormatOwnerResponsibles(ActOwner.GetAllOwnerResponsibles())})",
                UserName: userConfig.User.Name,
                UserDN: userConfig.User.Dn);
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("delete_owner"), "", true);
        }
        StateHasChanged();
    }

    private void RequestRemoveSampleData()
    {
        CleanupMessage = userConfig.GetText("U5218");
        CleanupMode = true;
    }

    private async Task RemoveSampleData()
    {
        foreach (var owner in SampleOwners)
        {
            ActOwner = owner;
            await DeleteOwner();
        }
        CleanupMode = false;
        ShowCleanupButton = false;
        StateHasChanged();
    }

    private static string FormatOwnerResponsibles(IEnumerable<string> dns)
    {
        List<string> formatted = [];
        foreach (string dn in dns.Where(dn => !string.IsNullOrWhiteSpace(dn)))
        {
            DistName distName = new(dn);
            string display = !string.IsNullOrWhiteSpace(distName.UserName) ? distName.UserName : distName.Group;
            formatted.Add(string.IsNullOrWhiteSpace(display) ? dn : display);
        }
        return string.Join(", ", formatted);
    }

    private string GetResponsibleTypeDisplayName(OwnerResponsibleType type)
    {
        string label = type.Name;
        if (!type.Active)
        {
            label += $" ({userConfig.GetText("inactive")})";
        }
        return label;
    }

    public void Dispose()
    {
        EventMediator.Unsubscribe<UpdateRuleOwnerMappingEvent>("UpdateOwnerRuleMappings");
    }
}
