@page "/settings/owners/responsibles"

@using FWO.Api.Client.Queries
@using FWO.Data
@using FWO.Logging
@using FWO.Ui.Services

@attribute [Authorize(Roles = $"{Roles.Admin}, {Roles.Auditor}")]

@inject ApiConnection apiConnection
@inject UserConfig userConfig

@if (initComplete)
{
    <div class="input-group">
        <h3>@(userConfig.GetText("responsibles"))</h3>
        <HelpLink Page="settings/responsibles"/>
    </div>
    <hr />
    @if (userConfig.AllowManualOwnerAdmin)
    {
        <div class="btn-group m-1">
            <button type="button" class="btn btn-sm btn-success" @onclick="AddResponsibleType">@(DisplayService.DisplayButton(userConfig, "add_responsible_type", Icons.Add))</button>
        </div>
    }

    <div class="m-2 vheight75">
        <Table class="table table-bordered th-bg-secondary table-responsive overflow-auto sticky-header" TableItem="OwnerResponsibleType" Items="responsibleTypes" PageSize="0" ColumnReorder="true">
            <Column TableItem="OwnerResponsibleType" Title="@(userConfig.GetText("responsibles"))" Field="(x => x.Id)" Sortable="false" Filterable="false">
                <Template>
                    <div class="btn-group">
                        @if (userConfig.AllowManualOwnerAdmin)
                        {
                            <button type="button" class="btn btn-sm btn-warning" @onclick="() => EditResponsibleType(context)">@(DisplayService.DisplayButton(userConfig, "edit", Icons.Edit))</button>
                            @if (!context.Active)
                            {
                                <button type="button" class="btn btn-sm btn-success" @onclick="async () => await ReactivateResponsibleType(context)">@(DisplayService.DisplayButton(userConfig, "reactivate", Icons.Add))</button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-sm btn-danger" @onclick="async () => await RequestDeleteResponsibleType(context)">@(DisplayService.DisplayButton(userConfig, "delete", Icons.Delete))</button>
                            }
                        }
                    </div>
                </Template>
            </Column>
            <Column TableItem="OwnerResponsibleType" Title="@(userConfig.GetText("id"))" Field="@(x => x.Id)" Sortable="true" Filterable="true" />
            <Column TableItem="OwnerResponsibleType" Title="@(userConfig.GetText("name"))" Field="@(x => x.Name)" Sortable="true" Filterable="true" />
                <Column TableItem="OwnerResponsibleType" Title="@(userConfig.GetText("active"))" Field="@(x => x.Active)" Sortable="true" Filterable="true">
                <Template Context="item">
                    @(item.Active.ShowAsHtml(withColors: true))
                </Template>
            </Column>
            <Column TableItem="OwnerResponsibleType" Title="@(userConfig.GetText("allow_modelling"))" Field="@(x => x.AllowModelling)" Sortable="true" Filterable="true">
                <Template Context="item">
                    @(item.AllowModelling.ShowAsHtml(withColors: true))
                </Template>
            </Column>
            <Column TableItem="OwnerResponsibleType" Title="@(userConfig.GetText("allow_recertification"))" Field="@(x => x.AllowRecertification)" Sortable="true" Filterable="true">
                <Template Context="item">
                    @(item.AllowRecertification.ShowAsHtml(withColors: true))
                </Template>
            </Column>
        </Table>
    </div>

    <PopUp Title="@(userConfig.GetText(AddMode ? "add_responsible_type" : "edit_responsible_type"))" Show="@EditMode" Size=PopupSize.Medium OnClose="CancelEdit">
        <Body>
            @if (EditMode)
            {
                <div class="form-group row mt-2">
                    <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("id")):</label>
                    <label class="col-sm-1 col-form-label col-form-label-sm">@actType.Id</label>
                </div>
                <div class="form-group row mt-2">
                    <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("name"))*:</label>
                    <div class="col-sm-7">
                        <input type="text" class="form-control form-control-sm" @bind="actType.Name" />
                    </div>
                </div>
                <div class="form-group row mt-2">
                    <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("active")):</label>
                    <div class="col-sm-1">
                        <input type="checkbox" class="form-check-input" @bind="actType.Active" />
                    </div>                    
                </div>
                <div class="form-group row mt-2">
                    <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("allow_modelling")):</label>
                    <div class="col-sm-1">
                        <input type="checkbox" class="form-check-input" @bind="actType.AllowModelling" />
                    </div>
                </div>
                <div class="form-group row mt-2">
                    <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("allow_recertification")):</label>
                    <div class="col-sm-1">
                        <input type="checkbox" class="form-check-input" @bind="actType.AllowRecertification" />
                    </div>
                </div>
                <div class="form-group row mt-2">
                    <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("sort_order")):</label>
                    <div class="col-sm-2">
                        <input type="number" class="form-control form-control-sm" @bind="actType.SortOrder" />
                    </div>
                </div>
            }
        </Body>
        <Footer>
            <div class="btn-group">
                <button type="button" class="btn btn-sm btn-primary" @onclick="SaveResponsibleType">@(DisplayService.DisplayButton(userConfig, "save", Icons.Save))</button>
                <button type="button" class="btn btn-sm btn-secondary" @onclick="CancelEdit">@(DisplayService.DisplayButton(userConfig, "cancel", Icons.Cancel))</button>
            </div>
        </Footer>
    </PopUp>

    <ConfirmDelete @bind-Display="DeleteTypeMode" PerformAction="DeleteResponsibleType" Title="@userConfig.GetText("responsibles")" DeleteMessage="@deleteTypeMessage" AllowedRoles="@($"{Roles.Admin}, {Roles.Auditor}")" />
}
else
{
    <Loading/>
}

@code
{
    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;

    private List<OwnerResponsibleType> responsibleTypes = [];
    private OwnerResponsibleType actType = new();
    private bool initComplete = false;
    private bool EditMode = false;
    private bool AddMode = false;
    private bool DeleteTypeMode = false;
    private string deleteTypeMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadTypes();
        initComplete = true;
    }

    private async Task LoadTypes()
    {
        try
        {
            responsibleTypes = await apiConnection.SendQueryAsync<List<OwnerResponsibleType>>(OwnerQueries.getOwnerResponsibleTypes);
            responsibleTypes = responsibleTypes
                .OrderBy(type => type.SortOrder)
                .ThenBy(type => type.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("fetch_data"), "", true);
        }
    }

    private void AddResponsibleType()
    {
        AddMode = true;
        EditMode = true;
        int nextOrder = responsibleTypes.Count == 0 ? 10 : responsibleTypes.Max(t => t.SortOrder) + 10;
        actType = new OwnerResponsibleType { Active = true, SortOrder = nextOrder, AllowModelling = false, AllowRecertification = false };
    }

    private void EditResponsibleType(OwnerResponsibleType type)
    {
        AddMode = false;
        EditMode = true;
        actType = new OwnerResponsibleType
        {
            Id = type.Id,
            Name = type.Name,
            Active = type.Active,
            SortOrder = type.SortOrder,
            AllowModelling = type.AllowModelling,
            AllowRecertification = type.AllowRecertification
        };
    }

    private void CancelEdit()
    {
        EditMode = false;
        AddMode = false;
    }

    private async Task SaveResponsibleType()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(actType.Name))
            {
                DisplayMessageInUi(null, userConfig.GetText("edit_responsible_type"), userConfig.GetText("E5102"), true);
                return;
            }

            if (AddMode)
            {
                var variables = new
                {
                    name = actType.Name,
                    active = actType.Active,
                    sort_order = actType.SortOrder,
                    allow_modelling = actType.AllowModelling,
                    allow_recertification = actType.AllowRecertification
                };
                ReturnId[]? returnIds = (await apiConnection.SendQueryAsync<ReturnIdWrapper>(OwnerQueries.newOwnerResponsibleType, variables)).ReturnIds;
                if (returnIds == null)
                {
                    DisplayMessageInUi(null, userConfig.GetText("add_responsible_type"), userConfig.GetText("E5291"), true);
                    return;
                }
                actType.Id = returnIds[0].NewId;
                responsibleTypes.Add(actType);
                Log.WriteAudit(Title: "Responsible Types Settings", Text: $"Added responsible type: {actType.Name}");
            }
            else
            {
                var variables = new
                {
                    id = actType.Id,
                    name = actType.Name,
                    active = actType.Active,
                    sort_order = actType.SortOrder,
                    allow_modelling = actType.AllowModelling,
                    allow_recertification = actType.AllowRecertification
                };
                int updatedId = (await apiConnection.SendQueryAsync<ReturnId>(OwnerQueries.updateOwnerResponsibleType, variables)).UpdatedId;
                if (updatedId != actType.Id)
                {
                    DisplayMessageInUi(null, userConfig.GetText("edit_responsible_type"), userConfig.GetText("E5291"), true);
                    return;
                }
                int index = responsibleTypes.FindIndex(t => t.Id == actType.Id);
                if (index >= 0)
                {
                    responsibleTypes[index] = actType;
                }
                Log.WriteAudit(Title: "Responsible Types Settings", Text: $"Updated responsible type: {actType.Name}");
            }
            await LoadTypes();
            EditMode = false;
            AddMode = false;
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("edit_responsible_type"), "", true);
        }
    }

    private async Task RequestDeleteResponsibleType(OwnerResponsibleType type)
    {
        actType = type;
        List<FwoOwner> ownersUsingType = await apiConnection.SendQueryAsync<List<FwoOwner>>(
            OwnerQueries.getOwnersForResponsibleType,
            new { responsibleTypeId = type.Id });
        deleteTypeMessage = ownersUsingType.Count > 0 && type.Active
            ? $"{userConfig.GetText("deactivate")} {type.Name}?"
            : $"{userConfig.GetText("delete")} {type.Name}?";
        DeleteTypeMode = true;
    }

    private async Task DeleteResponsibleType()
    {
        try
        {
            List<FwoOwner> ownersUsingType = await apiConnection.SendQueryAsync<List<FwoOwner>>(
                OwnerQueries.getOwnersForResponsibleType,
                new { responsibleTypeId = actType.Id });

            if (ownersUsingType.Count > 0)
            {
                await DeactivateResponsibleType(actType);
            }
            else
            {
                ReturnId[]? returnIds = (await apiConnection.SendQueryAsync<ReturnIdWrapper>(
                    OwnerQueries.deleteOwnerResponsibleType, new { id = actType.Id })).ReturnIds;
                if (returnIds == null || returnIds.Length == 0)
                {
                    DisplayMessageInUi(null, userConfig.GetText("delete"), userConfig.GetText("E5291"), true);
                    return;
                }
                responsibleTypes.RemoveAll(type => type.Id == actType.Id);
                Log.WriteAudit(Title: "Responsible Types Settings", Text: $"Deleted responsible type: {actType.Name}");
            }
            await LoadTypes();
            DeleteTypeMode = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("delete"), "", true);
        }
    }

    private async Task DeactivateResponsibleType(OwnerResponsibleType type)
    {
        if (type.Active)
        {
            var updateVariables = new
            {
                id = type.Id,
                name = type.Name,
                active = false,
                sort_order = type.SortOrder,
                allow_modelling = type.AllowModelling,
                allow_recertification = type.AllowRecertification
            };
            int updatedId = (await apiConnection.SendQueryAsync<ReturnId>(OwnerQueries.updateOwnerResponsibleType, updateVariables)).UpdatedId;
            if (updatedId == type.Id)
            {
                Log.WriteAudit(Title: "Responsible Types Settings", Text: $"Deactivated responsible type (still in use): {type.Name}");
            }
            else
            {
                DisplayMessageInUi(null, userConfig.GetText("edit_responsible_type"), userConfig.GetText("E5291"), true);
            }
        }
    }

    private async Task ReactivateResponsibleType(OwnerResponsibleType type)
    {
        try
        {
            var updateVariables = new
            {
                id = type.Id,
                name = type.Name,
                active = true,
                sort_order = type.SortOrder,
                allow_modelling = type.AllowModelling,
                allow_recertification = type.AllowRecertification
            };
            int updatedId = (await apiConnection.SendQueryAsync<ReturnId>(OwnerQueries.updateOwnerResponsibleType, updateVariables)).UpdatedId;
            if (updatedId != type.Id)
            {
                DisplayMessageInUi(null, userConfig.GetText("edit_responsible_type"), userConfig.GetText("E5291"), true);
                return;
            }
            Log.WriteAudit(Title: "Responsible Types Settings", Text: $"Reactivated responsible type: {type.Name}");
            await LoadTypes();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("edit_responsible_type"), "", true);
        }
    }

}
