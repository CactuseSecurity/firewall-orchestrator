@typeparam TItem
@using BlazorTable

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
    <div class="input-group input-group-sm cwidth-400">
        <span class="input-group-text">@SearchLabel</span>
        <input type="text" class="form-control" @bind="SearchText" @bind:event="oninput" />
        @if (!string.IsNullOrWhiteSpace(SearchText))
        {
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ClearSearch">
                <span class="@Icons.Cancel"></span>
            </button>
        }
    </div>
</div>

<div class="text-muted small mb-2">
    @($"{FilteredCount} / {TotalCount}")
</div>

<Table TableClass="@TableClass"
       TableItem="TItem"
       Items="FilteredItems"
       PageSize="PageSize"
       ColumnReorder="true">
    @ChildContent
</Table>

@code
{
    [Parameter, EditorRequired]
    public IEnumerable<TItem> FilteredItems { get; set; } = [];

    [Parameter, EditorRequired]
    public RenderFragment? ChildContent { get; set; }

    [Parameter, EditorRequired]
    public string SearchLabel { get; set; } = "";

    [Parameter]
    public string SearchText { get; set; } = "";

    [Parameter]
    public EventCallback<string> SearchTextChanged { get; set; }

    [Parameter]
    public int FilteredCount { get; set; }

    [Parameter]
    public int TotalCount { get; set; }

    [Parameter]
    public int PageSize { get; set; } = 25;

    [Parameter]
    public string TableClass { get; set; } = "table table-sm table-bordered th-bg-secondary table-responsive overflow-auto sticky-header";

    private async Task ClearSearch()
    {
        SearchText = "";
        await SearchTextChanged.InvokeAsync(SearchText);
    }
}
