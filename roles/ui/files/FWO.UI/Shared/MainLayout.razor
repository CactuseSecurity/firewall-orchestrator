@inherits LayoutComponentBase
@using FWO.Data.Middleware
@using FWO.Middleware.Client
@using FWO.Services.EventMediator
@using FWO.Services.EventMediator.Events
@using FWO.Services.EventMediator.Interfaces
@using FWO.Services
@using FWO.Ui.Auth
@using FWO.Ui.Data
@using FWO.Ui.Services
@using System.Timers
@using System.Security.Claims;
@using Microsoft.AspNetCore.Components.Server.Circuits;
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using RestSharp
@using System.IdentityModel.Tokens.Jwt

@inject ApiConnection apiConnection
@inject GlobalConfig globalConfig
@inject UserConfig userConfig
@inject MiddlewareClient middlewareClient
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider authenticationProvider
@inject ProtectedSessionStorage sessionStorage
@inject CircuitHandler circuitHandler
@inject TokenService tokenService
@inject IEventMediator EventMediator

@implements IDisposable

<NavigationMenu @bind-ShowAlert="showAlert" />

<div class="main">
    <div class="content px-4">
        @* DON'T DELETE THESE BUTTONS / They might be needed for testing *@
        @*         <button type="button" @onclick="@(() => ShowMessage("info", "info", MessageType.Info))">info</button>
        <button type="button" @onclick="@(() => ShowMessage("warning", "warning", MessageType.Warning))">warning</button>
        <button type="button" @onclick="@(() => ShowMessage("error", "error", MessageType.Error))">error</button>
        <button type="button" @onclick="@(() => ShowMessage("success", "success", MessageType.Success))">success</button>
        <button type="button" @onclick="@(() => {  UIMessageQue.Clear(); UIMessages.Clear(); })">clear</button> *@
        <CascadingValue Value="@DisplayMessageInUiFunction">
            @Body
        </CascadingValue>
    </div>
</div>

<div class="footer">
    @if (IsDebugBuild)
    {
        <div class="ms-auto m-2 w-25">
            <div class="alert alert-info py-2 px-3 small" role="status">
                <div class="mb-2"><strong class="text-black">Debug Token Expiry</strong></div>
                <div><strong class="text-primary">Access:</strong> @debugAccessTokenCountdown</div>
                <div class="mb-2"><strong class="text-danger">Refresh:</strong> @debugRefreshTokenCountdown</div>
                <button class="btn btn-sm btn-dark" @onclick="@(async () => await tokenService.RefreshTokenPair(force: true))">Refresh Tokens</button>
                <button class="btn btn-sm btn-danger" @onclick="@(async () => { await tokenService.RevokeTokens(); EventMediator.Publish(nameof(JwtExpiredEvent), new JwtExpiredEvent(new(userConfig.User.Dn))); })">Revoke Tokens</button>
                <button class="btn btn-sm btn-warning @Icons.Display" @onclick="@(_ => showTokens = !showTokens)"><span class="ps-1">@(showTokens ? "Hide" : "Show")</span></button>
                @if (showTokens)
                {
                    TokenPair? token = tokenService.GetTokenPair().GetAwaiter().GetResult();
                    <div class="mt-2">
                        <div class="mb-2"><strong class="text-primary">Access:</strong> <p class="word-wrap">@token?.AccessToken</p></div>
                        <div><strong class="text-danger">Refresh:</strong> <p class="word-wrap">@token?.RefreshToken</p></div>
                    </div>
                }
            </div>
        </div>
    }
    <div class="mx-2">
        @foreach (UIMessage uiMessage in UIMessages)
        {
            <div class="@uiMessage.CSSClass">
                <div class="d-flex flex-row justify-content-between">
                    <div>@uiMessage.Title - @uiMessage.Message</div>
                    <div class="@Icons.Close cursor-pointer" @onclick="@(() => HideUIMessage(uiMessage.Id))"></div>
                </div>
            </div>
        }
    </div>
</div>
<PopUp Title="@(reloginDialogTitle)" Show="@(showReloginDialog)" Size=PopupSize.Auto>

    <Body>
        <p>@(reloginDialogText)</p>
        <div class="input-group">
            <div class="input-group-prepend">
                <span class="input-group-text"><span class="@Icons.Locked"></span></span>
            </div>
            <input type="password" class="form-control @reloginCssClass" @bind="password"
                   placeholder="@(userConfig.GetText("password"))" @bind:event="oninput" @onkeypress="@KeyHandler">
            </div>
            @if (!string.IsNullOrEmpty(reloginErrorMessage))
            {
                <label class="mt-1 mb-1 text-danger">@reloginErrorMessage</label>
            }
        </Body>
        <Footer>
            <div class="btn-group">
                @if (reloginAbortable)
                {
                    <button type="button" class="btn btn-secondary" @onclick="@(() => showReloginDialog = false)">
                        @(userConfig.GetText("cancel"))
                    </button>
                }
                else
                {
                    <a class="btn btn-danger" href="/logout">@(userConfig.GetText("logout"))</a>
                }
                <button type="button" class="btn btn-primary" @onclick="Relogin">@(userConfig.GetText("relogin"))</button>
            </div>
        </Footer>
    </PopUp>

<KeyboardInput />

@code
{
    Action<Exception?, string, string, bool> DisplayMessageInUiFunction = DefaultInit.DoNothing;

    [CascadingParameter]
    private Task<AuthenticationState>? authenticationStateTask { get; set; }

    private GraphQlApiSubscription<List<Alert>>? alertSubscription;
    private bool showAlert = false;
    private object errorLock = new object();

    private string reloginErrorMessage = "";
    private string reloginCssClass = "";
    private string reloginDialogTitle = "";
    private string reloginDialogText = "";
    private bool showReloginDialog;
    private bool reloginAbortable;
    private string? password;
    private ClaimsPrincipal? user;
    private bool showTokens { get; set; }

    private List<UIMessage> UIMessages = [];
    private Queue<UIMessage> UIMessageQue = [];

    private Timer? UIMessageQueTimer;
    private PeriodicTaskRunner? tokenRefreshRunner;

    private string? LastLocation;
    private static readonly TimeSpan TokenRefreshCheckInterval = TimeSpan.FromSeconds(30);

#if DEBUG
    private const bool IsDebugBuild = true;
#else
    private const bool IsDebugBuild = false;
#endif

    private PeriodicTaskRunner? debugTokenClockRunner;
    private string debugAccessTokenCountdown = "n/a";
    private string debugRefreshTokenCountdown = "n/a";

    protected override async Task OnInitializedAsync()
    {
        DisplayMessageInUiFunction = DisplayMessageInUi;

        await CheckAndRefreshTokenAsync();

        EventMediator.Subscribe<PermissionChangedEvent>(nameof(PermissionChangedEvent), _ => OnPermissionsChanged(_.EventArgs));
        EventMediator.Subscribe<JwtExpiredEvent>(nameof(JwtExpiredEvent), _ => OnJwtExpired(_.EventArgs));

        NavigationManager.LocationChanged += OnLocationChanged;

        user = authenticationStateTask!.Result.User;

        alertSubscription = apiConnection.GetSubscription<List<Alert>>(ApiExceptionHandler, OnAlertUpdate, MonitorQueries.subscribeAlertChanges);

        UIMessageQueTimer = new()
        {
            AutoReset = true,
            Enabled = false,
            Interval = 500
        };

        UIMessageQueTimer.Elapsed += OnUIMessageTimerTick;

        tokenRefreshRunner = new(() => InvokeAsync(CheckAndRefreshTokenAsync), TokenRefreshCheckInterval);
        tokenRefreshRunner.Start();

        if (IsDebugBuild)
        {
            await UpdateDebugTokenCountdownAsync();
            debugTokenClockRunner = new(() => InvokeAsync(UpdateDebugTokenCountdownAsync), TimeSpan.FromSeconds(1));
            debugTokenClockRunner.Start();
        }
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (LastLocation != e.Location)
        {
            LastLocation = e.Location;

            await CheckAndRefreshTokenAsync();
        }
    }

    private async Task CheckAndRefreshTokenAsync()
    {
        try
        {
            if (!await tokenService.HasRefreshToken())
            {
                return;
            }

            if (await tokenService.IsAccessTokenExpired())
            {
                if (IsDebugBuild)
                {
                    ShowMessage("Access Token expired", "Your Access Token is expired, attempting refresh...", MessageType.Info);
                }
                Log.WriteDebug("Token Check", "Access token expired, attempting refresh...");

                CircuitHandlerService circuitHandlerService = (CircuitHandlerService)circuitHandler;

                bool refreshed = await ((AuthStateProvider)authenticationProvider).RefreshAuthenticationState(apiConnection, middlewareClient, userConfig, circuitHandlerService);

                if (refreshed)
                {
                    user = (await authenticationProvider.GetAuthenticationStateAsync()).User;

                    if (IsDebugBuild)
                    {
                        ShowMessage("Access Token refreshed", "Access Token was refreshed.", MessageType.Success);
                        await UpdateDebugTokenCountdownAsync();
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Log.WriteError("Token Check", "Error during token check/refresh", ex);
        }
    }

    private async Task KeyHandler(KeyboardEventArgs ev)
    {
        if (ev.Code == "Enter")
        {
            await Relogin();
        }
        reloginCssClass = "";
    }

    private void OnPermissionsChanged(PermissionChangedEventArgs? e)
    {
        if (e?.UserDn == userConfig.User.Dn)
        {
            ShowReloginDialog(userConfig.GetText("permissions"), userConfig.GetText("permissions_text"), reloginAbortable: false);
        }
    }

    private void OnJwtExpired(JwtExpiredEventArgs? e)
    {
        if (IsDebugBuild)
        {
            ShowMessage(userConfig.GetText("jwt_expired_title"), userConfig.GetText("jwt_expired_text"), MessageType.Error);
        }

        if (user?.Identity?.IsAuthenticated == true && !string.IsNullOrWhiteSpace(e?.UserDn) && e.UserDn == userConfig.User.Dn)
        {
            ShowReloginDialog(userConfig.GetText("jwt_expired_title"), userConfig.GetText("jwt_expired_text"), reloginAbortable: false);
        }
    }

    private void ShowReloginDialog(string title, string text, bool reloginAbortable)
    {
        reloginErrorMessage = "";
        password = "";
        this.reloginAbortable = reloginAbortable;
        reloginDialogTitle = title;
        reloginDialogText = text;
        showReloginDialog = true;

        InvokeAsync(StateHasChanged);
    }

    private async Task Relogin()
    {
        string errorMessage = userConfig.GetText("relogin_error");

        if (password == null)
        {
            password = "";
        }
        try
        {
            RestResponse<TokenPair> authResponse = await ((AuthStateProvider)authenticationProvider)
                .Authenticate(userConfig.User.Name, password, apiConnection, middlewareClient, userConfig, ((CircuitHandlerService)circuitHandler));

            if (authResponse.StatusCode == System.Net.HttpStatusCode.OK)
            {
                showReloginDialog = false;
                reloginErrorMessage = "";
                password = "";
                return;
            }
            // There was an error trying to authenticate the user. Probably invalid credentials
            errorMessage = (authResponse.Content != null ? userConfig.GetApiText(authResponse.Content) : "Middleware Api Error: " + authResponse.Content);
        }
        catch (Exception ex)
        {
            Log.WriteError("Re-login", "Re-login unsuccessful.", ex, userConfig.User.Name);
        }

        reloginErrorMessage = errorMessage;
        reloginCssClass = "is-invalid";
    }

    private void OnAlertUpdate(List<Alert> alerts)
    {
        user = authenticationStateTask!.Result.User;
        showAlert = (user.IsInRole(Roles.Admin) || user.IsInRole(Roles.FwAdmin) || user.IsInRole(Roles.Auditor)) && alerts.Count() > 0;

        InvokeAsync(StateHasChanged);
    }

    private void ShowMessage(string title, string message, MessageType type, int? showtime = null)
    {
        // Needed so there is no chance an error is announced by 2 threads at the same time.
        lock (errorLock)
        {
            if (showtime == null || showtime == 0)
            {
                showtime = userConfig.MessageViewTime * 1000; // convert to milliseconds
            }

            switch (type)
            {
                case MessageType.Error:
                    Task.Run(async () => await setAlert(title, message));
                    showtime = showtime * 3; // show errors a bit longer
                    break;
                default:
                    break;
            }

            UIMessage uiMessage = new()
            {
                Message = message,
                Title = title,
                Type = type
            };

            Timer messageTimer = new Timer(showtime.Value);
            messageTimer.Elapsed += (sender, e) => HideMessage(sender, e, uiMessage.Id);
            messageTimer.AutoReset = false;

            uiMessage.ShowTimer = messageTimer;

            if (UIMessages.Count < userConfig.MaxMessages)
            {
                messageTimer.Start();
                UIMessages.Add(uiMessage);
                InvokeAsync(StateHasChanged);
            }
            else
            {
                UIMessageQue.Enqueue(uiMessage);
            }

            UIMessageQueTimer?.Start();
        }
    }

    private void HideMessage(object? _, ElapsedEventArgs __, string messageId)
    {
        HideUIMessage(messageId);
    }

    private void OnUIMessageTimerTick(object? _, ElapsedEventArgs __)
    {
        if (UIMessageQueTimer is null)
        {
            return;
        }

        if (UIMessageQue == null || UIMessageQue.Count == 0)
        {
            UIMessageQueTimer.Stop();
            return;
        }

        if (UIMessageQue.Count > 0 && UIMessages.Count < userConfig.MaxMessages)
        {
            UIMessage uiMessage = UIMessageQue.Dequeue();
            uiMessage.ShowTimer!.Start();
            UIMessages.Add(uiMessage);

            InvokeAsync(StateHasChanged);
        }
    }

    private void HideUIMessage(string messageId)
    {
        UIMessage? uiMessage = UIMessages.FirstOrDefault(_ => _.Id == messageId);

        if (uiMessage is null)
        {
            return;
        }

        uiMessage.Dispose();

        UIMessages.RemoveAll(_ => _.Id == messageId);

        InvokeAsync(StateHasChanged);
    }

    private void DisplayMessageInUi(Exception? exception = null, string title = "", string message = "", bool ErrorFlag = false)
    {
        int severity = 0;
        string cause = "";
        string description = "";
        MessageType messageType = MessageType.Info;

        if (exception == null)
        {
            cause = title;
            description = message;
            if (ErrorFlag)
            {
                // User message to be displayed as error
                Log.WriteWarning(title, message);
                messageType = MessageType.Warning;
                severity = 1;
            }
            else
            {
                // User message is no error
                messageType = MessageType.Success;
            }
        }
        else
        {
            messageType = MessageType.Error;

            // first some recurring specific messages
            if (exception.Message.Contains("JWTExpired"))
            {
                Log.WriteError("Auth Token Error", "JWT expired in session.", exception);
                // TODO: Improve error handling for jwt expiry / api unreachable, so that no action leads to unhandled exception
                if (!showReloginDialog)
                {
                    showReloginDialog = true;
                    ShowMessage(userConfig.GetText("jwt_expired_title"), userConfig.GetText("jwt_expired_text"), MessageType.Info, showtime: -1);
                }
                return;
            }
            else if (exception.Message == "no such type exists in the schema: 'cidr'")
            {
                // this is the default error message when user's access rights are not sufficient for API access
                severity = 2;
                cause = userConfig.GetText("api_access");
                description = userConfig.GetText("E0004");
            }
            else
            {
                string role = "";
                if (apiConnection is GraphQlApiConnection)
                {
                    role = ((GraphQlApiConnection)apiConnection).GetActRole();
                }
                else
                {
                    try
                    {
                        JwtReader jwtReader = new(userConfig.User.Jwt);
                        Task.Run(async () => await jwtReader.Validate());
                        role = jwtReader.GetRole();
                    }
                    catch (Exception) { }
                }
                
                Log.WriteError((title != "" ? title : "Unspecified Error"), (message != "" ? message : "Unspecified error occured: "), exception, userConfig.User.Name, role);
                
                severity = 2;
                cause = (title != "" ? title : userConfig.GetText("unspecified_error"));
                description = $"{(message != "" ? message : userConfig.GetText("E0001"))}" + (ErrorFlag ? $": {exception.Message}" : "") + " . " + userConfig.GetText("E0002");
            }
        }

        ShowMessage(cause, description, messageType);

        Task.Run(async () => await AddUiLogEntry(severity, cause, description));
    }

    public async Task AddUiLogEntry(int severity, string cause, string description)
    {
        try
        {
            var Variables = new
            {
                user = userConfig.User.DbId,
                severity = severity,
                suspectedCause = cause,
                description = description,
            };

            ReturnId[]? returnIds = (await apiConnection.SendQueryAsync<ReturnIdWrapper>(MonitorQueries.addUiLogEntry, Variables)).ReturnIds;
            
            if (returnIds == null)
            {
                Log.WriteError("Write Log", "Log could not be written to database");
            }
        }
        catch (Exception exc)
        {
            Log.WriteError("Write Log", $"Could not write log for user {userConfig.User.DbId}: ", exc);
        }
    }

    private void ApiExceptionHandler(Exception exception)
    {
        Log.WriteError("Alarm Handling", "Api subscription lead to exception. Retry subscription.", exception);
        // Subscription will be restored if no exception is thrown here
    }

    public async Task setAlert(string title, string message)
    {
        Log.WriteAlert($"source: \"{GlobalConst.kUi}\"", $"userId: \"{userConfig.User.DbId}\", title: \"{title}\", description: \"{message}\", alertCode: \"{AlertCode.UiError}\"");
        AlertHelper.AdditionalAlertData alertData = new()
        {
            UserId = userConfig.User.DbId,
            CompareTitle = true
        };
        await AlertHelper.SetAlert(apiConnection, title, message, GlobalConst.kUi, AlertCode.UiError, alertData);
    }

    public void Dispose()
    {
        if (UIMessageQueTimer is not null)
        {
            UIMessageQueTimer.Stop();
            UIMessageQueTimer.Elapsed -= OnUIMessageTimerTick;
            UIMessageQueTimer.Dispose();
        }

        alertSubscription?.Dispose();
        tokenRefreshRunner?.Dispose();
        debugTokenClockRunner?.Dispose();
        NavigationManager.LocationChanged -= OnLocationChanged;
        EventMediator.Unsubscribe<PermissionChangedEvent>(nameof(PermissionChangedEvent));
        EventMediator.Unsubscribe<JwtExpiredEvent>(nameof(JwtExpiredEvent));

    }

    private async Task UpdateDebugTokenCountdownAsync()
    {
        (DateTime? accessExpiresAtUtc, DateTime? refreshExpiresAtUtc) = await tokenService.GetTokenExpirations();

        debugAccessTokenCountdown = FormatTokenExpiryCountdown(accessExpiresAtUtc);
        debugRefreshTokenCountdown = FormatTokenExpiryCountdown(refreshExpiresAtUtc);

        StateHasChanged();
    }

    private static string FormatTokenExpiryCountdown(DateTime? expiresAtUtc)
    {
        if (!expiresAtUtc.HasValue)
        {
            return "n/a";
        }

        TimeSpan remaining = expiresAtUtc.Value - DateTime.UtcNow;
        string expiresAtLabel = expiresAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");

        if (remaining <= TimeSpan.Zero)
        {
            return $"expired {FormatDuration(remaining.Duration())} ago ({expiresAtLabel})";
        }

        return $"in {FormatDuration(remaining)} ({expiresAtLabel})";
    }

    private static string FormatDuration(TimeSpan duration)
    {
        return $"{Math.Floor(duration.TotalDays):00}d {duration.Hours:00}h {duration.Minutes:00}m {duration.Seconds:00}s";
    }
}
